@page "/"
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.Net.Http.Json
@using Kohinoorea.Shared.Models.Commerce
@using Kohinoorea.Client.Services

<PageTitle>Index</PageTitle>
<main>
    <section class="hero hero-split">
        <div class="container hero-split-shell">
            <div class="hero-split-content">
                <div class="hero-split-left">
                    <div class="hero-kicker">Built for XAUUSD precision on MT4</div>
                    <h1>Built to Perform. <span class="hero-highlight">Designed to Dominate.</span></h1>
                    <p class="hero-lead">Kohinoor EA is a premium MT4 automation system for traders who want structured execution, risk-aware trade handling, and a more professional approach to XAUUSD trading.</p>

                    <div class="hero-features">
                        <div class="hero-feature">
                            <svg class="hero-feature-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                            <span>0ms Latency</span>
                        </div>
                        <div class="hero-feature">
                            <svg class="hero-feature-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
                            <span>Encrypted Keys</span>
                        </div>
                        <div class="hero-feature">
                            <svg class="hero-feature-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            <span>24/7 Execution</span>
                        </div>
                        <div class="hero-feature">
                            <svg class="hero-feature-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                            <span>Real-time Analytics</span>
                        </div>
                    </div>

                    <div class="hero-actions">
                        <a class="button button-gold" href="/pricing#plans">Join Our Network</a>
                        <a class="button button-secondary" href="/performance">View Performance</a>
                    </div>

                    <div class="broker-strip" aria-label="Supported brokers">
                        <div class="broker-strip-label">Supported Brokers</div>
                        <div class="broker-marquee">
                            <div class="broker-track">
                                <span class="broker-chip"><strong>IC</strong> IC Markets</span>
                                <span class="broker-chip"><strong>PE</strong> PepperStone</span>
                                <span class="broker-chip"><strong>CF</strong> CFI</span>
                                <span class="broker-chip"><strong>XM</strong> XM Groups</span>
                                <span class="broker-chip"><strong>EX</strong> Exness</span>
                                <span class="broker-chip"><strong>VA</strong> Vantage</span>
                                <span class="broker-chip"><strong>GT</strong> GTC</span>
                                <span class="broker-chip"><strong>IC</strong> IC Markets</span>
                                <span class="broker-chip"><strong>PE</strong> PepperStone</span>
                                <span class="broker-chip"><strong>CF</strong> CFI</span>
                                <span class="broker-chip"><strong>XM</strong> XM Groups</span>
                                <span class="broker-chip"><strong>EX</strong> Exness</span>
                                <span class="broker-chip"><strong>VA</strong> Vantage</span>
                                <span class="broker-chip"><strong>GT</strong> GTC</span>
                            </div>
                        </div>
                    </div>

                    @if (isLoggedIn)
                    {
                        <div class="plan-strip" aria-label="Popular plan">
                            <div class="plan-strip-label">Popular Plan</div>
                            @if (!string.IsNullOrWhiteSpace(productStatusMessage))
                            {
                                <p class="summary-caption" style="margin:0.25rem 0 0.75rem;">@productStatusMessage</p>
                            }
                            <div class="plan-marquee">
                                <div class="plan-track">
                                    @foreach (var product in MarqueeProducts)
                                    {
                                        <div class="plan-card plan-clickable" role="button" tabindex="0" @onclick="() => NavigateToBuyProduct(product.Id)">
                                            <div class="plan-media">
                                                <img src="@GetProductImageUrl(product)" alt="@product.Name" loading="lazy" />
                                                <div class="plan-overlay">
                                                    <div class="plan-overlay-title">@product.Name</div>
                                                    <div class="plan-overlay-badge">@FormatUsd(product.Price)</div>
                                                </div>
                                            </div>
                                            <div class="plan-price" aria-hidden="true">@FormatUsd(product.Price)</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <!-- ...existing code... -->
                </div> <!-- close hero-split-left -->
                <div class="hero-stats-bar">
                    <div class="auth-panel">
                        <div class="auth-card">
                            @if (!isLoggedIn)
                            {
                                <div class="auth-tabs">
                                    <button class="auth-tab active" data-tab="signin">Sign In</button>
                                    <button class="auth-tab" data-tab="signup">Sign Up</button>
                                </div>
                                <!-- Sign In Content -->
                                <div class="auth-content" id="signin-content">
                                    <div class="auth-header-block">
                                        <h2 class="auth-heading">Welcome Back</h2>
                                        <p class="auth-subheading">Sign in to your dashboard</p>
                                    </div>
                                    <div class="role-segment" id="role-segment">
                                        <button class="role-segment-btn active" data-role="trader">
                                            <svg class="role-seg-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                                            Trader
                                        </button>
                                        <button class="role-segment-btn" data-role="admin">
                                            <svg class="role-seg-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                            Admin
                                        </button>
                                    </div>
                                    <div class="auth-form">
                                        <div class="form-group">
                                            <label class="form-label">Email</label>
                                            <div class="input-wrapper">
                                                <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                                                <input type="email" class="form-input" placeholder="you@example.com" @bind="indexLoginEmail" @bind:event="oninput">
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <div class="form-label-row">
                                                <label class="form-label">Password</label>
                                                <a href="#" class="forgot-password">Forgot Password?</a>
                                            </div>
                                            <div class="input-wrapper">
                                                <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                                                <input type="password" class="form-input" placeholder="Enter your password" @bind="indexLoginPassword" @bind:event="oninput">
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(indexLoginMessage))
                                        {
                                            <p class="signin-footer" style="color:#f87171;">@indexLoginMessage</p>
                                        }
                                        <button type="button" class="auth-submit-button" @onclick="HandleIndexLoginAsync" disabled="@indexLoginBusy">
                                            <span class="submit-text">@(indexLoginBusy ? "Signing in..." : "Sign in as Trader")</span>
                                            <svg class="button-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                                        </button>
                                    </div>
                                    <p class="signin-footer">Don't have an account? <a href="#" class="signin-footer-link" data-switch-tab="signup">Sign up free</a></p>
                                </div>
                                <!-- Sign Up Content -->
                                <div class="auth-content" id="signup-content" style="display: none;">
                                    <h2 class="auth-heading">Create Account</h2>
                                    <p class="auth-subheading">Choose your portal to get started</p>
                                    <div class="signup-portals">
                                        <div class="portal-card portal-trader">
                                            <div class="portal-icon">
                                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                                            </div>
                                            <div class="portal-info">
                                                <h3 class="portal-title">Trader</h3>
                                                <p class="portal-desc">Access trading robots & manage licenses</p>
                                            </div>
                                            <a class="portal-signup-button" href="/registration">
                                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                                                Sign Up as Trader
                                            </a>
                                        </div>
                                        <div class="portal-card portal-admin">
                                            <div class="portal-icon">
                                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                                            </div>
                                            <div class="portal-info">
                                                <h3 class="portal-title">Admin</h3>
                                                <p class="portal-desc">Invite only - contact administrator</p>
                                            </div>
                                            <button class="portal-signup-button portal-disabled" disabled>
                                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                                                Invite Only
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="auth-logout-card" style="position:relative;display:flex;flex-direction:column;align-items:center;padding:2rem 1.5rem;">
                                    <div class="premium-card" style="position:relative;width:100%;max-width:480px;padding:40px 30px;border-radius:32px;overflow:hidden;background:linear-gradient(145deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03));backdrop-filter:blur(18px);border:1px solid rgba(242,202,119,0.25);box-shadow:0 25px 80px rgba(0,0,0,0.45),0 0 40px rgba(242,202,119,0.12);">
                                        <button class="logout-btn" @onclick="HandleLogoutAsync" style="position:absolute;top:20px;right:20px;width:44px;height:44px;border-radius:50%;border:1px solid rgba(242,202,119,0.25);background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.25s;">
                                            <svg width="22" height="22" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="stroke:#f2ca77;">
                                                <path d="M17 16l4-4m0 0l-4-4m4 4H7" />
                                                <path d="M9 20a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h4" />
                                            </svg>
                                        </button>

                                        <div class="avatar" style="width:84px;height:84px;margin:auto;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2.4rem;font-weight:900;color:#1f1400;background:linear-gradient(135deg,#fff4c6,#f2ca77,#d97706);box-shadow:0 0 30px rgba(242,202,119,0.4);">
                                            @(!string.IsNullOrWhiteSpace(loggedInUserName) ? loggedInUserName.Substring(0, 1).ToUpper() : "T")
                                        </div>

                                        <h1 class="title" style="margin-top:22px;text-align:center;font-size:2rem;font-weight:900;color:#f8d98b;">
                                            Welcome, @loggedInUserName!
                                        </h1>

                                        <p class="subtitle" style="margin-top:12px;text-align:center;line-height:1.7;color:rgba(255,255,255,0.72);">
                                            Unlock premium trading robots, elite analytics, priority onboarding, and exclusive launch offers.
                                        </p>

                                        <div class="offer" style="margin:26px auto 0;width:max-content;padding:14px 28px;border-radius:999px;background:linear-gradient(90deg,#f2ca77,#ffb347);color:#1f1400;font-weight:900;letter-spacing:.06em;box-shadow:0 10px 25px rgba(242,202,119,0.28);">
                                            LAUNCH15 · 15% OFF
                                        </div>
                                        <div class="plans" style="margin-top:42px;">
                                            <div class="plans-title" style="text-align:center;font-size:1.2rem;font-weight:800;color:#f8d98b;margin-bottom:20px;">Choose Your Premium Plan</div>
                                            <div class="plan-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:18px;">
                                                @if (GridProducts.Count == 0)
                                                {
                                                    <div class="plan-card">
                                                        <div class="plan-name">No products yet</div>
                                                        <div class="plan-promo">Admin hasn’t posted plans yet.</div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @foreach (var product in GridProducts)
                                                    {
                                                        <div class="plan-card plan-clickable" role="button" tabindex="0" @onclick="() => NavigateToBuyProduct(product.Id)">
                                                            <div class="plan-media">
                                                                <img src="@GetProductImageUrl(product)" alt="@product.Name" loading="lazy" />
                                                                <div class="plan-overlay">
                                                                    <div class="plan-overlay-title">@product.Name</div>
                                                                    <div class="plan-overlay-badge">@FormatUsd(product.Price)</div>
                                                                </div>
                                                            </div>
                                                            <div class="plan-price" aria-hidden="true">@FormatUsd(product.Price)</div>
                                                            <div class="plan-promo">@GetPlanPromo(product)</div>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="features-section">
        <div class="container">
            <aside class="hero-console-panel">
                <div class="hero-console-panel-top">
                    <span class="status-badge">Limited time offer</span>
                    <div class="hero-console-pill-row" role="tablist" aria-label="Kohinoor EA highlights">
                        <button class="@("hero-console-pill " + (activeHighlightTab == TabOptions.MT4 ? "active" : ""))" type="button" role="tab" aria-selected="@(activeHighlightTab == TabOptions.MT4)" @onclick="() => SetActiveTab(TabOptions.MT4)">MT4 Ready</button>
                        <button class="@("hero-console-pill " + (activeHighlightTab == TabOptions.XAUUSD ? "active" : ""))" type="button" role="tab" aria-selected="@(activeHighlightTab == TabOptions.XAUUSD)" @onclick="() => SetActiveTab(TabOptions.XAUUSD)">XAUUSD</button>
                        <button class="@("hero-console-pill " + (activeHighlightTab == TabOptions.Offer ? "active" : ""))" type="button" role="tab" aria-selected="@(activeHighlightTab == TabOptions.Offer)" @onclick="() => SetActiveTab(TabOptions.Offer)">Launch Price</button>
                    </div>
                </div>

                @if (activeHighlightTab == TabOptions.MT4)
                {
                    <div class="hero-console-panel-block hero-highlight-panel active">
                        <h2>The Diamond Standard of Automated Trading</h2>
                        <p>Kohinoor EA combines smart entry and exit logic, advanced risk management, and emotion-free execution for traders who want a disciplined MT4 workflow.</p>
                    </div>
                }
                else if (activeHighlightTab == TabOptions.XAUUSD)
                {
                    <div class="hero-console-panel-block hero-highlight-panel active">
                        <h2>Optimized for XAUUSD precision</h2>
                        <p>Built for gold traders, Kohinoor EA follows structured market conditions designed for the dynamic movement of XAUUSD.</p>
                    </div>
                }
                else if (activeHighlightTab == TabOptions.Offer)
                {
                    <div class="hero-console-panel-block hero-highlight-panel active">
                        <h2>Special launch pricing ends soon</h2>
                        <p>Secure access at the introductory price before rates increase. Launch offer buyers can use promo code LAUNCH26 for extra savings.</p>
                    </div>
                }

                @if (activeHighlightTab == TabOptions.MT4)
                {
                    <div class="hero-console-panel-grid hero-highlight-panel active">
                        <div class="hero-console-panel-item">
                            <strong>Fully Automated Trading</strong>
                            <span>Monitors the market, executes trades, and manages open positions according to programmed strategy rules.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>Smart Entry &amp; Exit Logic</strong>
                            <span>Uses structured market conditions and predefined filters to focus on quality trade setups.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>Advanced Risk Management</strong>
                            <span>Built with adjustable trade management settings to help control exposure and support disciplined decisions.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>24/7 Market Monitoring</strong>
                            <span>Designed to reduce missed opportunities and respond without hesitation when conditions are met.</span>
                        </div>
                    </div>
                }
                else if (activeHighlightTab == TabOptions.XAUUSD)
                {
                    <div class="hero-console-panel-grid hero-highlight-panel active">
                        <div class="hero-console-panel-item">
                            <strong>Gold Pair Support</strong>
                            <span>Designed around XAUUSD, one of the most active and opportunity-rich forex instruments.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>Market Structure Logic</strong>
                            <span>Uses rule-based filters for timing, structure, and disciplined execution instead of guesswork.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>Fast Opportunity Response</strong>
                            <span>Continuously watches for qualifying gold setups and reacts when predefined conditions are met.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>MT4 Broker Fit</strong>
                            <span>Prepared for MT4-compatible broker accounts with XAUUSD trading access.</span>
                        </div>
                    </div>
                }
                else if (activeHighlightTab == TabOptions.Offer)
                {
                    <div class="hero-console-panel-grid hero-highlight-panel active">
                        <div class="hero-console-panel-item">
                            <strong>Special Launch Price</strong>
                            <span>Get Kohinoor EA at a special introductory price before the next pricing update.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>Promo Code LAUNCH26</strong>
                            <span>Apply the launch promo for 15% extra off eligible annual and lifetime access.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>Flexible Access</strong>
                            <span>Choose monthly, annual, or lifetime access based on your trading plan.</span>
                        </div>
                        <div class="hero-console-panel-item">
                            <strong>New Client Offer</strong>
                            <span>Claim your access while introductory terms are still available.</span>
                        </div>
                    </div>
                }

                <div class="launch-offer-card">
                    <strong>Special Launch Price</strong>
                    <span>Exclusive offer for new clients. Secure your access before rates increase.</span>
                </div>

                <div class="hero-console-panel-actions">
                    <a class="button button-primary" href="/pricing#plans">Get Kohinoor EA</a>
                    <a class="button button-secondary" href="/performance">View Live Results</a>
                    <a class="button button-tertiary" href="https://wa.me/919047828806?text=Hi%20I%20want%20to%20get%20started%20with%20Kohinoor%20EA">Chat on WhatsApp</a>
                </div>
            </aside>
        </div>
    </section>
    <section class="section">
        <div class="container">
            <h2 class="section-title">Why traders choose Kohinoor EA</h2>
            <p class="section-copy">A premium MT4 Expert Advisor built to reduce emotional decisions, save time, and apply the same disciplined process every time the market opens an opportunity.</p>
            <div class="metrics-grid">
                <article class="card">
                    <h3>Emotion-Free Trading</h3>
                    <p>Removes hesitation, fear, and impulsive reactions by following predefined algorithmic conditions instead of human emotion.</p>
                </article>
                <article class="card">
                    <h3>Easy Setup</h3>
                    <p>Simple installation and user-friendly settings make it accessible to both new and experienced MT4 users.</p>
                </article>
                <article class="card">
                    <h3>Professional Efficiency</h3>
                    <p>Spend less time monitoring charts and more time managing your broader trading goals and account preferences.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container panel">
            <span class="badge">What It Solves</span>
            <h2 class="section-title">Trading discipline at machine speed</h2>
            <p>Many traders struggle with inconsistent execution, missed opportunities, and lack of time. Kohinoor EA addresses those issues by automating market monitoring, trade execution, and position management using a structured rules-based process.</p>
            <div class="button-group">
                <a class="button button-primary" href="/about">Learn How It Works</a>
                <a class="button button-secondary" href="https://wa.me/919047828806?text=Hi%20I%20want%20to%20see%20live%20results%20for%20Kohinoor%20EA">Chat on WhatsApp</a>
            </div>
        </div>
    </section>
</main>

<footer class="site-footer">

    <section class="section">
        <div class="container story-grid">
            <article class="panel">
                <span class="badge">Who it is for</span>
                <h2 class="section-title">Built for traders who want structure</h2>
                <p>Kohinoor EA is designed for traders who want to move away from emotional decision-making and toward a more disciplined, rules-based process.</p>
                <ul class="list">
                    <li>MT4 users who want an automated XAUUSD workflow</li>
                    <li>Busy traders who cannot monitor charts all day</li>
                    <li>Users looking for consistent trade handling and risk-aware execution</li>
                    <li>Buyers who want support with onboarding and initial setup</li>
                </ul>
            </article>
            <article class="panel">
                <span class="badge">What buyers get</span>
                <h2 class="section-title">A polished trading workflow, not just a file</h2>
                <p>The goal is not only automated entries. Kohinoor EA is positioned as a more complete trading support workflow for disciplined MT4 execution.</p>
                <div class="stat-grid">
                    <div class="stat">
                        <strong>Automation core</strong>
                        <span>Trade execution and position management based on predefined logic.</span>
                    </div>
                    <div class="stat">
