@code {
    private string indexLoginEmail = string.Empty;
    private string indexLoginPassword = string.Empty;
    private string? indexLoginMessage;
    private bool indexLoginBusy;
    private bool isLoggedIn = false;
    private string? loggedInUserName;
    private string? authToken;

    // Features section tab state
    private TabOptions activeHighlightTab = TabOptions.MT4;

    private enum TabOptions
    {
        MT4,
        XAUUSD,
        Offer
    }

    private void SetActiveTab(TabOptions tab)
    {
        activeHighlightTab = tab;
    }

    protected override async Task OnInitializedAsync()
    {
        currency = await CurrencyContext.ResolveAsync(Http, LocalStorage);
        await CheckTokenAndSetStateAsync();
        await LoadProductsAsync();
    }

    private readonly List<ProductDto> products = new();
    private string? productStatusMessage;

    private List<ProductDto> ActiveProducts =>
        products.Where(p => p.IsActive).OrderBy(p => p.Price).ThenBy(p => p.Name).ToList();

    private List<ProductDto> GridProducts => ActiveProducts.Take(2).ToList();

    private List<ProductDto> MarqueeProducts
    {
        get
        {
            var active = ActiveProducts;
            if (active.Count == 0)
            {
                return new List<ProductDto>();
            }

            // Duplicate for smooth -50% marquee travel.
            return active.Concat(active).ToList();
        }
    }

    private async Task LoadProductsAsync()
    {
        productStatusMessage = null;
        products.Clear();

        try
        {
            var response = await Http.GetAsync("api/commerce/products");
            if (!response.IsSuccessStatusCode)
            {
                productStatusMessage = "Unable to load products right now.";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<List<ProductDto>>();
            products.AddRange(payload ?? Enumerable.Empty<ProductDto>());
        }
        catch
        {
            productStatusMessage = "Unable to load products right now.";
        }
    }

    private CurrencyContext currency = CurrencyContext.FromCountryCode("US");

    private string FormatUsd(decimal price) => CurrencyContext.FormatPriceForCountry(price, currency.CountryCode);

    private static string GetPlanPromo(ProductDto product)
    {
        var description = product.Description ?? string.Empty;
        return "Premium access & automation tools";
    }

    private void NavigateToBuyProduct(long productId)
    {
        Navigation.NavigateTo($"/buy-product?productId={productId}", true);
    }

    private static string GetProductImageUrl(ProductDto product)
    {
        if (!string.IsNullOrWhiteSpace(product.ImageLink))
        {
            return product.ImageLink.Trim();
        }

        var name = product.Name?.ToLowerInvariant() ?? string.Empty;

        if (name.Contains("monthly", StringComparison.Ordinal))
        {
            return "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80";
        }

        if (name.Contains("annual", StringComparison.Ordinal))
        {
            return "https://images.unsplash.com/photo-1551281044-8b66f0f6c1b0?auto=format&fit=crop&w=800&q=80";
        }

        if (name.Contains("lifetime", StringComparison.Ordinal))
        {
            return "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=800&q=80";
        }

        return "https://images.unsplash.com/photo-1556740749-887f6717d7e4?auto=format&fit=crop&w=800&q=80";
    }

    private async Task CheckTokenAndSetStateAsync()
    {
        authToken = await LocalStorage.GetItemAsync<string>("authToken");
        if (!string.IsNullOrWhiteSpace(authToken) && !IsTokenExpired(authToken))
        {
            isLoggedIn = true;
            loggedInUserName = GetUserNameFromToken(authToken);
            if (string.IsNullOrWhiteSpace(loggedInUserName))
            {
                loggedInUserName = indexLoginEmail?.Trim();
            }
        }
        else
        {
            isLoggedIn = false;
            loggedInUserName = null;
        }
        StateHasChanged();
    }

    private bool IsTokenExpired(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3) return true;
            var payload = System.Text.Json.JsonDocument.Parse(System.Text.Encoding.UTF8.GetString(PadBase64(parts[1])));
            if (payload.RootElement.TryGetProperty("exp", out var exp))
            {
                var expTime = DateTimeOffset.FromUnixTimeSeconds(exp.GetInt64());
                return expTime < DateTimeOffset.UtcNow;
            }
        }
        catch { }
        return true;
    }

    private byte[] PadBase64(string base64)
    {
        int pad = 4 - (base64.Length % 4);
        if (pad < 4) base64 += new string('=', pad);
        return Convert.FromBase64String(base64.Replace('-', '+').Replace('_', '/'));
    }

    private string? GetUserNameFromToken(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3) return null;
            var payload = System.Text.Json.JsonDocument.Parse(System.Text.Encoding.UTF8.GetString(PadBase64(parts[1])));

            static string? ReadString(System.Text.Json.JsonElement element) =>
                element.ValueKind == System.Text.Json.JsonValueKind.String ? element.GetString() : null;

            var candidateKeys = new[]
            {
                "unique_name",
                "name",
                "full_name",
                "given_name",
                "preferred_username",
                "email",
                "sub",
                "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name",
                "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress"
            };

            foreach (var key in candidateKeys)
            {
                if (payload.RootElement.TryGetProperty(key, out var value))
                {
                    var str = ReadString(value);
                    if (!string.IsNullOrWhiteSpace(str))
                    {
                        return str.Trim();
                    }
                }
            }
        }
        catch { }
        return null;
    }

    private async Task HandleIndexLoginAsync()
    {
        indexLoginMessage = null;

        if (string.IsNullOrWhiteSpace(indexLoginEmail) || string.IsNullOrWhiteSpace(indexLoginPassword))
        {
            indexLoginMessage = "Please enter your email and password.";
            return;
        }

        indexLoginBusy = true;
        try
        {
            var request = new LoginRequest { Email = indexLoginEmail, Password = indexLoginPassword };
            var response = await Http.PostAsJsonAsync("api/auth/login", request);

            AuthResponse? payload = null;
            var mediaType = response.Content.Headers.ContentType?.MediaType;
            if (!string.IsNullOrWhiteSpace(mediaType) && mediaType.Contains("json", StringComparison.OrdinalIgnoreCase))
            {
                try { payload = await response.Content.ReadFromJsonAsync<AuthResponse>(); } catch { }
            }

            if (response.IsSuccessStatusCode && payload?.Success == true)
            {
                if (!string.IsNullOrWhiteSpace(payload.Token))
                {
                    await LocalStorage.SetItemAsync("authToken", payload.Token);
                    Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", payload.Token);
                    await JS.InvokeVoidAsync("kohinoorAuthTouch");
                }
                await CheckTokenAndSetStateAsync();
                // Navigation based on role
                if (!string.IsNullOrWhiteSpace(payload.Role) && string.Equals(payload.Role, AuthRoles.Admin, StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/admin-dashboard", true);
                }
                else
                {
                    Navigation.NavigateTo("/dashboard", true);
                }
                return;
            }

            indexLoginMessage = payload?.Message ?? "Unable to sign in. Please check your credentials.";
        }
        finally
        {
            indexLoginBusy = false;
        }
    }

    private async Task HandleLogoutAsync()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        Http.DefaultRequestHeaders.Authorization = null;
        authToken = null;
        await CheckTokenAndSetStateAsync();
        indexLoginEmail = string.Empty;
        indexLoginPassword = string.Empty;
        indexLoginMessage = null;
    }
}

