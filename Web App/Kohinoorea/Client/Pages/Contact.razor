      </article>
    </div>
  </section>

  <section class="section">
    <div class="container contact-form-layout">
      <div class="contact-panel">
        <span class="badge">Need a response?</span>
        <h2 class="section-title">Send your message with context</h2>
        <p>Share what you need help with so the team can guide you faster, whether you are asking about plans, onboarding, setup, or activation.</p>

        <div class="contact-stat-grid">
          <div class="contact-stat-card">
            <span class="contact-mini-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6"/></svg>
            </span>
            <div>
              <strong>Sales questions</strong>
              <p>Plan selection, pricing flow, purchase assistance, and the best entry path.</p>
            </div>
          </div>

          <div class="contact-stat-card">
            <span class="contact-mini-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V6l-8-4-8 4v6c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
            </span>
            <div>
              <strong>Support questions</strong>
              <p>Setup, activation, account guidance, onboarding help, and troubleshooting.</p>
            </div>
          </div>

          <div class="contact-stat-card">
            <span class="contact-mini-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/></svg>
            </span>
            <div>
              <strong>Best results</strong>
              <p>Include your goal, current stage, and the help you need so the team can reply faster.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-panel contact-form-panel">
        <h2 class="section-title">Contact form</h2>
        <EditForm class="contact-form" Model="contactRequest" OnValidSubmit="SubmitContactMessageAsync">
          <DataAnnotationsValidator />

          @if (!string.IsNullOrWhiteSpace(contactFormStatusMessage))
          {
            <div class="contact-form-status @(isContactFormError ? "error" : "success")">@contactFormStatusMessage</div>
          }

          <div class="contact-field">
            <div class="contact-input-wrap">
              <span class="contact-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>
              </span>
              <InputText @bind-Value="contactRequest.Name" placeholder="Your name" />
            </div>
            <ValidationMessage For="@(() => contactRequest.Name)" />
          </div>

          <div class="contact-field">
            <div class="contact-input-wrap">
              <span class="contact-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
              </span>
              <InputText @bind-Value="contactRequest.Email" type="email" placeholder="Your email" />
            </div>
            <ValidationMessage For="@(() => contactRequest.Email)" />
          </div>

          <div class="contact-field">
            <div class="contact-input-wrap">
              <span class="contact-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h7"/></svg>
              </span>
              <InputText @bind-Value="contactRequest.Subject" placeholder="Subject" />
            </div>
            <ValidationMessage For="@(() => contactRequest.Subject)" />
          </div>

          <div class="contact-field">
            <div class="contact-input-wrap">
              <span class="contact-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/></svg>
              </span>
              <InputTextArea @bind-Value="contactRequest.Message" placeholder="Tell us what you need" />
            </div>
            <ValidationMessage For="@(() => contactRequest.Message)" />
          </div>

          <div class="contact-form-foot">
            <button class="button button-primary" type="submit" disabled="@isSubmittingContactMessage">@(isSubmittingContactMessage ? "Sending..." : "Send Message")</button>
            <span class="contact-input-note">Your message is saved to the contact inbox so the admin team can review it and reply by email.</span>
          </div>
        </EditForm>
      </div>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="container footer-grid">
  <div><strong>Kohinoor EA</strong></div>
  <div><p>Connect with the team for sales questions, activation support, and onboarding guidance.</p></div>
  </div>
</footer>

@code {
  private CreateContactMessageRequest contactRequest = new();
  private bool isSubmittingContactMessage;
  private bool isContactFormError;
  private string? contactFormStatusMessage;

  private async Task SubmitContactMessageAsync()
  {
    contactFormStatusMessage = null;
    isContactFormError = false;
    isSubmittingContactMessage = true;

    try
    {
      var response = await Http.PostAsJsonAsync("api/commerce/contact-messages", contactRequest);
      AuthResponse? payload = null;

      if (response.Content.Headers.ContentLength is > 0 || response.Content.Headers.ContentType is not null)
      {
        try
        {
          payload = await response.Content.ReadFromJsonAsync<AuthResponse>();
        }
        catch
        {
        }
      }

      if (!response.IsSuccessStatusCode || payload?.Success == false)
      {
        contactFormStatusMessage = payload?.Message ?? "We couldn't save your message right now. Please try again.";
        isContactFormError = true;
        return;
      }

      contactFormStatusMessage = payload?.Message ?? "Thanks for contacting us. Our team will review your message soon.";
      contactRequest = new CreateContactMessageRequest();
    }
    finally
    {
      isSubmittingContactMessage = false;
    }
  }
}
