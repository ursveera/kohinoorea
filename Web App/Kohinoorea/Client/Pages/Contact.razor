@page "/contact"
@using Kohinoorea.Shared.Models.Auth
@using Kohinoorea.Shared.Models.Commerce
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http

<PageTitle>Contact</PageTitle>

<style>
  .contact-premium-shell {
    background:
      radial-gradient(circle at top left, rgba(251,191,36,0.14), transparent 28%),
      radial-gradient(circle at top right, rgba(168,85,247,0.12), transparent 26%);
  }

  .contact-hero-card,
  .contact-panel,
  .contact-channel-card {
    border: 1px solid rgba(255,255,255,0.08);
    background: linear-gradient(135deg, rgba(255,255,255,0.88), rgba(255,255,255,0.76));
    box-shadow: 0 24px 64px rgba(15,23,42,0.08);
    backdrop-filter: blur(18px);
  }

  body[data-theme="dark"] .contact-hero-card,
  body[data-theme="dark"] .contact-panel,
  body[data-theme="dark"] .contact-channel-card {
    background: linear-gradient(135deg, rgba(15,23,42,0.78), rgba(15,23,42,0.62));
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 24px 64px rgba(0,0,0,0.28);
  }

  .contact-hero-card {
    padding: 34px;
    border-radius: 32px;
  }

  .contact-hero-grid {
    align-items: center;
    gap: 28px;
  }

  .contact-hero-copy p {
    max-width: 720px;
  }

  .contact-highlight-grid {
    margin-top: 26px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .contact-highlight-card {
    padding: 18px;
    border-radius: 22px;
    border: 1px solid rgba(251,191,36,0.16);
    background: linear-gradient(135deg, rgba(251,191,36,0.1), rgba(249,115,22,0.04));
    display: grid;
    gap: 12px;
  }

  body[data-theme="dark"] .contact-highlight-card {
    background: linear-gradient(135deg, rgba(251,191,36,0.12), rgba(168,85,247,0.08));
  }

  .contact-icon-badge {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #111827;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    box-shadow: 0 14px 30px rgba(251,191,36,0.22);
  }

  .contact-icon-badge svg {
    width: 24px;
    height: 24px;
  }

  .contact-highlight-card strong,
  .contact-channel-card h3,
  .contact-panel h3 {
    color: var(--text, #111827);
  }

  body[data-theme="dark"] .contact-highlight-card strong,
  body[data-theme="dark"] .contact-channel-card h3,
  body[data-theme="dark"] .contact-panel h3 {
    color: #f8fafc;
  }

  .contact-highlight-card span,
  .contact-hero-meta p,
  .contact-channel-card p,
  .contact-panel p,
  .contact-panel li,
  .contact-input-note {
    color: var(--muted, #6b7280);
    line-height: 1.7;
  }

  body[data-theme="dark"] .contact-highlight-card span,
  body[data-theme="dark"] .contact-hero-meta p,
  body[data-theme="dark"] .contact-channel-card p,
  body[data-theme="dark"] .contact-panel p,
  body[data-theme="dark"] .contact-panel li,
  body[data-theme="dark"] .contact-input-note {
    color: #cbd5e1;
  }

  .contact-hero-meta {
    padding: 28px;
    border-radius: 28px;
  }

  .contact-hero-meta-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 20px;
  }

  .contact-hero-meta h3 {
    margin-bottom: 8px;
    font-size: 26px;
  }

  .contact-hero-stack {
    display: grid;
    gap: 14px;
  }

  .contact-hero-item {
    padding: 16px 18px;
    border-radius: 20px;
    border: 1px solid rgba(148,163,184,0.14);
    background: rgba(255,255,255,0.42);
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  body[data-theme="dark"] .contact-hero-item {
    background: rgba(30,41,59,0.46);
  }

  .contact-hero-item-icon {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #111827;
    background: linear-gradient(135deg, #fbbf24, #fb7185);
    flex-shrink: 0;
  }

  .contact-hero-item-icon svg {
    width: 20px;
    height: 20px;
  }

  .contact-channel-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .contact-channel-card {
    padding: 24px;
    border-radius: 28px;
    display: grid;
    gap: 16px;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .contact-channel-card:hover {
    transform: translateY(-4px);
    border-color: rgba(251,191,36,0.24);
    box-shadow: 0 24px 64px rgba(15,23,42,0.12);
  }

  .contact-channel-card-featured {
    background:
      radial-gradient(circle at top right, rgba(34,197,94,0.18), transparent 36%),
      linear-gradient(135deg, rgba(255,255,255,0.92), rgba(255,255,255,0.8));
  }

  body[data-theme="dark"] .contact-channel-card-featured {
    background:
      radial-gradient(circle at top right, rgba(34,197,94,0.14), transparent 36%),
      linear-gradient(135deg, rgba(15,23,42,0.82), rgba(15,23,42,0.66));
  }

  .contact-channel-top {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
  }

  .contact-channel-title {
    display: grid;
    gap: 8px;
  }

  .contact-channel-title h3 {
    margin: 0;
    font-size: 24px;
  }

  .contact-channel-bullets {
    margin: 0;
    padding-left: 18px;
    display: grid;
    gap: 6px;
  }

  .contact-channel-bullets li {
    color: var(--muted, #6b7280);
    line-height: 1.6;
  }

  body[data-theme="dark"] .contact-channel-bullets li {
    color: #cbd5e1;
  }

  .contact-panel {
    padding: 28px;
    border-radius: 30px;
  }

  .contact-form-layout {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 20px;
  }

  .contact-stat-grid {
    margin-top: 24px;
    display: grid;
    gap: 14px;
  }

  .contact-stat-card {
    padding: 16px 18px;
    border-radius: 20px;
    border: 1px solid rgba(148,163,184,0.14);
    background: rgba(255,255,255,0.42);
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  body[data-theme="dark"] .contact-stat-card {
    background: rgba(30,41,59,0.46);
  }

  .contact-mini-icon {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(251,191,36,0.14);
    color: #f59e0b;
    flex-shrink: 0;
  }

  body[data-theme="dark"] .contact-mini-icon {
    background: rgba(251,191,36,0.16);
    color: #fde68a;
  }

  .contact-mini-icon svg {
    width: 20px;
    height: 20px;
  }

  .contact-form {
    display: grid;
    gap: 14px;
  }

  .contact-field {
    display: grid;
    gap: 6px;
  }

  .contact-input-wrap {
    display: grid;
    grid-template-columns: 48px 1fr;
    align-items: center;
    border: 1px solid rgba(148,163,184,0.18);
    border-radius: 18px;
    background: rgba(255,255,255,0.62);
    overflow: hidden;
  }

  body[data-theme="dark"] .contact-input-wrap {
    background: rgba(15,23,42,0.54);
  }

  .contact-input-wrap textarea,
  .contact-input-wrap input {
    border: 0;
    background: transparent;
    width: 100%;
  }

  .contact-input-wrap textarea:focus,
  .contact-input-wrap input:focus {
    outline: none;
  }

  .contact-input-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #f59e0b;
  }

  body[data-theme="dark"] .contact-input-icon {
    color: #fde68a;
  }

  .contact-input-icon svg {
    width: 20px;
    height: 20px;
  }

  .contact-form-panel textarea {
    min-height: 160px;
    resize: vertical;
  }

  .contact-form-foot {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .contact-form-status {
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(148,163,184,0.18);
    background: rgba(255,255,255,0.62);
    color: var(--text, #111827);
    line-height: 1.6;
  }

  body[data-theme="dark"] .contact-form-status {
    background: rgba(15,23,42,0.54);
    color: #f8fafc;
  }

  .contact-form-status.success {
    border-color: rgba(34,197,94,0.24);
    background: linear-gradient(135deg, rgba(34,197,94,0.12), rgba(34,197,94,0.06));
  }

  .contact-form-status.error {
    border-color: rgba(248,113,113,0.28);
    background: linear-gradient(135deg, rgba(248,113,113,0.12), rgba(248,113,113,0.06));
  }

  .contact-field .validation-message {
    padding-left: 4px;
    color: #dc2626;
    font-size: 12px;
    line-height: 1.4;
  }

  body[data-theme="dark"] .contact-field .validation-message {
    color: #fca5a5;
  }

  @@media (max-width: 1100px) {
    .contact-highlight-grid,
    .contact-channel-grid,
    .contact-form-layout {
      grid-template-columns: 1fr;
    }
  }

  @@media (max-width: 820px) {
    .contact-hero-card,
    .contact-panel,
    .contact-channel-card {
      padding: 22px;
    }

    .contact-hero-meta-top,
    .contact-channel-top,
    .contact-form-foot {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<main class="contact-premium-shell">
  <section class="page-hero">
    <div class="container">
      <div class="contact-hero-card">
        <div class="hero-grid contact-hero-grid">
          <div class="contact-hero-copy">
            <div class="eyebrow">Direct contact</div>
            <h1>Talk to the <span class="gradient-text">Kohinoor EA</span> team</h1>
            <p>Reach the Kohinoor EA team for plan details, onboarding support, activation guidance, and pre-purchase questions through the contact method that fits you best.</p>

            <div class="contact-highlight-grid">
              <div class="contact-highlight-card">
                <span class="contact-icon-badge" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8Z"/></svg>
                </span>
                <strong>Fast guidance</strong>
                <span>Get help choosing the right plan, purchase path, and setup direction quickly.</span>
              </div>
              <div class="contact-highlight-card">
                <span class="contact-icon-badge" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12a8 8 0 0 1 16 0"/><path d="M4 12v3a2 2 0 0 0 2 2h2v-5H4Z"/><path d="M20 12v3a2 2 0 0 1-2 2h-2v-5h4Z"/><path d="M12 19v3"/></svg>
                </span>
                <strong>Direct assistance</strong>
                <span>Ask about activation, onboarding, plan access, or pre-sales support.</span>
              </div>
              <div class="contact-highlight-card">
                <span class="contact-icon-badge" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16"/><path d="M7 12h10"/><path d="M10 18h4"/></svg>
                </span>
                <strong>Flexible contact</strong>
                <span>Use chat, Telegram, or email based on how much detail you want to share.</span>
              </div>
            </div>
          </div>

          <aside class="contact-hero-meta">
            <div class="contact-hero-meta-top">
              <div>
                <span class="badge">Support window</span>
                <h3>Choose the fastest path to the team</h3>
                <p>For quick buying questions, use WhatsApp. For regular messaging, use Telegram. For licensing and detailed requests, email remains the best channel.</p>
              </div>
            </div>

            <div class="contact-hero-stack">
              <div class="contact-hero-item">
                <span class="contact-hero-item-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-1.9 5.4A8.5 8.5 0 0 1 12.5 20 8.38 8.38 0 0 1 7 18l-4 1 1.1-3.5A8.38 8.38 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3a8.5 8.5 0 0 1 8.5 8.5Z"/></svg>
                </span>
                <div>
                  <strong>WhatsApp</strong>
                  <p>Fastest route for pricing, plan selection, and purchase help.</p>
                </div>
              </div>

              <div class="contact-hero-item">
                <span class="contact-hero-item-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4 20-7Z"/><path d="m22 2-11 11"/></svg>
                </span>
                <div>
                  <strong>Telegram</strong>
                  <p>Simple ongoing communication for updates and lighter day-to-day messaging.</p>
                </div>
              </div>

              <div class="contact-hero-item">
                <span class="contact-hero-item-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
                </span>
                <div>
                  <strong>Email</strong>
                  <p>Best for licensing questions, account issues, and detailed support requests.</p>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container contact-channel-grid">
      <article class="contact-channel-card contact-channel-card-featured" id="whatsapp">
        <div class="contact-channel-top">
          <div class="contact-channel-title">
            <span class="badge">Fastest</span>
            <h3>WhatsApp</h3>
          </div>
          <span class="contact-icon-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-1.9 5.4A8.5 8.5 0 0 1 12.5 20 8.38 8.38 0 0 1 7 18l-4 1 1.1-3.5A8.38 8.38 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3a8.5 8.5 0 0 1 8.5 8.5Z"/></svg>
          </span>
        </div>
        <p>Use WhatsApp for fast responses on pricing, setup, plan selection, and purchase assistance.</p>
        <ul class="contact-channel-bullets">
          <li>Best for pre-sales questions</li>
          <li>Fast purchase follow-up</li>
          <li>Quick setup direction</li>
        </ul>
        <a class="button button-primary" href="https://wa.me/919047828806?text=Hi%20I%20want%20to%20buy%20Kohinoor%20EA">Chat on WhatsApp</a>
        <p class="fine-print">Best for quick pre-sales conversations and direct purchase follow-up.</p>
      </article>

      <article class="contact-channel-card" id="telegram">
        <div class="contact-channel-top">
          <div class="contact-channel-title">
            <span class="badge">Messaging</span>
            <h3>Telegram</h3>
          </div>
          <span class="contact-icon-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4 20-7Z"/><path d="m22 2-11 11"/></svg>
          </span>
        </div>
        <p>Use Telegram for updates, direct conversation, and streamlined communication with the team.</p>
        <ul class="contact-channel-bullets">
          <li>Ongoing communication</li>
          <li>Simple update sharing</li>
          <li>Lightweight chat workflow</li>
        </ul>
        <a class="button button-secondary" href="https://t.me/kohinoor">Open Telegram</a>
        <p class="fine-print">Useful for users who prefer a lighter messaging workflow and ongoing updates.</p>
      </article>

      <article class="contact-channel-card" id="email">
        <div class="contact-channel-top">
          <div class="contact-channel-title">
            <span class="badge">Detailed support</span>
            <h3>Email</h3>
          </div>
          <span class="contact-icon-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
          </span>
        </div>
        <p>Use email for licensing questions, account support, activation help, and longer-form inquiries.</p>
        <ul class="contact-channel-bullets">
          <li>Best for full context</li>
          <li>Support history friendly</li>
          <li>Business communication ready</li>
        </ul>
        <a class="button button-tertiary" href="mailto:support@kohinoorea.com?subject=Kohinoor%20EA%20Inquiry">Send Email</a>
