    private async Task NotifyUsersAboutProductAsync(ProductDto product)
    {
        if (notifiedProductUntilUtc.TryGetValue(product.Id, out var untilUtc) && untilUtc > DateTime.UtcNow)
        {
            return;
        }

        notifiedProductUntilUtc[product.Id] = DateTime.UtcNow.AddMinutes(1);
        StateHasChanged();

        try
        {
            var response = await Http.PostAsync($"api/commerce/products/{product.Id}/notify", content: null);
            if (!response.IsSuccessStatusCode)
            {
                statusMessage = "Unable to notify users about this product.";
                _ = ShowToastAsync(statusMessage, isError: true);
                notifiedProductUntilUtc.Remove(product.Id);
                return;
            }

            statusMessage = $"Users notified about {product.Name}.";
            _ = ShowToastAsync(statusMessage);
        }
        catch
        {
            statusMessage = "Unable to notify users about this product.";
            _ = ShowToastAsync(statusMessage, isError: true);
            notifiedProductUntilUtc.Remove(product.Id);
        }
        finally
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(TimeSpan.FromMinutes(1));
                }
                catch
                {
                }

                await InvokeAsync(() =>
                {
                    notifiedProductUntilUtc.Remove(product.Id);
                    StateHasChanged();
                });
            });
        }
    }

    private bool IsProductNotified(ProductDto product)
    {
        return notifiedProductUntilUtc.TryGetValue(product.Id, out var untilUtc) && untilUtc > DateTime.UtcNow;
    }

