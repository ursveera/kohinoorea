        exportModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./assets/js/admin-export.js");
        await exportModule.InvokeVoidAsync("downloadTextFile", $"orders-{DateTime.UtcNow:yyyyMMdd-HHmm}.html", html, "text/html;charset=utf-8");
