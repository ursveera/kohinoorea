    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += HandleLocationChanged;

        var meResponse = await Http.GetAsync("api/auth/me");
        if (!meResponse.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        var me = await meResponse.Content.ReadFromJsonAsync<AuthResponse>();
        if (!string.Equals(me?.Role, AuthRoles.Admin, StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/dashboard", true);
            return;
        }

        profileEmail = me?.Email ?? string.Empty;
        await LoadDashboardDataAsync();
        ApplySectionFromUri(Navigation.Uri, shouldQueueScroll: true);
        canRenderDashboard = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrWhiteSpace(pendingScrollAnchor))
        {
            var anchor = pendingScrollAnchor;
            pendingScrollAnchor = null;
            await JS.InvokeVoidAsync("eval", $"document.getElementById('{anchor}')?.scrollIntoView({{ behavior: 'smooth', block: 'start' }});");
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private void NavigateToSection(AdminSection section)
    {
        activeSection = section;
        pendingScrollAnchor = GetSectionHash(section);
        Navigation.NavigateTo($"/admin-dashboard#{GetSectionHash(section)}", replace: true);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ApplySectionFromUri(e.Location, shouldQueueScroll: true);
        _ = InvokeAsync(StateHasChanged);
    }

    private void ApplySectionFromUri(string uri, bool shouldQueueScroll)
    {
        var fragment = Navigation.ToAbsoluteUri(uri).Fragment.TrimStart('#').ToLowerInvariant();
        var section = fragment switch
        {
            "orders" => AdminSection.Orders,
            "customers" => AdminSection.Customers,
            "faq" => AdminSection.Faq,
            "notifications" => AdminSection.Notifications,
            "contact" => AdminSection.Contact,
            "support" => AdminSection.Support,
            _ => AdminSection.Products
        };

        activeSection = section;
        if (shouldQueueScroll)
        {
            pendingScrollAnchor = GetSectionHash(section);
        }
    }

    private static string GetSectionHash(AdminSection section)
    {
        return section switch
        {
            AdminSection.Orders => "orders",
            AdminSection.Customers => "customers",
            AdminSection.Faq => "faq",
            AdminSection.Notifications => "notifications",
            AdminSection.Contact => "contact",
            AdminSection.Support => "support",
            _ => "products"
        };
    }

    private async Task LoadDashboardDataAsync()
    {
        statusMessage = null;

        var ordersTask = Http.GetAsync("api/commerce/orders/trace");
        var productsTask = Http.GetAsync("api/commerce/products?all=true");
        var faqsTask = Http.GetAsync("api/commerce/faqs/admin");
        var contactsTask = Http.GetAsync("api/commerce/contact-messages");
        var supportTask = Http.GetAsync("api/commerce/support/trace");
        var customersTask = Http.GetAsync("api/auth/users");
        var followUpLeadsTask = Http.GetAsync("api/auth/follow-up-leads");

        await Task.WhenAll(ordersTask, productsTask, faqsTask, contactsTask, supportTask, customersTask, followUpLeadsTask);

        var ordersResponse = await ordersTask;
        var productsResponse = await productsTask;
        var faqsResponse = await faqsTask;
        var contactsResponse = await contactsTask;
        var supportResponse = await supportTask;
        var customersResponse = await customersTask;
        var followUpLeadsResponse = await followUpLeadsTask;

        orderTrace.Clear();
        if (ordersResponse.IsSuccessStatusCode)
        {
            var payload = await ordersResponse.Content.ReadFromJsonAsync<List<OrderTraceDto>>();
            orderTrace.AddRange(payload ?? Enumerable.Empty<OrderTraceDto>());
        }

        products.Clear();
        if (productsResponse.IsSuccessStatusCode)
        {
            var payload = await productsResponse.Content.ReadFromJsonAsync<List<ProductDto>>();
            products.AddRange(payload ?? Enumerable.Empty<ProductDto>());
        }

        faqs.Clear();
        if (faqsResponse.IsSuccessStatusCode)
        {
            var payload = await faqsResponse.Content.ReadFromJsonAsync<List<FaqDto>>();
            faqs.AddRange(payload ?? Enumerable.Empty<FaqDto>());
        }

        contactMessages.Clear();
        if (contactsResponse.IsSuccessStatusCode)
        {
            var payload = await contactsResponse.Content.ReadFromJsonAsync<List<ContactMessageDto>>();
            contactMessages.AddRange(payload ?? Enumerable.Empty<ContactMessageDto>());
        }

        supportTrace.Clear();
        if (supportResponse.IsSuccessStatusCode)
        {
            var payload = await supportResponse.Content.ReadFromJsonAsync<List<SupportQueryDto>>();
            supportTrace.AddRange(payload ?? Enumerable.Empty<SupportQueryDto>());
        }

        customers.Clear();
        if (customersResponse.IsSuccessStatusCode)
        {
            var payload = await customersResponse.Content.ReadFromJsonAsync<List<AdminUserDto>>();
            customers.AddRange(payload ?? Enumerable.Empty<AdminUserDto>());
        }

        followUpLeads.Clear();
        if (followUpLeadsResponse.IsSuccessStatusCode)
        {
            var payload = await followUpLeadsResponse.Content.ReadFromJsonAsync<List<AdminLeadNotificationDto>>();
            followUpLeads.AddRange(payload ?? Enumerable.Empty<AdminLeadNotificationDto>());
        }

        pendingOrderStatuses.Clear();
        foreach (var order in orderTrace)
        {
            pendingOrderStatuses[order.OrderId] = NormalizeOrderStatus(order.Status);
        }

        if (selectedFollowUpLeadUserId.HasValue && followUpLeads.All(lead => lead.UserId != selectedFollowUpLeadUserId.Value))
        {
            selectedFollowUpLeadUserId = null;
            followUpEmailRequest = new SendLeadFollowUpEmailRequest();
        }

        if (!selectedFollowUpLeadUserId.HasValue && followUpLeads.Count > 0)
        {
            SelectFollowUpLead(followUpLeads[0]);
        }

        if (selectedContactMessageId.HasValue && contactMessages.All(contactMessage => contactMessage.Id != selectedContactMessageId.Value))
        {
            selectedContactMessageId = null;
            contactReplyRequest = new SendContactReplyRequest();
        }

        if (!selectedContactMessageId.HasValue && contactMessages.Count > 0)
        {
            SelectContactMessage(contactMessages[0]);
        }

        productCount = products.Count;
        orderCount = orderTrace.Count;
        customerCount = customers.Count;
        faqCount = faqs.Count;
        contactCount = contactMessages.Count;
        totalRevenue = orderTrace.Sum(x => x.TotalAmount);
    }

