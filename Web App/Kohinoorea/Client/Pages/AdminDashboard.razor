    private bool IsPlanReminded(long orderId) => remindedPlanOrderIds.Contains(orderId);

    private async Task SendPlanReminderAsync(ActivePlanDto plan)
    {
        if (!plan.IsEligibleForReminder)
        {
            return;
        }

        var response = await Http.PostAsync($"api/commerce/active-plans/{plan.OrderId}/remind", content: null);
        if (!response.IsSuccessStatusCode)
        {
            statusMessage = "Failed to send reminder email.";
            _ = ShowToastAsync(statusMessage, isError: true);
            return;
        }

        remindedPlanOrderIds.Add(plan.OrderId);
        _ = ShowToastAsync($"Reminder email sent to {plan.UserEmail}.");

        _ = Task.Run(async () =>
        {
            await Task.Delay(TimeSpan.FromMinutes(1));
            remindedPlanOrderIds.Remove(plan.OrderId);
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task NotifyAllFilteredPlansAsync()
    {
        var orderIds = EligibleFilteredPlanOrderIds;
        if (orderIds.Count == 0)
        {
            return;
        }

        isBulkNotifyingPlans = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/commerce/active-plans/remind-bulk", new BulkPlanReminderRequest
            {
                OrderIds = orderIds
            });

            if (!response.IsSuccessStatusCode)
            {
                statusMessage = "Bulk notify failed.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<JsonElement>();
            var sent = payload.TryGetProperty("sent", out var s) ? s.GetInt32() : 0;
            var skipped = payload.TryGetProperty("skipped", out var sk) ? sk.GetInt32() : 0;
            var failed = payload.TryGetProperty("failed", out var f) ? f.GetInt32() : 0;

            _ = ShowToastAsync($"Bulk notify done: sent {sent}, skipped {skipped}, failed {failed}.");
        }
        finally
        {
            isBulkNotifyingPlans = false;
        }
    }

