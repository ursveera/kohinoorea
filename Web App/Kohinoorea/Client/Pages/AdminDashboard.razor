      <button class="nav-button @(activeSection == AdminSection.Faq ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Faq)">FAQ</button>
    }
    @if (CanAccess(AdminSection.Notifications))
    {
      <button class="nav-button @(activeSection == AdminSection.Notifications ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Notifications)">Notifications</button>
    }
    @if (CanAccess(AdminSection.Contact))
    {
      <button class="nav-button @(activeSection == AdminSection.Contact ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Contact)">Contact</button>
    }
    @if (CanAccess(AdminSection.Support))
    {
      <button class="nav-button @(activeSection == AdminSection.Support ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Support)">Support</button>
    }

    <div class="sidebar-card">
      <h3>@SidebarTitle</h3>
      <p>@SidebarMessage</p>
    </div>
  </aside>

  <main class="main">
    <header class="topbar" id="overview">
      <div>
        <h2>@PageTitle</h2>
        <p>Jump directly to Products, Orders, Customers, FAQ, Notifications, Contact, or Support and work each section inside its own scrollable control panel.</p>
      </div>
      <div class="profile">
        <div class="avatar">@AvatarInitial</div>
        <div>
          <strong>Administrator</strong>
          <span>@ProfileEmail</span>
        </div>
      </div>
    </header>

    <section class="cards">
      @if (CanAccess(AdminSection.Products))
      {
      <div class="stat-card @(activeSection == AdminSection.Products ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Products)">
        <div class="stat-icon">P</div>
        <h3>Products</h3>
        <p>Create plans, click any product to edit it, and keep the catalog scrollable on the right.</p>
        <div class="stat-number">@productCount</div>
      </div>
      }

      @if (CanAccess(AdminSection.Orders))
      {
      <div class="stat-card @(activeSection == AdminSection.Orders ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Orders)">
        <div class="stat-icon">O</div>
        <h3>Orders</h3>
        <p>Filter orders, scroll the table, and update statuses without losing position.</p>
        <div class="stat-number">@orderCount</div>
      </div>
      }

      @if (CanAccess(AdminSection.Customers))
      {
      <div class="stat-card @(activeSection == AdminSection.Customers ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Customers)">
        <div class="stat-icon">C</div>
        <h3>Customers</h3>
        <p>Load the users table and inspect account activity in one place.</p>
        <div class="stat-number">@customerCount</div>
      </div>
      }

      @if (CanAccess(AdminSection.Admins))
      {
      <div class="stat-card @(activeSection == AdminSection.Admins ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Admins)">
        <div class="stat-icon">A</div>
        <h3>Admins</h3>
        <p>Create, update, reset, or remove admin accounts.</p>
        <div class="stat-number">@adminCount</div>
      </div>
      }

      @if (CanAccess(AdminSection.Faq))
      {
      <div class="stat-card @(activeSection == AdminSection.Faq ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Faq)">
        <div class="stat-icon">F</div>
        <h3>FAQ</h3>
        <p>Publish premium question-and-answer content for the public FAQ page.</p>
        <div class="stat-number">@faqCount</div>
      </div>
      }

      @if (CanAccess(AdminSection.Notifications))
      {
      <div class="stat-card @(activeSection == AdminSection.Notifications ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Notifications)">
        <div class="stat-icon">N</div>
        <h3>Notifications</h3>
        <p>Follow up with signed-up users who still have no completed purchase.</p>
        <div class="stat-number">@followUpLeads.Count</div>
      </div>
      }

      @if (CanAccess(AdminSection.Contact))
      {
      <div class="stat-card @(activeSection == AdminSection.Contact ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Contact)">
        <div class="stat-icon">M</div>
        <h3>Contact</h3>
        <p>Review inbound contact requests and reply directly from the admin inbox.</p>
        <div class="stat-number">@contactCount</div>
      </div>
      }

      @if (CanAccess(AdminSection.Support))
      {
      <div class="stat-card @(activeSection == AdminSection.Support ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Support)">
        <div class="stat-icon">S</div>
        <h3>Support</h3>
        <p>Stay on top of open queries and respond from a focused thread view.</p>
        <div class="stat-number">@supportTrace.Count</div>
      </div>
      }
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
      <p class="summary-caption">@statusMessage</p>
    }

    <section id="@CurrentSectionAnchor" class="content-panel">
      @if (activeSection == AdminSection.Products)
      {
        <div class="panel-header">
          <div>
            <h3>Product Management</h3>
            <p class="section-intro">Click any product card to load it into the form, edit it, and update it without leaving this section.</p>
          </div>
          <span class="badge">Admin Posted Products</span>
        </div>

        <div class="product-management-layout @(isProductsMaximized ? "products-maximized" : null)">
          <EditForm class="management-form form-grid" Model="createProduct" OnValidSubmit="SaveProductAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div>
              <label>Product Name</label>
              <InputText @bind-Value="createProduct.Name" placeholder="Premium Annual Plan" />
            </div>

            <div>
              <label>Description</label>
              <div class="description-builder-toolbar">
                <button class="ghost-btn" type="button" @onclick="AddDescriptionSummaryField">Add p</button>
                <button class="ghost-btn" type="button" @onclick="AddDescriptionFeatureField">Add span</button>
                <button class="submit-btn" type="button" @onclick="BuildDescriptionFromFields">Insert Description</button>
                <button class="ghost-btn" type="button" @onclick="ClearDescriptionFields">Clear Fields</button>
              </div>
              <div class="description-builder-fields">
                @for (var i = 0; i < descriptionSummaryInputs.Count; i++)
                {
                  var summaryIndex = i;
                  <div class="description-builder-row">
                    <span class="description-builder-label">p @(@summaryIndex + 1)</span>
                    <input class="description-builder-input" value="@descriptionSummaryInputs[summaryIndex]" @oninput="e => UpdateDescriptionSummaryField(summaryIndex, e.Value?.ToString())" placeholder="Summary paragraph text..." />
                    <button class="ghost-btn" type="button" @onclick="() => RemoveDescriptionSummaryField(summaryIndex)">Remove</button>
                  </div>
                }

                @for (var i = 0; i < descriptionFeatureInputs.Count; i++)
                {
                  var featureIndex = i;
                  <div class="description-builder-row">
                    <span class="description-builder-label">span @(@featureIndex + 1)</span>
                    <input class="description-builder-input" value="@descriptionFeatureInputs[featureIndex]" @oninput="e => UpdateDescriptionFeatureField(featureIndex, e.Value?.ToString())" placeholder="Feature bullet text..." />
                    <button class="ghost-btn" type="button" @onclick="() => RemoveDescriptionFeatureField(featureIndex)">Remove</button>
                  </div>
                }
              </div>

              <InputTextArea @bind-Value="createProduct.Description" placeholder="Generated description will appear here after Insert Description." />
              <p class="helper-text">Use Add p/Add span to create fields, then click Insert Description to build one HTML description string.</p>
              <div class="description-preview">
                <h5>Beautified Preview</h5>
                <p class="description-preview-summary">@adminCurrency.ReplacePricesInTextFromUsd(GetDescriptionSummary(createProduct.Description))</p>
                @if (GetDescriptionTagValues(createProduct.Description, "span").Count > 0)
                {
                  <div class="description-preview-features">
                    @foreach (var feature in GetDescriptionTagValues(createProduct.Description, "span"))
                    {
                      <span class="description-preview-feature">@adminCurrency.ReplacePricesInTextFromUsd(feature)</span>
                    }
                  </div>
                }
                @if (GetDescriptionTagValues(createProduct.Description, "i").Count > 0)
                {
                  <div class="description-preview-notes">
                    @foreach (var note in GetDescriptionTagValues(createProduct.Description, "i"))
                    {
                      <p class="description-preview-note">@adminCurrency.ReplacePricesInTextFromUsd(note)</p>
                    }
                  </div>
                }
                @if (string.IsNullOrWhiteSpace(createProduct.Description))
                {
                  <p class="description-preview-empty">Add p, span, and i tags above to see formatted content.</p>
                }
              </div>
            </div>

            <div class="upload-box">
              <label>Product Image</label>
              <InputFile OnChange="HandleProductImageSelectedAsync" accept=".jpg,.jpeg,.png,.webp,.gif" />
              <small>@(isUploadingImage ? "Uploading image..." : string.IsNullOrWhiteSpace(selectedImageName) ? "Upload a cover image or paste a direct URL below." : $"Selected: {selectedImageName}")</small>
            </div>

            <div>
              <label>Image URL</label>
              <InputText @bind-Value="createProduct.ImageLink" placeholder="/uploads/products/... or https://..." />
            </div>

            <div class="form-row">
              <div>
                <label>Price</label>
                <InputNumber @bind-Value="createProduct.Price" placeholder="2999" />
              </div>
              <div>
                <label>Country Code</label>
                <InputText @bind-Value="createProduct.CountryCode" placeholder="IN, US, GB or leave empty" />
              </div>
            </div>

            <div class="form-row">
              <div>
                <label>Valid From (UTC)</label>
                <InputDate TValue="DateTime?" @bind-Value="createProduct.ValidFromUtc" />
                <p class="helper-text">Optional. Leave empty for no start date.</p>
              </div>
              <div>
                <label>Valid To (UTC)</label>
                <InputDate TValue="DateTime?" @bind-Value="createProduct.ValidToUtc" />
                <p class="helper-text">Optional. Leave empty for no end date.</p>
              </div>
            </div>

            <div class="form-row">
              <label class="toggle-row">
                <InputCheckbox @bind-Value="createProduct.IsActive" /> Active listing
              </label>
              <label class="toggle-row">
                <InputCheckbox @bind-Value="createProduct.IsMaster" /> Master pricing plan
              </label>
            </div>

            <div class="button-row">
              <button class="submit-btn" type="submit">@(editingProductId.HasValue ? "Update Product" : "Create Product")</button>
              @if (editingProductId.HasValue)
              {
                <button class="ghost-btn" type="button" @onclick="ResetProductForm">Cancel Edit</button>
              }
            </div>
          </EditForm>

          <div class="product-list-panel @(isProductsMaximized ? "maximized" : null)">
            <div class="product-list-header">
              <input class="filter-box" @bind="productFilter" @bind:event="oninput" placeholder="Filter products by name, country, status, or description..." />
              <button class="ghost-btn" type="button" @onclick="ToggleProductsMaximize">@(isProductsMaximized ? "Normal" : "Maximize")</button>
            </div>
            <div class="product-grid">
              @if (FilteredProducts.Count == 0)
              {
                <p class="empty-note">No products match this filter.</p>
              }
              else
              {
                @foreach (var product in FilteredProducts)
                {
                  <div class="product-card @(editingProductId == product.Id ? "active" : null)" @onclick="() => StartEditingProduct(product)">
                    <div class="product-img">
                      <img src="@GetProductImageUrl(product)" alt="@product.Name" loading="lazy" />
                    </div>
                    <div class="product-info">
                      <h4>@product.Name</h4>
                      @if (isProductsMaximized)
                      {
                        <p>@GetProductFullDescription(product)</p>
                      }
                      else
                      {
                        <p>@GetProductSummary(product)</p>
                      }
                    </div>
                    <div class="product-price">
                      <span class="price">@adminCurrency.FormatFromUsd(product.Price)</span>
                    </div>
                    <div class="product-tags">
                      <span class="tag">@(product.IsActive ? "Active" : "Hidden")</span>
                      @if (product.IsMaster)
                      {
                        <span class="tag">Master</span>
                      }
                      @if (!string.IsNullOrWhiteSpace(product.CountryCode))
                      {
                        <span class="tag">@product.CountryCode!.ToUpperInvariant()</span>
                      }
                    </div>
                    <div class="product-actions" @onclick:stopPropagation="true">
                      <button class="product-action-btn"
                              type="button"
                              disabled="@IsProductNotified(product)"
                              @onclick="() => NotifyUsersAboutProductAsync(product)">
                        @(IsProductNotified(product) ? "Notified" : "Notify Users")
                      </button>
                      <button class="product-action-btn" type="button" @onclick="() => ToggleProductActiveAsync(product)">@(product.IsActive ? "Soft Delete" : "Restore")</button>
                      <button class="product-action-btn force" type="button" @onclick="() => ForceDeleteProductAsync(product)">Force Delete</button>
                    </div>
                  </div>
                }
              }
            </div>
          </div>
        </div>
      }
      else if (activeSection == AdminSection.ActivePlans)
      {
        <div class="panel-header">
          <div>
            <h3>Active Plans</h3>
            <p class="section-intro">Shows completed orders with product validity windows. Recently expired plans (last 30 days) can be reminded by email.</p>
          </div>
          <span class="badge">Plan Status</span>
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <input class="filter-box" style="flex: 1; min-width: 280px;" value="@activePlanFilter" @oninput="OnActivePlanFilterInput" placeholder="Filter by user, email, product, state..." />
          <button class="submit-btn" type="button" disabled="@(EligibleFilteredPlanOrderIds.Count == 0 || isBulkNotifyingPlans)" @onclick="NotifyAllFilteredPlansAsync">
            @(isBulkNotifyingPlans ? "Notifying..." : $"Notify All ({EligibleFilteredPlanOrderIds.Count})")
          </button>
        </div>

        <div class="table-wrap" id="activeplans-scroll">
          <table>
            <thead>
              <tr>
                <th>Order</th>
                <th>User</th>
                <th>Email</th>
                <th>Product</th>
                <th>Ordered</th>
                <th>Valid From</th>
                <th>Valid To</th>
                <th>State</th>
                <th>Reminder</th>
              </tr>
            </thead>
            <tbody>
              @if (FilteredActivePlans.Count == 0)
              {
                <tr>
                  <td colspan="9">No plans found.</td>
                </tr>
              }
              else
              {
                @foreach (var plan in FilteredActivePlans.Take(visibleActivePlans))
                {
                  <tr>
                    <td>ORD-@plan.OrderId</td>
                    <td>@plan.UserFullName</td>
                    <td>@plan.UserEmail</td>
                    <td>@plan.ProductName</td>
                    <td>@plan.OrderedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</td>
                    <td>@(plan.ValidFromUtc.HasValue ? plan.ValidFromUtc.Value.ToLocalTime().ToString("dd MMM yyyy") : "-")</td>
                    <td>@(plan.ValidToUtc.HasValue ? plan.ValidToUtc.Value.ToLocalTime().ToString("dd MMM yyyy") : "-")</td>
                    <td>
                      <span class="status-pill @(plan.PlanState == "Active" ? "success" : plan.PlanState == "Expired" ? "warning" : "neutral")">@plan.PlanState</span>
                    </td>
                    <td>
                      @if (!plan.IsEligibleForReminder)
                      {
                        <span class="helper-text">—</span>
                      }
                      else
                      {
                        <button class="product-action-btn"
                                type="button"
                                disabled="@IsPlanReminded(plan.OrderId)"
                                @onclick="() => SendPlanReminderAsync(plan)">
                          @(IsPlanReminded(plan.OrderId) ? "Reminded" : (plan.ReminderType == "ExpiringSoon" ? "Notify (Expiring)" : "Notify (Expired)"))
                        </button>
                      }
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
          <div id="activeplans-sentinel" style="height:1px;"></div>
        </div>
      }
      else if (activeSection == AdminSection.Orders)
      {
        <div class="panel-header">
          <div>
            <h3>Order Trace</h3>
            <p class="section-intro">Filter orders instantly and keep the table scrollable while saving status changes.</p>
          </div>
          <span class="badge">Live Admin Control</span>
        </div>

        <div class="panel-header" style="margin-top: 1.25rem;">
          <div>
            <h3>Order Pending Verification</h3>
            <p class="section-intro">These orders are still marked as Pending. Verify payment and mark Completed so the user can access the product.</p>
          </div>
          <span class="badge">Pending</span>
        </div>

        <div class="lead-list" style="margin-bottom: 1.5rem;">
          @if (PendingOrdersForVerification.Count == 0)
          {
            <p class="empty-note">No pending orders are waiting right now.</p>
          }
          else
          {
            @foreach (var order in PendingOrdersForVerification)
            {
              <div class="lead-card" style="cursor: default;">
                <div class="lead-card-header">
                  <div>
                    <h4>ORD-@order.OrderId — @order.ProductName</h4>
                    <p>@order.UserFullName (@order.UserEmail)</p>
                  </div>
                  <span class="status pending">@NormalizeOrderStatus(order.Status)</span>
                </div>

                <div class="lead-meta-row">
                  <span class="lead-meta-chip">@order.PaymentMethod</span>
                  <span class="lead-meta-chip">@adminCurrency.FormatFromUsd(order.TotalAmount)</span>
                  <span class="lead-meta-chip">@order.OrderedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                </div>

                <div class="button-row" style="margin-top: .75rem;">
                  <button class="submit-btn" type="button" disabled="@(savingOrderIds.Contains(order.OrderId))" @onclick="() => MarkOrderCompletedAsync(order)">
                    @(savingOrderIds.Contains(order.OrderId) ? "Saving..." : "Mark Completed")
                  </button>
                </div>
              </div>
            }
          }
        </div>

        <div class="orders-toolbar">
          <input class="filter-box" value="@orderFilter" @oninput="OnOrderFilterInput" placeholder="Filter orders by id, product, user, email, or status..." />
          <div class="orders-export">
            <button class="ghost-btn" type="button" @onclick="ExportOrdersCsvAsync">Export Excel</button>
            <button class="ghost-btn" type="button" @onclick="ExportOrdersPdfAsync">Export PDF</button>
            <button class="ghost-btn" type="button" @onclick="ExportOrdersHtmlAsync">Export HTML</button>
          </div>
        </div>

        <div class="table-wrap" id="orders-scroll">
          <table>
            <thead>
              <tr>
                <th>Order</th>
                <th>Product</th>
                <th>User</th>
                <th>Email</th>
                <th>Qty</th>
                <th>Total</th>
                <th>Ordered</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              @if (FilteredOrders.Count == 0)
              {
                <tr>
                  <td colspan="8">No orders match this filter.</td>
                </tr>
              }
              else
              {
                @foreach (var row in FilteredOrders.Take(visibleOrders))
                {
                  <tr>
                    <td><strong>ORD-@row.OrderId</strong></td>
                    <td>@row.ProductName</td>
                    <td>@row.UserFullName</td>
                    <td>@row.UserEmail</td>
                    <td>@row.Quantity</td>
                    <td>@adminCurrency.FormatFromUsd(row.TotalAmount)</td>
                    <td>@row.OrderedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</td>
                    <td>
                      <div class="order-actions">
                        <span class="status @GetStatusCss(row.Status)">@NormalizeOrderStatus(row.Status)</span>
                        <select class="status-select" value="@GetPendingOrderStatus(row)" @onchange="e => HandlePendingOrderStatusChange(row.OrderId, e.Value?.ToString())">
                          <option value="Pending">Pending</option>
                          <option value="Completed">Completed</option>
                          <option value="Denied">Denied</option>
                        </select>
                        <button class="ghost-btn" type="button" disabled="@(!IsOrderStatusDirty(row) || savingOrderIds.Contains(row.OrderId))" @onclick="() => SaveOrderStatusAsync(row)">
                          @(savingOrderIds.Contains(row.OrderId) ? "Saving..." : "Save")
                        </button>
                      </div>
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
          <div id="orders-sentinel" style="height:1px;"></div>
        </div>
      }
      else if (activeSection == AdminSection.Customers)
      {
        <div class="panel-header">
          <div>
            <h3>Customers</h3>
            <p class="section-intro">This section loads the users table directly from the admin auth endpoint.</p>
          </div>
          <span class="badge">User Accounts</span>
        </div>

        <input class="filter-box" value="@customerFilter" @oninput="OnCustomerFilterInput" placeholder="Filter customers by name, email, phone, role, or status..." />

        <div class="table-wrap" id="customers-scroll">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Contact</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created</th>
                <th>Last Login</th>
              </tr>
            </thead>
            <tbody>
              @if (FilteredCustomers.Count == 0)
              {
                <tr>
                  <td colspan="6">No customers match this filter.</td>
                </tr>
              }
              else
              {
                @foreach (var customer in FilteredCustomers.Take(visibleCustomers))
                {
                  <tr>
                    <td>
                      <div class="customer-cell">
                        <strong>@customer.FullName</strong>
                        <small>ID @customer.Id</small>
                      </div>
                    </td>
                    <td>
                      <div class="customer-cell">
                        <span>@customer.Email</span>
                        <small>@(string.IsNullOrWhiteSpace(customer.Phone) ? "No phone" : customer.Phone)</small>
                      </div>
                    </td>
                    <td>@customer.Role</td>
                    <td>
                      <div class="order-actions">
                        <span class="status @(customer.IsActive ? "open" : "closed")">@(customer.IsActive ? "Active" : "Inactive")</span>
                        <button class="ghost-btn" type="button" disabled="@savingCustomerIds.Contains(customer.Id)" @onclick="() => ToggleCustomerActiveAsync(customer)">
                          @(savingCustomerIds.Contains(customer.Id) ? "Saving..." : customer.IsActive ? "Deactivate" : "Activate")
                        </button>
                      </div>
                    </td>
                    <td>@customer.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>@(customer.LastLoginAtUtc.HasValue ? customer.LastLoginAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "Never")</td>
                  </tr>
                }
              }
            </tbody>
          </table>
          <div id="customers-sentinel" style="height:1px;"></div>
        </div>
      }
      else if (activeSection == AdminSection.Admins)
      {
        <div class="panel-header">
          <div>
            <h3>Admin Accounts</h3>
            <p class="section-intro">Add admins, edit details, reset passwords, and delete admin accounts.</p>
          </div>
          <span class="badge">Admins</span>
        </div>

        <EditForm class="form-grid admin-form-card" Model="createAdminRequest" OnValidSubmit="CreateAdminAsync">
          <DataAnnotationsValidator />
          <div class="admin-grid-2">
            <div>
              <label>Full Name</label>
              <InputText class="admin-input" @bind-Value="createAdminRequest.FullName" placeholder="Admin name" />
            </div>
            <div>
              <label>Email</label>
              <InputText class="admin-input" @bind-Value="createAdminRequest.Email" placeholder="admin@kohinoorea.com" />
            </div>
            <div>
              <label>Phone</label>
              <InputText class="admin-input" @bind-Value="createAdminRequest.Phone" placeholder="Optional phone" />
            </div>
            <div>
              <label>Temp Password</label>
              <InputText class="admin-input" @bind-Value="createAdminRequest.Password" placeholder="Set a temp password" type="password" />
            </div>
          </div>
          <div>
            <label>Admin Access</label>
            <div class="role-toggle-bar">
              <div class="role-toggle-actions">
                <button class="role-chip @(IsAllRolesSelected(createAdminRoles) ? "selected" : null)" type="button" @onclick="SelectAllAdminRoles">
                  <span class="dot"></span> Full Access
                </button>
                <button class="role-chip @(!IsAnyRoleSelected(createAdminRoles) ? "selected" : null)" type="button" @onclick="ClearAdminRoles">
                  <span class="dot"></span> None
                </button>
                <button class="role-chip @(IsSupportOnly(createAdminRoles) ? "selected" : null)" type="button" @onclick="SelectSupportOnly">
                  <span class="dot"></span> Support Only
                </button>
                <button class="role-chip @(IsOrdersOnly(createAdminRoles) ? "selected" : null)" type="button" @onclick="SelectOrdersOnly">
                  <span class="dot"></span> Orders Only
                </button>
              </div>
              <div class="role-toggle-actions">
                <span class="helper-text">Tap modules to grant access.</span>
              </div>
            </div>

            <div class="role-grid">
              <div class="role-tile @(createAdminRoles.Products ? "selected" : null)" @onclick="ToggleProductsRole">
                <div>
                  <strong>Products</strong>
                  <small>Create and edit plans</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Products ? "On" : "Off")</span>
              </div>
              <div class="role-tile @(createAdminRoles.Orders ? "selected" : null)" @onclick="ToggleOrdersRole">
                <div>
                  <strong>Orders</strong>
                  <small>Verify and complete orders</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Orders ? "On" : "Off")</span>
              </div>
              <div class="role-tile @(createAdminRoles.Customers ? "selected" : null)" @onclick="ToggleCustomersRole">
                <div>
                  <strong>Customers</strong>
                  <small>Manage user accounts</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Customers ? "On" : "Off")</span>
              </div>
              <div class="role-tile @(createAdminRoles.Admins ? "selected" : null)" @onclick="ToggleAdminsRole">
                <div>
                  <strong>Admins</strong>
                  <small>Admin accounts + passwords</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Admins ? "On" : "Off")</span>
              </div>
              <div class="role-tile @(createAdminRoles.Faq ? "selected" : null)" @onclick="ToggleFaqRole">
                <div>
                  <strong>FAQ</strong>
                  <small>Publish FAQ content</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Faq ? "On" : "Off")</span>
              </div>
              <div class="role-tile @(createAdminRoles.Notifications ? "selected" : null)" @onclick="ToggleNotificationsRole">
                <div>
                  <strong>Notifications</strong>
                  <small>Lead follow-ups</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Notifications ? "On" : "Off")</span>
              </div>
              <div class="role-tile @(createAdminRoles.Contact ? "selected" : null)" @onclick="ToggleContactRole">
                <div>
                  <strong>Contact</strong>
                  <small>Inbox + replies</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Contact ? "On" : "Off")</span>
              </div>
              <div class="role-tile @(createAdminRoles.Support ? "selected" : null)" @onclick="ToggleSupportRole">
                <div>
                  <strong>Support</strong>
                  <small>Tickets and threads</small>
                </div>
                <span class="role-pill">@(createAdminRoles.Support ? "On" : "Off")</span>
              </div>
            </div>
          </div>
          <div class="button-row">
            <button class="admin-btn primary" type="submit" disabled="@isSavingAdmin">@(isSavingAdmin ? "Saving..." : "Add Admin")</button>
          </div>
        </EditForm>

        <input class="filter-box admin-input" @bind="adminFilter" @bind:event="oninput" placeholder="Filter admins by name, email, phone, or status..." style="margin-top: 1rem;" />

        <div class="table-wrap admin-table" id="admins-scroll">
          <table>
            <thead>
              <tr>
                <th>Admin</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              @if (FilteredAdmins.Count == 0)
              {
                <tr>
                  <td colspan="6">No admins match this filter.</td>
                </tr>
              }
              else
              {
                @foreach (var admin in FilteredAdmins)
                {
                  <tr>
                    <td>
                      <InputText class="admin-input" @bind-Value="admin.FullName" />
                    </td>
                    <td>@admin.Email</td>
                    <td>
                      <InputText class="admin-input" @bind-Value="admin.Phone" />
                    </td>
                    <td>
                      <select class="status-select" value="@(admin.IsActive ? "Active" : "Inactive")" @onchange="e => HandleAdminActiveChange(admin.Id, e.Value?.ToString())">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                      </select>
                    </td>
                    <td>@admin.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>
                      <div class="admin-actions">
                        <button class="admin-btn primary" type="button" disabled="@savingAdminIds.Contains(admin.Id)" @onclick="() => SaveAdminAsync(admin)">
                          @(savingAdminIds.Contains(admin.Id) ? "Saving..." : "Save")
                        </button>
                        <button class="admin-btn" type="button" disabled="@savingAdminIds.Contains(admin.Id)" @onclick="() => StartResetAdminPassword(admin.Id)">
                          Reset Password
                        </button>
                        <button class="admin-btn danger" type="button" disabled="@savingAdminIds.Contains(admin.Id)" @onclick="() => DeleteAdminAsync(admin.Id)">
                          Delete
                        </button>
                      </div>
                      @if (adminIdResettingPassword == admin.Id)
                      {
                        <div style="margin-top:.5rem; display:flex; gap:.5rem; align-items:center;">
                          <input class="admin-input" style="max-width:260px;" @bind="adminNewPassword" @bind:event="oninput" placeholder="New password" type="password" />
                          <button class="admin-btn primary" type="button" disabled="@savingAdminIds.Contains(admin.Id)" @onclick="() => ResetAdminPasswordAsync(admin.Id)">Save</button>
                          <button class="admin-btn" type="button" @onclick="CancelResetAdminPassword">Cancel</button>
                        </div>
                      }
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      }
      else if (activeSection == AdminSection.Faq)
      {
        <div class="panel-header">
          <div>
            <h3>FAQ Management</h3>
            <p class="section-intro">Create premium FAQ entries, control their order, and decide which ones appear on the public FAQ page.</p>
          </div>
          <span class="badge">Public Content</span>
        </div>

        <div class="faq-layout">
          <div class="thread-panel">
            <input class="filter-box" @bind="faqFilter" @bind:event="oninput" placeholder="Filter FAQs by question, answer, order, or status..." />

            <div class="faq-list">
              @if (FilteredFaqs.Count == 0)
              {
                <div class="faq-empty-panel">
                  <p class="empty-note">No FAQs match this filter yet.</p>
                </div>
              }
              else
              {
                @foreach (var faq in FilteredFaqs)
                {
                  <div class="faq-card @(editingFaqId == faq.Id ? "active" : null)">
                    <div class="faq-card-header">
                      <h4>@faq.Question</h4>
                      <span class="status @(faq.IsActive ? "open" : "closed")">@(faq.IsActive ? "Visible" : "Hidden")</span>
                    </div>

                    <p class="faq-card-answer">@faq.Answer</p>

                    <div class="faq-card-meta">
                      <span class="faq-chip">Order @faq.DisplayOrder</span>
                      <span class="faq-chip">Created @faq.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                    </div>

                    <div class="button-row">
                      <button class="ghost-btn" type="button" @onclick="() => StartEditingFaq(faq)">Edit</button>
                      <button class="ghost-btn" type="button" @onclick="() => ToggleFaqActiveAsync(faq)">
                        @(faq.IsActive ? "Hide" : "Show")
                      </button>
                      <button class="ghost-btn force" type="button" @onclick="() => DeleteFaqAsync(faq)">Delete</button>
                    </div>
                  </div>
                }
              }
            </div>
          </div>

          <EditForm class="management-form form-grid" Model="faqRequest" OnValidSubmit="SaveFaqAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div>
              <label>Question</label>
              <InputText @bind-Value="faqRequest.Question" placeholder="What is Kohinoor EA?" />
            </div>

            <div>
              <label>Answer</label>
              <InputTextArea @bind-Value="faqRequest.Answer" placeholder="Write the full FAQ answer here..." />
            </div>

            <div class="form-row">
              <div>
                <label>Display Order</label>
                <InputNumber @bind-Value="faqRequest.DisplayOrder" />
              </div>
              <label class="toggle-row">
                <InputCheckbox @bind-Value="faqRequest.IsActive" /> Show on public FAQ page
              </label>
            </div>

            <p class="helper-text">Lower display order appears first on the public FAQ page. Hidden FAQs stay in admin only.</p>

            <div class="button-row">
              <button class="submit-btn" type="submit" disabled="@isSavingFaq">@(isSavingFaq ? "Saving..." : editingFaqId.HasValue ? "Update FAQ" : "Add FAQ")</button>
              @if (editingFaqId.HasValue)
              {
                <button class="ghost-btn" type="button" @onclick="ResetFaqForm">Cancel Edit</button>
              }
            </div>
          </EditForm>
        </div>
      }
      else if (activeSection == AdminSection.Notifications)
      {
        <div class="panel-header">
          <div>
            <h3>Follow-up Notifications</h3>
            <p class="section-intro">Select a signed-up user who still has no completed purchase, then send a follow-up email from the admin dashboard.</p>
          </div>
          <span class="badge">Lead Follow-up</span>
        </div>

        <div class="notification-layout">
          <div>
            <input class="filter-box" @bind="followUpLeadFilter" @bind:event="oninput" placeholder="Filter leads by name, email, phone, plan, broker, or order status..." />

            <div class="lead-list">
              @if (FilteredFollowUpLeads.Count == 0)
              {
                <p class="empty-note">No follow-up users are waiting right now.</p>
              }
              else
              {
                @foreach (var lead in FilteredFollowUpLeads)
                {
                  <button class="lead-card @(selectedFollowUpLeadUserId == lead.UserId ? "active" : null)" type="button" @onclick="() => SelectFollowUpLead(lead)">
                    <div class="lead-card-header">
                      <div>
                        <h4>@lead.FullName</h4>
                        <p>@lead.Email</p>
                      </div>
                      <span class="status pending">No purchase</span>
                    </div>

                    <div class="lead-meta-row">
                      <span class="lead-meta-chip">@GetLeadPlanLabel(lead.RequestedPlan)</span>
                      <span class="lead-meta-chip">@GetLeadOrderSummary(lead)</span>
                      <span class="lead-meta-chip">Joined @lead.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                    </div>
                  </button>
                }
              }
            </div>
          </div>

          <EditForm class="thread-panel form-grid" Model="followUpEmailRequest" OnValidSubmit="SendFollowUpNotificationAsync">
            <DataAnnotationsValidator />

            @if (SelectedFollowUpLead is null)
            {
              <p class="empty-note">Select a user from the left to prepare a notification email.</p>
            }
            else
            {
              <div class="notification-recipient">
                <strong>@SelectedFollowUpLead.FullName</strong>
                <span>@SelectedFollowUpLead.Email</span>
                <span>@GetLeadPlanLabel(SelectedFollowUpLead.RequestedPlan) | @GetLeadOrderSummary(SelectedFollowUpLead)</span>
              </div>

              <div class="lead-detail-grid">
                <div class="lead-detail-card">
                  <strong>Phone</strong>
                  <span>@(string.IsNullOrWhiteSpace(SelectedFollowUpLead.Phone) ? "Not provided" : SelectedFollowUpLead.Phone)</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Broker</strong>
                  <span>@(string.IsNullOrWhiteSpace(SelectedFollowUpLead.Mt4Broker) ? "Not provided" : SelectedFollowUpLead.Mt4Broker)</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Last Login</strong>
                  <span>@(SelectedFollowUpLead.LastLoginAtUtc.HasValue ? SelectedFollowUpLead.LastLoginAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "Never")</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Last Order</strong>
                  <span>@GetLeadLastOrderText(SelectedFollowUpLead)</span>
                </div>
              </div>

              <div>
                <label>Email Subject</label>
                <InputText @bind-Value="followUpEmailRequest.Subject" placeholder="Kohinoor EA follow-up" />
                <ValidationMessage For="@(() => followUpEmailRequest.Subject)" />
              </div>

              <div>
                <label>Email Message</label>
                <InputTextArea @bind-Value="followUpEmailRequest.Message" placeholder="Write your follow-up message here..." />
                <ValidationMessage For="@(() => followUpEmailRequest.Message)" />
              </div>

              <p class="helper-text">This email is sent to the selected user's registered account email using the SMTP settings configured on the server.</p>

              <div class="button-row">
                <button class="submit-btn" type="submit" disabled="@(!CanSendFollowUpEmail)">@(isSendingFollowUpEmail ? "Sending..." : "Send Notification Email")</button>
                <button class="ghost-btn" type="button" disabled="@(SelectedFollowUpLead is null)" @onclick="ResetFollowUpDraft">Reset Draft</button>
              </div>
            }
          </EditForm>
        </div>
      }
      else if (activeSection == AdminSection.Contact)
      {
        <div class="panel-header">
          <div>
            <h3>Contact Inbox</h3>
            <p class="section-intro">Review contact requests from the public page, select any message, and reply to the sender by email from the dashboard.</p>
          </div>
          <span class="badge">Contact Replies</span>
        </div>

        <div class="contact-admin-layout">
          <div>
            <input class="filter-box" @bind="contactFilter" @bind:event="oninput" placeholder="Filter contact messages by name, email, subject, message, or reply status..." />

            <div class="lead-list">
              @if (FilteredContactMessages.Count == 0)
              {
                <p class="empty-note">No contact requests have arrived yet.</p>
              }
              else
              {
                @foreach (var contactMessage in FilteredContactMessages)
                {
                  <button class="lead-card @(selectedContactMessageId == contactMessage.Id ? "active" : null)" type="button" @onclick="() => SelectContactMessage(contactMessage)">
                    <div class="lead-card-header">
                      <div>
                        <h4>@contactMessage.Name</h4>
                        <p>@contactMessage.Email</p>
                      </div>
                      <span class="status @(contactMessage.IsReplied ? "completed" : "pending")">@(contactMessage.IsReplied ? "Replied" : "Awaiting reply")</span>
                    </div>

                    <p>@contactMessage.Subject</p>
                    <div class="lead-meta-row">
                      <span class="lead-meta-chip">Received @contactMessage.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                      @if (contactMessage.LastRepliedAtUtc.HasValue)
                      {
                        <span class="lead-meta-chip">Last replied @contactMessage.LastRepliedAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                      }
                    </div>
                  </button>
                }
              }
            </div>
          </div>

          <EditForm class="thread-panel form-grid" Model="contactReplyRequest" OnValidSubmit="SendContactReplyAsync">
            <DataAnnotationsValidator />

            @if (SelectedContactMessage is null)
            {
              <p class="empty-note">Select a contact message from the left to review it and send an email reply.</p>
            }
            else
            {
              <div class="notification-recipient">
                <strong>@SelectedContactMessage.Name</strong>
                <span>@SelectedContactMessage.Email</span>
                <span>@(SelectedContactMessage.IsReplied ? "This contact already has a reply history." : "Waiting for the first admin reply.")</span>
              </div>

              <div class="lead-detail-grid">
                <div class="lead-detail-card">
                  <strong>Subject</strong>
                  <span>@SelectedContactMessage.Subject</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Received</strong>
                  <span>@SelectedContactMessage.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Status</strong>
                  <span>@(SelectedContactMessage.IsReplied ? "Replied" : "Awaiting reply")</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Last Reply</strong>
                  <span>@(SelectedContactMessage.LastRepliedAtUtc.HasValue ? SelectedContactMessage.LastRepliedAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "No reply sent yet")</span>
                </div>
              </div>

              <div class="contact-message-preview">
                <strong>Original Message</strong>
                <p>@SelectedContactMessage.Message</p>
              </div>

              <div>
                <label>Email Subject</label>
                <InputText @bind-Value="contactReplyRequest.Subject" placeholder="Re: Your Kohinoor EA inquiry" />
                <ValidationMessage For="@(() => contactReplyRequest.Subject)" />
              </div>

              <div>
                <label>Email Message</label>
                <InputTextArea @bind-Value="contactReplyRequest.Message" placeholder="Write your reply here..." />
                <ValidationMessage For="@(() => contactReplyRequest.Message)" />
              </div>

              <p class="helper-text">Reply emails use the same SMTP delivery flow already used for OTP and notification emails.</p>

              <div class="button-row">
                <button class="submit-btn" type="submit" disabled="@(!CanSendContactReply)">@(isSendingContactReply ? "Sending..." : "Send Reply Email")</button>
                <button class="ghost-btn" type="button" disabled="@(SelectedContactMessage is null)" @onclick="ResetContactReplyDraft">Reset Draft</button>
                <button class="ghost-btn force" type="button" disabled="@(SelectedContactMessage is null)" @onclick="DeleteSelectedContactMessageAsync">Delete</button>
              </div>
            }
          </EditForm>
        </div>
      }
      else if (activeSection == AdminSection.Support)
      {
        var selectedSupportQuery = SelectedSupportThreadQuery;
        <div class="panel-header">
          <div>
            <h3>Support Query Trace</h3>
            <p class="section-intro">Support remains focused: choose any query on the left and reply from the thread panel on the right.</p>
          </div>
          <div style="display:flex; gap:10px; align-items:center;">
            <span class="badge">Admin Support</span>
            <button class="ghost-btn" type="button" @onclick="ToggleSupportMaximize">@(isSupportMaximized ? "Minimize" : "Focus Thread")</button>
          </div>
        </div>

        <div class="support-layout @(isSupportMaximized ? "maximized" : null)" id="support-scroll">
          <div class="query-list">
            @if (supportTrace.Count == 0)
            {
              <p class="empty-note">No support queries yet.</p>
            }
            else
            {
              @foreach (var query in FilteredSupportQueries.Take(visibleSupport))
              {
                <div class="query-card @(expandedSupportQueryId == query.Id ? "active" : null)">
                  <h4>@query.Subject</h4>
                  <p><strong>@query.Category:</strong> @query.Message</p>
                  <div class="query-meta">
                    <span>@query.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                    <span style="display:flex; align-items:center; gap:10px;">
                      <span class="status @GetStatusCss(query.Status)">@query.Status</span>
                      <button class="ghost-btn" type="button" @onclick="() => ToggleSupportThreadAsync(query.Id)">@(expandedSupportQueryId == query.Id ? "Close" : "Open")</button>
                    </span>
                  </div>
                </div>
              }
              <div id="support-sentinel" style="height:1px;"></div>
            }
          </div>

          <div class="thread-panel">
            @if (!expandedSupportQueryId.HasValue || selectedSupportQuery is null)
            {
              <p class="empty-note">Open any support query to inspect the full conversation and send an admin reply.</p>
            }
            else
            {
              <div class="thread-meta" style="margin-bottom:14px;">
                <div>
                  <h4 style="margin-bottom:4px;">@selectedSupportQuery.Subject</h4>
                  <p class="summary-caption" style="margin-bottom:0;">Ticket #@selectedSupportQuery.Id • @selectedSupportQuery.Category • @selectedSupportQuery.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</p>
                </div>
                <div class="button-row">
                  <button class="ghost-btn" type="button" disabled="@isUpdatingSupportTicketStatus" @onclick="ToggleSelectedSupportTicketStatusAsync">
                    @(IsSupportTicketClosed(selectedSupportQuery.Status) ? "Reopen Ticket" : "Close Ticket")
                  </button>
                  <button class="ghost-btn" type="button" @onclick="CloseSupportThread">Close Thread</button>
                </div>
              </div>

              <div class="thread-stack">
                @if (expandedSupportMessages.Count == 0)
                {
                  <p class="empty-note">No messages yet.</p>
                }
                else
                {
                  @foreach (var message in expandedSupportMessages)
                  {
                    var bubbleCss = string.Equals(message.SenderRole, AuthRoles.Admin, StringComparison.OrdinalIgnoreCase) ? "admin" : "user";
                    <div class="chat-bubble @bubbleCss">
                      @message.Message
                      <span class="chat-meta">@message.SenderRole • @message.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                    </div>
                  }
                }
              </div>

              <EditForm Model="adminReplyRequest" OnValidSubmit="SendAdminReplyAsync">
                <DataAnnotationsValidator />
                <label>Reply to Customer</label>
                <InputTextArea Value="@adminReplyRequest.Message"
                               ValueChanged="OnAdminReplyMessageChangedAsync"
                               ValueExpression="@(() => adminReplyRequest.Message)"
                               placeholder="Reply to this query..." />
                @if (!string.IsNullOrWhiteSpace(realtimeTypingLine))
                {
                  <p class="summary-caption" style="margin-top:8px;">@realtimeTypingLine</p>
                }
                <button class="submit-btn" type="submit" style="margin-top:12px;">Send Reply</button>
              </EditForm>
            }
          </div>
        </div>
      }
    </section>
  </main>
</div>
}
else
{
  <div class="loading-shell">Loading admin dashboard...</div>
}

<div class="toast-container">
  @foreach (var toast in toasts)
  {
    <div class="toast @(toast.IsError ? "error" : "success")">@toast.Text</div>
  }
</div>

@code {
