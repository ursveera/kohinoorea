    private HashSet<string> myRoles = new(StringComparer.OrdinalIgnoreCase);

    private bool HasRole(string role) => myRoles.Contains(role);

    private bool IsFullAdmin => myRoles.Contains(AuthRoles.Admin) && !myRoles.Any(r => r.StartsWith("Admin.", StringComparison.OrdinalIgnoreCase));

    private bool CanAccess(AdminSection section)
    {
        if (!myRoles.Contains(AuthRoles.Admin))
        {
            return false;
        }

        if (IsFullAdmin)
        {
            return true;
        }

        return section switch
        {
            AdminSection.Products => HasRole(AdminSectionRoles.Products),
            AdminSection.ActivePlans => HasRole(AdminSectionRoles.Orders),
            AdminSection.Orders => HasRole(AdminSectionRoles.Orders),
            AdminSection.Customers => HasRole(AdminSectionRoles.Customers),
            AdminSection.Admins => HasRole(AdminSectionRoles.Admins),
            AdminSection.Faq => HasRole(AdminSectionRoles.Faq),
            AdminSection.Notifications => HasRole(AdminSectionRoles.Notifications),
            AdminSection.Contact => HasRole(AdminSectionRoles.Contact),
            AdminSection.Support => HasRole(AdminSectionRoles.Support),
            _ => false
        };
    }

    private AdminSection GetDefaultAllowedSection()
    {
        var ordered = new[]
        {
            AdminSection.Products,
            AdminSection.Orders,
            AdminSection.Customers,
            AdminSection.Admins,
            AdminSection.Faq,
            AdminSection.Notifications,
            AdminSection.Contact,
            AdminSection.Support
        };

        return ordered.FirstOrDefault(CanAccess);
    }

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += HandleLocationChanged;

        var meResponse = await Http.GetAsync("api/auth/me");
        if (!meResponse.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        var me = await meResponse.Content.ReadFromJsonAsync<AuthResponse>();
        if (me is null || !string.Equals(me.Role, AuthRoles.Admin, StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/dashboard", true);
            return;
        }

        profileEmail = me?.Email ?? string.Empty;
        myRoles = new HashSet<string>(me.Roles ?? new List<string> { AuthRoles.Admin }, StringComparer.OrdinalIgnoreCase);

        if (!CanAccess(activeSection))
        {
            activeSection = GetDefaultAllowedSection();
        }

        await LoadDashboardDataAsync();
        ApplySectionFromUri(Navigation.Uri, shouldQueueScroll: true);
        canRenderDashboard = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrWhiteSpace(pendingScrollAnchor))
        {
            var anchor = pendingScrollAnchor;
            pendingScrollAnchor = null;
            await JS.InvokeVoidAsync("eval", $"document.getElementById('{anchor}')?.scrollIntoView({{ behavior: 'smooth', block: 'start' }});");
        }

        await base.OnAfterRenderAsync(firstRender);
        await EnsureInfiniteScrollAsync();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private void NavigateToSection(AdminSection section)
    {
        activeSection = section;
        pendingScrollAnchor = GetSectionHash(section);
        Navigation.NavigateTo($"/admin-dashboard#{GetSectionHash(section)}", replace: true);

        ResetPagingForSection(section);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ApplySectionFromUri(e.Location, shouldQueueScroll: true);
        _ = InvokeAsync(StateHasChanged);
    }

    private void ApplySectionFromUri(string uri, bool shouldQueueScroll)
    {
        var fragment = Navigation.ToAbsoluteUri(uri).Fragment.TrimStart('#').ToLowerInvariant();
        var section = fragment switch
        {
            "active-plans" => AdminSection.ActivePlans,
            "orders" => AdminSection.Orders,
            "customers" => AdminSection.Customers,
            "admins" => AdminSection.Admins,
            "faq" => AdminSection.Faq,
            "notifications" => AdminSection.Notifications,
            "contact" => AdminSection.Contact,
            "support" => AdminSection.Support,
            _ => AdminSection.Products
        };

        activeSection = section;
        if (!CanAccess(activeSection))
        {
            activeSection = GetDefaultAllowedSection();
        }
        if (shouldQueueScroll)
        {
            pendingScrollAnchor = GetSectionHash(activeSection);
        }

        ResetPagingForSection(activeSection);
    }

    private void ResetPagingForSection(AdminSection section)
    {
        switch (section)
        {
            case AdminSection.Orders:
                visibleOrders = PageSize;
                break;
            case AdminSection.Customers:
                visibleCustomers = PageSize;
                break;
            case AdminSection.ActivePlans:
                visibleActivePlans = PageSize;
                break;
            case AdminSection.Support:
                visibleSupport = PageSize;
                break;
        }
    }

    private static string GetSectionHash(AdminSection section)
    {
        return section switch
        {
            AdminSection.ActivePlans => "active-plans",
            AdminSection.Orders => "orders",
            AdminSection.Customers => "customers",
            AdminSection.Admins => "admins",
            AdminSection.Faq => "faq",
            AdminSection.Notifications => "notifications",
            AdminSection.Contact => "contact",
            AdminSection.Support => "support",
            _ => "products"
        };
    }

    private async Task LoadDashboardDataAsync()
    {
        statusMessage = null;

        var ordersTask = CanAccess(AdminSection.Orders) ? Http.GetAsync("api/commerce/orders/trace") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var productsTask = CanAccess(AdminSection.Products) ? Http.GetAsync("api/commerce/products?all=true") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var activePlansTask = CanAccess(AdminSection.ActivePlans) ? Http.GetAsync("api/commerce/active-plans") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var faqsTask = CanAccess(AdminSection.Faq) ? Http.GetAsync("api/commerce/faqs/admin") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var contactsTask = CanAccess(AdminSection.Contact) ? Http.GetAsync("api/commerce/contact-messages") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var supportTask = CanAccess(AdminSection.Support) ? Http.GetAsync("api/commerce/support/trace") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var customersTask = CanAccess(AdminSection.Customers) ? Http.GetAsync("api/auth/users") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var adminsTask = CanAccess(AdminSection.Admins) ? Http.GetAsync("api/auth/admins") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));
        var followUpLeadsTask = CanAccess(AdminSection.Notifications) ? Http.GetAsync("api/auth/follow-up-leads") : Task.FromResult(new HttpResponseMessage(System.Net.HttpStatusCode.Forbidden));

        await Task.WhenAll(ordersTask, productsTask, activePlansTask, faqsTask, contactsTask, supportTask, customersTask, adminsTask, followUpLeadsTask);

        var ordersResponse = await ordersTask;
        var productsResponse = await productsTask;
        var activePlansResponse = await activePlansTask;
        var faqsResponse = await faqsTask;
        var contactsResponse = await contactsTask;
        var supportResponse = await supportTask;
        var customersResponse = await customersTask;
        var adminsResponse = await adminsTask;
        var followUpLeadsResponse = await followUpLeadsTask;

        orderTrace.Clear();
        if (ordersResponse.IsSuccessStatusCode)
        {
            var payload = await ordersResponse.Content.ReadFromJsonAsync<List<OrderTraceDto>>();
            orderTrace.AddRange(payload ?? Enumerable.Empty<OrderTraceDto>());
        }

        products.Clear();
        if (productsResponse.IsSuccessStatusCode)
        {
            var payload = await productsResponse.Content.ReadFromJsonAsync<List<ProductDto>>();
            products.AddRange(payload ?? Enumerable.Empty<ProductDto>());
        }

        activePlans.Clear();
        if (activePlansResponse.IsSuccessStatusCode)
        {
            var payload = await activePlansResponse.Content.ReadFromJsonAsync<List<ActivePlanDto>>();
            activePlans.AddRange(payload ?? Enumerable.Empty<ActivePlanDto>());
        }

        faqs.Clear();
        if (faqsResponse.IsSuccessStatusCode)
        {
            var payload = await faqsResponse.Content.ReadFromJsonAsync<List<FaqDto>>();
            faqs.AddRange(payload ?? Enumerable.Empty<FaqDto>());
        }

        contactMessages.Clear();
        if (contactsResponse.IsSuccessStatusCode)
        {
            var payload = await contactsResponse.Content.ReadFromJsonAsync<List<ContactMessageDto>>();
            contactMessages.AddRange(payload ?? Enumerable.Empty<ContactMessageDto>());
        }

        supportTrace.Clear();
        if (supportResponse.IsSuccessStatusCode)
        {
            var payload = await supportResponse.Content.ReadFromJsonAsync<List<SupportQueryDto>>();
            supportTrace.AddRange(payload ?? Enumerable.Empty<SupportQueryDto>());
        }

        customers.Clear();
        if (customersResponse.IsSuccessStatusCode)
        {
            var payload = await customersResponse.Content.ReadFromJsonAsync<List<AdminUserDto>>();
            customers.AddRange(payload ?? Enumerable.Empty<AdminUserDto>());
        }

        admins.Clear();
        if (adminsResponse.IsSuccessStatusCode)
        {
            var payload = await adminsResponse.Content.ReadFromJsonAsync<List<AdminUserDto>>();
            admins.AddRange(payload ?? Enumerable.Empty<AdminUserDto>());
        }

        followUpLeads.Clear();
        if (followUpLeadsResponse.IsSuccessStatusCode)
        {
            var payload = await followUpLeadsResponse.Content.ReadFromJsonAsync<List<AdminLeadNotificationDto>>();
            followUpLeads.AddRange(payload ?? Enumerable.Empty<AdminLeadNotificationDto>());
        }

        pendingOrderStatuses.Clear();
        foreach (var order in orderTrace)
        {
            pendingOrderStatuses[order.OrderId] = NormalizeOrderStatus(order.Status);
        }

        if (selectedFollowUpLeadUserId.HasValue && followUpLeads.All(lead => lead.UserId != selectedFollowUpLeadUserId.Value))
        {
            selectedFollowUpLeadUserId = null;
            followUpEmailRequest = new SendLeadFollowUpEmailRequest();
        }

        if (!selectedFollowUpLeadUserId.HasValue && followUpLeads.Count > 0)
        {
            SelectFollowUpLead(followUpLeads[0]);
        }

        if (selectedContactMessageId.HasValue && contactMessages.All(contactMessage => contactMessage.Id != selectedContactMessageId.Value))
        {
            selectedContactMessageId = null;
            contactReplyRequest = new SendContactReplyRequest();
        }

        if (!selectedContactMessageId.HasValue && contactMessages.Count > 0)
        {
            SelectContactMessage(contactMessages[0]);
        }

        productCount = products.Count;
        orderCount = orderTrace.Count;
        customerCount = customers.Count;
        adminCount = admins.Count;
        faqCount = faqs.Count;
        contactCount = contactMessages.Count;
        totalRevenue = orderTrace.Sum(x => x.TotalAmount);
    }

    private async Task EnsureInfiniteScrollAsync()
    {
        try
        {
            infiniteScrollModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./assets/js/admin-infinite-scroll.js");
            infiniteScrollDotNetRef ??= DotNetObjectReference.Create(this);

            // Always disconnect previous observer and attach for the current section.
            if (infiniteScrollHandle is not null)
            {
                try { await infiniteScrollHandle.InvokeVoidAsync("disconnect"); } catch { }
                try { await infiniteScrollHandle.DisposeAsync(); } catch { }
                infiniteScrollHandle = null;
            }

            var sentinelId = activeSection switch
            {
                AdminSection.Orders => "orders-sentinel",
                AdminSection.Customers => "customers-sentinel",
                AdminSection.ActivePlans => "activeplans-sentinel",
                AdminSection.Support => "support-sentinel",
                _ => null
            };

            if (string.IsNullOrWhiteSpace(sentinelId))
            {
                return;
            }

            // JS returns null if sentinel not in DOM yet.
            infiniteScrollHandle = await infiniteScrollModule!.InvokeAsync<IJSObjectReference?>(
                "observeSentinel",
                infiniteScrollDotNetRef,
                sentinelId,
                "OnInfiniteScrollHit");
        }
        catch
        {
        }
    }

    [JSInvokable]
    public Task OnInfiniteScrollHit()
    {
        switch (activeSection)
        {
            case AdminSection.Orders:
                visibleOrders = Math.Min(FilteredOrders.Count, visibleOrders + PageSize);
                break;
            case AdminSection.Customers:
                visibleCustomers = Math.Min(FilteredCustomers.Count, visibleCustomers + PageSize);
                break;
            case AdminSection.ActivePlans:
                visibleActivePlans = Math.Min(FilteredActivePlans.Count, visibleActivePlans + PageSize);
                break;
            case AdminSection.Support:
                visibleSupport = Math.Min(FilteredSupportQueries.Count, visibleSupport + PageSize);
                break;
        }

        return InvokeAsync(StateHasChanged);
    }

    private async Task ExportOrdersCsvAsync()
    {
        var items = FilteredOrders;
        var csv = BuildOrdersCsv(items);
        exportModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./assets/js/admin-export.js");
        await exportModule.InvokeVoidAsync("downloadTextFile", $"orders-{DateTime.UtcNow:yyyyMMdd-HHmm}.csv", csv, "text/csv;charset=utf-8");
    }

    private async Task ExportOrdersHtmlAsync()
    {
        var items = FilteredOrders;
