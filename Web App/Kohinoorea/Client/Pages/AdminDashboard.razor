  private async Task OnConfirmModalResult(bool confirmed)
  {
    showConfirmModal = false;
    if (confirmed && pendingForceDeleteProduct != null)
    {
      await ActuallyForceDeleteProductAsync(pendingForceDeleteProduct);
    }
    pendingForceDeleteProduct = null;
  }

  private Task HideConfirmModal()
  {
    showConfirmModal = false;
    StateHasChanged();
    return Task.CompletedTask;
  }

  private async Task ActuallyForceDeleteProductAsync(ProductDto product)
