    private async Task HandleProductImageSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
        {
            return;
        }

        selectedImageName = file.Name;
        isUploadingImage = true;

        try
        {
            using var content = new MultipartFormDataContent();
            await using var stream = file.OpenReadStream(10_000_000);
            using var fileContent = new StreamContent(stream);

            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/commerce/products/upload-image", content);
            if (!response.IsSuccessStatusCode)
            {
                statusMessage = "Image upload failed.";
                _ = ShowToastAsync("Image upload failed.", isError: true);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<ImageUploadResponse>();
            createProduct.ImageLink = payload?.ImageUrl ?? string.Empty;
            statusMessage = "Image uploaded.";
            _ = ShowToastAsync("Product image uploaded.");
        }
        finally
        {
            isUploadingImage = false;
        }
    }

    private void HandlePendingOrderStatusChange(long orderId, string? value)
    {
        pendingOrderStatuses[orderId] = NormalizeOrderStatus(value);
    }

    private string GetPendingOrderStatus(OrderTraceDto row)
    {
        return pendingOrderStatuses.TryGetValue(row.OrderId, out var value)
            ? NormalizeOrderStatus(value)
            : NormalizeOrderStatus(row.Status);
    }

    private bool IsOrderStatusDirty(OrderTraceDto row)
    {
        return !string.Equals(GetPendingOrderStatus(row), NormalizeOrderStatus(row.Status), StringComparison.OrdinalIgnoreCase);
    }

    private async Task SaveOrderStatusAsync(OrderTraceDto row)
    {
        var previousStatus = NormalizeOrderStatus(row.Status);
        var nextStatus = GetPendingOrderStatus(row);

        if (string.Equals(previousStatus, nextStatus, StringComparison.OrdinalIgnoreCase))
        {
            _ = ShowToastAsync($"Order #{row.OrderId} already has that status.");
            return;
        }

        row.Status = nextStatus;
        savingOrderIds.Add(row.OrderId);
        StateHasChanged();

        var response = await Http.PatchAsJsonAsync($"api/commerce/orders/{row.OrderId}/status", new { Status = nextStatus });
        if (!response.IsSuccessStatusCode)
        {
            row.Status = previousStatus;
            pendingOrderStatuses[row.OrderId] = previousStatus;
            savingOrderIds.Remove(row.OrderId);
            StateHasChanged();
            _ = ShowToastAsync($"Failed to update order #{row.OrderId}.", isError: true);
            return;
        }

        pendingOrderStatuses[row.OrderId] = nextStatus;
        savingOrderIds.Remove(row.OrderId);
        StateHasChanged();
        _ = ShowToastAsync($"Order #{row.OrderId} marked as {nextStatus}.");
    }

    private async Task ToggleCustomerActiveAsync(AdminUserDto customer)
    {
        var nextActive = !customer.IsActive;
        savingCustomerIds.Add(customer.Id);
        StateHasChanged();

        try
        {
            var response = await Http.PutAsync($"api/auth/users/{customer.Id}/active/{nextActive.ToString().ToLowerInvariant()}", content: null);
            AuthResponse? payload = null;

            if (response.Content.Headers.ContentLength is > 0 || response.Content.Headers.ContentType is not null)
            {
                try
                {
                    payload = await response.Content.ReadFromJsonAsync<AuthResponse>();
                }
                catch
                {
                }
            }

            if (!response.IsSuccessStatusCode || payload?.Success == false)
            {
                statusMessage = payload?.Message ?? "Unable to update customer status.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            statusMessage = payload?.Message ?? (nextActive ? "User activated successfully." : "User deactivated successfully.");
            _ = ShowToastAsync(statusMessage);
            await LoadDashboardDataAsync();
        }
        finally
        {
            savingCustomerIds.Remove(customer.Id);
            StateHasChanged();
        }
    }

