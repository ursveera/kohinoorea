    private async Task ExportOrdersPdfAsync()
    {
        var qs = string.IsNullOrWhiteSpace(orderFilter)
            ? string.Empty
            : $"?q={Uri.EscapeDataString(orderFilter.Trim())}";

        var response = await Http.GetAsync($"api/commerce/orders/trace/export/pdf{qs}");
        if (!response.IsSuccessStatusCode)
        {
            _ = ShowToastAsync("Failed to export PDF.", isError: true);
            return;
        }

        var bytes = await response.Content.ReadAsByteArrayAsync();
        exportModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./assets/js/admin-export.js");
        await exportModule.InvokeVoidAsync("downloadBytesFile", $"orders-{DateTime.UtcNow:yyyyMMdd-HHmm}.pdf", bytes, "application/pdf");
    }

    private string BuildOrdersCsv(IEnumerable<OrderTraceDto> items)
    {
        static string Csv(string? value)
        {
            var v = value ?? string.Empty;
            v = v.Replace("\r", " ").Replace("\n", " ").Trim();
            if (v.Contains('"'))
            {
                v = v.Replace("\"", "\"\"");
            }

            var mustQuote = v.Contains(',') || v.Contains('"');
            return mustQuote ? $"\"{v}\"" : v;
        }

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Order,Product,User,Email,Qty,Total,OrderedUtc,Status,Filter");

        var filter = string.IsNullOrWhiteSpace(orderFilter) ? "none" : orderFilter.Trim();
        foreach (var row in items)
        {
            sb.Append(Csv($"ORD-{row.OrderId}")).Append(',')
              .Append(Csv(row.ProductName)).Append(',')
              .Append(Csv(row.UserFullName)).Append(',')
              .Append(Csv(row.UserEmail)).Append(',')
              .Append(Csv(row.Quantity.ToString())).Append(',')
              .Append(Csv(row.TotalAmount.ToString(System.Globalization.CultureInfo.InvariantCulture))).Append(',')
              .Append(Csv(row.OrderedAtUtc.ToString("yyyy-MM-dd HH:mm:ss"))).Append(',')
              .Append(Csv(NormalizeOrderStatus(row.Status))).Append(',')
              .AppendLine(Csv(filter));
        }

        return sb.ToString();
    }

    private string BuildOrdersHtml(IEnumerable<OrderTraceDto> items, bool forPrint)
    {
        static string Html(string? raw) => System.Net.WebUtility.HtmlEncode(raw ?? string.Empty);
        var filter = string.IsNullOrWhiteSpace(orderFilter) ? "No filter" : orderFilter.Trim();
        var generated = DateTime.UtcNow.ToString("dd MMM yyyy HH:mm 'UTC'");

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("<!doctype html>");
        sb.AppendLine("<html><head><meta charset=\"utf-8\" />");
        sb.AppendLine("<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />");
        sb.AppendLine("<title>Kohinoor EA - Orders Export</title>");
        sb.AppendLine("<style>");
        sb.AppendLine("body{font-family:Inter,system-ui,Segoe UI,Roboto,Arial,sans-serif;margin:24px;color:#0f172a}");
        sb.AppendLine(".wrap{max-width:1100px;margin:0 auto}");
        sb.AppendLine(".title{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:14px}");
        sb.AppendLine("h1{font-size:22px;margin:0}");
        sb.AppendLine(".meta{color:#475569;font-size:12px}");
        sb.AppendLine(".pill{display:inline-flex;align-items:center;gap:6px;border:1px solid #e2e8f0;border-radius:999px;padding:6px 10px;background:#f8fafc;font-size:12px;color:#334155}");
        sb.AppendLine("table{width:100%;border-collapse:collapse;margin-top:14px}");
        sb.AppendLine("th,td{border-bottom:1px solid #e2e8f0;padding:10px 10px;text-align:left;font-size:12px;vertical-align:top}");
        sb.AppendLine("th{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#64748b}");
        sb.AppendLine(".right{text-align:right}");
        sb.AppendLine(".status{font-weight:700}");
        if (forPrint)
        {
            sb.AppendLine("@media print{body{margin:0} .pill{border-color:#cbd5e1}}");
        }
        sb.AppendLine("</style></head><body><div class=\"wrap\">");

        sb.AppendLine("<div class=\"title\">");
        sb.AppendLine("<div>");
        sb.AppendLine("<h1>Kohinoor EA - Orders Export</h1>");
        sb.AppendLine($"<div class=\"meta\">Generated: {Html(generated)} • Items: {items.Count()}</div>");
        sb.AppendLine("</div>");
        sb.AppendLine($"<div class=\"pill\">Filter: <strong>{Html(filter)}</strong></div>");
        sb.AppendLine("</div>");

        sb.AppendLine("<table><thead><tr>");
        sb.AppendLine("<th>Order</th><th>Product</th><th>User</th><th>Email</th><th class=\"right\">Qty</th><th class=\"right\">Total (USD)</th><th>Ordered (UTC)</th><th>Status</th>");
        sb.AppendLine("</tr></thead><tbody>");

        foreach (var row in items)
        {
            sb.AppendLine("<tr>");
            sb.AppendLine($"<td><strong>ORD-{row.OrderId}</strong></td>");
            sb.AppendLine($"<td>{Html(row.ProductName)}</td>");
            sb.AppendLine($"<td>{Html(row.UserFullName)}</td>");
            sb.AppendLine($"<td>{Html(row.UserEmail)}</td>");
            sb.AppendLine($"<td class=\"right\">{row.Quantity}</td>");
            sb.AppendLine($"<td class=\"right\">{row.TotalAmount:0.00}</td>");
            var orderedUtc = row.OrderedAtUtc.ToString("dd MMM yyyy HH:mm");
            sb.AppendLine($"<td>{Html(orderedUtc)}</td>");
            sb.AppendLine($"<td class=\"status\">{Html(NormalizeOrderStatus(row.Status))}</td>");
            sb.AppendLine("</tr>");
        }

        if (!items.Any())
        {
            sb.AppendLine("<tr><td colspan=\"8\" class=\"meta\">No orders match this filter.</td></tr>");
        }

        sb.AppendLine("</tbody></table>");
        sb.AppendLine("<div class=\"meta\" style=\"margin-top:14px\">Tip: For Excel, import the CSV export. For PDF, use the browser Save as PDF in the print dialog.</div>");
        sb.AppendLine("</div></body></html>");
        return sb.ToString();
    }

