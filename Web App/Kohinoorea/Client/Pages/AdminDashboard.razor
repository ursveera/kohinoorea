    private async Task CloseSupportTicketAsync(long queryId)
    {
        isUpdatingSupportTicketStatus = true;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/commerce/support/{queryId}/close", new CloseSupportTicketRequest
            {
                Message = "✅ Ticket closed by admin. If you still need help, please open a new ticket from your dashboard."
            });

            if (!response.IsSuccessStatusCode)
            {
                statusMessage = "Unable to close support ticket.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            await LoadSupportThreadAsync(queryId);

            var selectedQuery = supportTrace.FirstOrDefault(q => q.Id == queryId);
            if (selectedQuery is not null)
            {
                selectedQuery.Status = "Closed";
            }

            statusMessage = "Support ticket closed.";
            _ = ShowToastAsync(statusMessage);

            // Best-effort realtime ping so user view refreshes immediately.
            await PublishSupportRealtimeStatusAsync("Closed");
            await PublishSupportRealtimeAsync("✅ Ticket closed by admin.");
        }
        finally
        {
            isUpdatingSupportTicketStatus = false;
        }
    }

    private async Task UpdateSupportTicketStatusAsync(string nextStatus)
    {
        var selectedQuery = SelectedSupportThreadQuery;
        if (selectedQuery is null)
        {
            return;
        }

        isUpdatingSupportTicketStatus = true;

        try
        {
            var response = await Http.PatchAsJsonAsync($"api/commerce/support/{selectedQuery.Id}/status", new UpdateSupportQueryStatusRequest
            {
                Status = nextStatus
            });

            if (!response.IsSuccessStatusCode)
            {
                statusMessage = "Unable to update support ticket status.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            selectedQuery.Status = nextStatus;
            statusMessage = string.Equals(nextStatus, "Closed", StringComparison.OrdinalIgnoreCase)
                ? "Support ticket closed."
                : "Support ticket reopened.";
            _ = ShowToastAsync(statusMessage);
        }
        finally
        {
            isUpdatingSupportTicketStatus = false;
        }
    }

    private void CloseSupportThread()
    {
        expandedSupportQueryId = null;
        expandedSupportMessages.Clear();
        adminReplyRequest = new CreateSupportQueryMessageRequest();
        realtimeTypingLine = string.Empty;
        _ = StopSupportRealtimeAsync();
    }

    private async Task EnsureSupportRealtimeModuleAsync()
    {
        if (supportRealtimeModule is not null)
        {
            return;
        }

        supportRealtimeDotNetRef ??= DotNetObjectReference.Create(this);
        supportRealtimeModule = await JS.InvokeAsync<IJSObjectReference>("import", "./assets/js/firebase-support-chat.js");
    }

    private async Task StartSupportRealtimeAsync(long ownerUserId)
    {
        await EnsureSupportRealtimeModuleAsync();
        await StopSupportRealtimeAsync();
        realtimeTypingLine = string.Empty;

        var options = new
        {
            clientId = (string?)null,
            role = "admin",
            displayName = "Admin"
        };

        supportRealtimeInstance = await supportRealtimeModule!.InvokeAsync<IJSObjectReference>(
            "createSupportChat",
            supportRealtimeDotNetRef!,
            $"ticket-{ownerUserId}",
            options);
    }

    private async Task StopSupportRealtimeAsync()
    {
        if (supportRealtimeInstance is not null)
        {
            try { await supportRealtimeInstance.InvokeVoidAsync("dispose"); } catch { }
            try { await supportRealtimeInstance.DisposeAsync(); } catch { }
            supportRealtimeInstance = null;
        }
    }

    private async Task PublishSupportRealtimeAsync(string messageText)
    {
        if (supportRealtimeInstance is null || string.IsNullOrWhiteSpace(messageText))
        {
            return;
        }

        try
        {
            await supportRealtimeInstance.InvokeVoidAsync("sendMessage", messageText);
            await supportRealtimeInstance.InvokeVoidAsync("setTyping", false);
        }
        catch
        {
        }
    }

    private async Task PublishSupportRealtimeStatusAsync(string status)
    {
        if (supportRealtimeInstance is null || string.IsNullOrWhiteSpace(status))
        {
            return;
        }

        try
        {
            await supportRealtimeInstance.InvokeVoidAsync("setStatus", status);
        }
        catch
        {
        }
    }

    private async Task OnAdminReplyMessageChangedAsync(string value)
    {
        adminReplyRequest.Message = value;

        if (!expandedSupportQueryId.HasValue || supportRealtimeInstance is null)
        {
            return;
        }

        var now = DateTime.UtcNow;
        if (now - lastRealtimeTypingPingUtc < TimeSpan.FromSeconds(2))
        {
            return;
        }

        lastRealtimeTypingPingUtc = now;
        try
        {
            await supportRealtimeInstance.InvokeVoidAsync("setTyping", !string.IsNullOrWhiteSpace(adminReplyRequest.Message));
        }
        catch
        {
        }
    }

    public sealed class SupportRealtimeMessage
    {
        public string Id { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
        public string SenderRole { get; set; } = "user";
        public string SenderName { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public long? CreatedAt { get; set; }
    }

    public sealed class SupportTypingUser
    {
        public string ClientId { get; set; } = string.Empty;
        public string Role { get; set; } = "user";
        public string DisplayName { get; set; } = string.Empty;
    }

    [JSInvokable]
    public async Task OnMessage(SupportRealtimeMessage message)
    {
        if (!expandedSupportQueryId.HasValue)
        {
            return;
        }

        await LoadSupportThreadAsync(expandedSupportQueryId.Value);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnTyping(List<SupportTypingUser> typing)
    {
        if (typing is null || typing.Count == 0)
        {
            realtimeTypingLine = string.Empty;
        }
        else
        {
            var names = typing
                .Select(t => string.IsNullOrWhiteSpace(t.DisplayName) ? t.Role : t.DisplayName)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Take(1)
                .ToList();

            realtimeTypingLine = names.Count == 0 ? "User is typing…" : $"{names[0]} is typing…";
        }

        return InvokeAsync(StateHasChanged);
    }

