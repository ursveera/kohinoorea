@page "/admin-dashboard"
@implements IDisposable
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Forms
@using Kohinoorea.Client.Services

<PageTitle>Kohinoorea Admin Dashboard</PageTitle>
<PremiumConfirmModal
  Title="Confirm Permanent Delete"
  Message="@modalMessage"
  IsVisible="@showConfirmModal"
  OnResult="OnConfirmModalResult"
  OnClose="HideConfirmModal" />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  :root, body[data-theme="dark"] {
    --d-bg: linear-gradient(135deg,#060810 0%,#0f1623 55%,#040609 100%);
    --d-glow1: rgba(255,196,87,0.18);
    --d-glow2: rgba(128,90,213,0.18);
    --d-text: #f0f4ff;
    --d-muted: #7b8fa8;
    --d-sidebar-bg: rgba(6,9,18,0.82);
    --d-sidebar-border: rgba(255,255,255,0.07);
    --d-brand-sub: #6b7fa0;
    --d-nav-text: #b8c8de;
    --d-nav-hover: rgba(255,255,255,0.08);
    --d-nav-border: rgba(255,255,255,0.07);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.14),rgba(249,115,22,0.07));
    --d-plan-card-border: rgba(251,191,36,0.2);
    --d-plan-card-text: #c8d4e8;
    --d-profile-bg: rgba(255,255,255,0.07);
    --d-profile-border: rgba(255,255,255,0.07);
    --d-card-bg: rgba(255,255,255,0.06);
    --d-card-border: rgba(255,255,255,0.08);
    --d-card-shimmer: rgba(255,255,255,0.025);
    --d-panel-bg: rgba(255,255,255,0.06);
    --d-panel-border: rgba(255,255,255,0.08);
    --d-panel-shadow: 0 20px 80px rgba(0,0,0,0.28);
    --d-th-color: #6b7fa0;
    --d-td-color: #d1dce8;
    --d-row-border: rgba(255,255,255,0.07);
    --d-product-bg: rgba(255,255,255,0.05);
    --d-product-hover: rgba(255,255,255,0.09);
    --d-product-border: rgba(255,255,255,0.07);
    --d-product-img: linear-gradient(135deg,#1a2235,#2a3a55);
    --d-product-desc: #6b7fa0;
    --d-ghost-bg: rgba(15,23,42,0.6);
    --d-ghost-border: rgba(255,255,255,0.16);
    --d-ghost-text: #c8d4e8;
    --d-query-bg: rgba(255,255,255,0.05);
    --d-query-border: rgba(255,255,255,0.07);
    --d-form-bg: rgba(255,255,255,0.05);
    --d-form-border: rgba(255,255,255,0.07);
    --d-input-bg: rgba(10,16,30,0.88);
    --d-input-border: rgba(255,255,255,0.09);
    --d-input-text: #f0f4ff;
    --d-label-text: #b8c8de;
    --d-empty-text: #6b7fa0;
    --d-divider: rgba(255,255,255,0.07);
    --d-stat-num: #fbbf24;
  }

  body[data-theme="light"] {
    --d-bg: linear-gradient(135deg,#eef2f9 0%,#faf7f0 55%,#f2eefb 100%);
    --d-glow1: rgba(251,191,36,0.2);
    --d-glow2: rgba(128,90,213,0.1);
    --d-text: #111827;
    --d-muted: #6b7280;
    --d-sidebar-bg: rgba(255,255,255,0.88);
    --d-sidebar-border: rgba(0,0,0,0.09);
    --d-brand-sub: #6b7280;
    --d-nav-text: #374151;
    --d-nav-hover: rgba(0,0,0,0.05);
    --d-nav-border: rgba(0,0,0,0.05);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.1),rgba(249,115,22,0.05));
    --d-plan-card-border: rgba(251,191,36,0.3);
    --d-plan-card-text: #374151;
    --d-profile-bg: rgba(0,0,0,0.04);
    --d-profile-border: rgba(0,0,0,0.08);
    --d-card-bg: rgba(255,255,255,0.82);
    --d-card-border: rgba(0,0,0,0.08);
    --d-card-shimmer: rgba(255,255,255,0.7);
    --d-panel-bg: rgba(255,255,255,0.88);
    --d-panel-border: rgba(0,0,0,0.08);
    --d-panel-shadow: 0 8px 40px rgba(0,0,0,0.1);
    --d-th-color: #6b7280;
    --d-td-color: #374151;
    --d-row-border: rgba(0,0,0,0.07);
    --d-product-bg: rgba(255,255,255,0.75);
    --d-product-hover: rgba(255,255,255,0.95);
    --d-product-border: rgba(0,0,0,0.08);
    --d-product-img: linear-gradient(135deg,#dde3f0,#c7d2e8);
    --d-product-desc: #6b7280;
    --d-ghost-bg: rgba(255,255,255,0.7);
    --d-ghost-border: rgba(0,0,0,0.14);
    --d-ghost-text: #374151;
    --d-query-bg: rgba(255,255,255,0.7);
    --d-query-border: rgba(0,0,0,0.07);
    --d-form-bg: rgba(255,255,255,0.75);
    --d-form-border: rgba(0,0,0,0.07);
    --d-input-bg: rgba(255,255,255,0.95);
    --d-input-border: rgba(0,0,0,0.12);
    --d-input-text: #111827;
    --d-label-text: #374151;
    --d-empty-text: #6b7280;
    --d-divider: rgba(0,0,0,0.07);
    --d-stat-num: #d97706;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Inter", sans-serif;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, var(--d-glow1), transparent 35%),
      radial-gradient(circle at top right, var(--d-glow2), transparent 35%),
      var(--d-bg);
    color: var(--d-text);
    transition: background 0.35s, color 0.25s;
  }

  .dashboard {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  .sidebar {
    padding: 28px 22px;
    background: var(--d-sidebar-bg);
    border-right: 1px solid var(--d-sidebar-border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 38px;
  }

  .brand-icon {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #111827;
    font-weight: 900;
    box-shadow: 0 10px 30px rgba(251,191,36,0.28);
  }

  .brand h1 {
    font-size: 20px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .brand p {
    font-size: 12px;
    color: var(--d-brand-sub);
    margin-top: 2px;
  }

  .nav-button {
    width: 100%;
    border: 0;
    color: var(--d-nav-text);
    background: transparent;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    margin-bottom: 8px;
    border-radius: 16px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: 0.25s ease;
    text-align: left;
  }

  .nav-button:hover,
  .nav-button.active {
    color: var(--d-text);
    background: var(--d-nav-hover);
    box-shadow: inset 0 0 0 1px var(--d-nav-border);
  }

  .sidebar-card {
    margin-top: 34px;
    padding: 20px;
    border-radius: 22px;
    background: var(--d-plan-card-bg);
    border: 1px solid var(--d-plan-card-border);
  }

  .sidebar-card h3 {
    font-size: 15px;
    color: var(--d-text);
    margin-bottom: 8px;
  }

  .sidebar-card p {
    color: var(--d-plan-card-text);
    font-size: 13px;
    line-height: 1.6;
  }

  .main {
    padding: 28px;
    overflow: hidden;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 18px;
  }

  .topbar h2 {
    font-size: 32px;
    letter-spacing: -0.06em;
    color: var(--d-text);
  }

  .topbar p {
    color: var(--d-muted);
    margin-top: 6px;
  }

  .profile {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    border-radius: 999px;
    background: var(--d-profile-bg);
    border: 1px solid var(--d-profile-border);
  }

  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fbbf24, #a855f7);
    display: grid;
    place-items: center;
    font-weight: 800;
    color: #fff;
  }

  .profile span {
    display: block;
    font-size: 13px;
    color: var(--d-muted);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }

  .stat-card {
    position: relative;
    border: 1px solid var(--d-card-border);
    background: var(--d-card-bg);
    border-radius: 28px;
    padding: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-card::after {
    content: "";
    position: absolute;
    right: -35px;
    top: -35px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(251,191,36,0.1);
    pointer-events: none;
  }

  .stat-card:hover,
  .stat-card.active {
    transform: translateY(-6px);
    border-color: rgba(251,191,36,0.4);
    box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 0 0 1px rgba(251,191,36,0.1), inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-icon {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    font-size: 24px;
    background: var(--d-nav-hover);
    margin-bottom: 18px;
    border: 1px solid var(--d-card-border);
  }

  .stat-card h3 {
    font-size: 18px;
    margin-bottom: 8px;
    color: var(--d-text);
  }

  .stat-card p {
    color: var(--d-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .stat-number {
    margin-top: 18px;
    font-size: 30px;
    font-weight: 800;
    color: var(--d-stat-num);
  }

  .content-panel {
    border: 1px solid var(--d-panel-border);
    background: var(--d-panel-bg);
    border-radius: 30px;
    padding: 26px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: var(--d-panel-shadow);
    animation: fadeIn 0.35s ease;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 22px;
  }

  .panel-header h3 {
    font-size: 24px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .badge {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(34,197,94,0.11);
    color: #22c55e;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(34,197,94,0.22);
  }

  .filter-box,
  .management-form input,
  .management-form textarea,
  .management-form select,
  .thread-panel input,
  .thread-panel textarea,
  .thread-panel select,
  .status-select {
    width: 100%;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    color: var(--d-input-text);
    padding: 13px 14px;
    border-radius: 16px;
    outline: none;
    font-size: 14px;
    transition: border-color 0.2s, background 0.2s;
  }

  .filter-box {
    margin-bottom: 16px;
  }

  .table-wrap {
    overflow: auto;
    max-height: 60vh;
    padding-right: 4px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
  }

  th, td {
    padding: 16px 14px;
    text-align: left;
    border-bottom: 1px solid var(--d-row-border);
    font-size: 14px;
    vertical-align: middle;
  }

  th {
    color: var(--d-th-color);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--d-panel-bg) 88%, transparent);
    backdrop-filter: blur(12px);
  }

  td {
    color: var(--d-td-color);
  }

  .status {
    display: inline-flex;
    padding: 7px 11px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
  }

  .completed,
  .delivered {
    background: rgba(34,197,94,0.12);
    color: #16a34a;
  }

  .pending {
    background: rgba(251,191,36,0.12);
    color: #d97706;
  }

  .denied,
  .cancelled {
    background: rgba(248,113,113,0.12);
    color: #dc2626;
  }

  .open {
    background: rgba(96,165,250,0.12);
    color: #2563eb;
  }

  .closed {
    background: rgba(148,163,184,0.12);
    color: #6b7280;
  }

  body[data-theme="dark"] .completed,
  body[data-theme="dark"] .delivered { color: #86efac; }
  body[data-theme="dark"] .pending { color: #fde68a; }
  body[data-theme="dark"] .denied,
  body[data-theme="dark"] .cancelled { color: #fca5a5; }
  body[data-theme="dark"] .open { color: #93c5fd; }
  body[data-theme="dark"] .closed { color: #cbd5e1; }

  .product-management-layout,
  .faq-layout,
  .support-layout,
  .notification-layout,
  .contact-admin-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: start;
  }

  .support-layout.maximized {
    grid-template-columns: 1fr;
  }

  .management-form,
  .thread-panel,
  .product-list-panel {
    padding: 20px;
    border-radius: 24px;
    background: var(--d-form-bg);
    border: 1px solid var(--d-form-border);
  }

  .management-form {
    position: sticky;
    top: 20px;
  }

  .management-form label,
  .thread-panel label {
    display: block;
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 700;
    color: var(--d-label-text);
  }

  .management-form textarea,
  .thread-panel textarea {
    min-height: 130px;
    resize: vertical;
  }

  .management-form input:focus,
  .management-form textarea:focus,
  .management-form select:focus,
  .thread-panel input:focus,
  .thread-panel textarea:focus,
  .status-select:focus,
  .filter-box:focus {
    border-color: rgba(251,191,36,0.4);
  }

  .form-grid {
    display: grid;
    gap: 14px;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .toggle-row {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--d-label-text);
    font-size: 14px;
    font-weight: 600;
  }

  .toggle-row input {
    width: auto;
    margin: 0;
  }

  .helper-text {
    margin-top: -4px;
    color: var(--d-muted);
    font-size: 12px;
    line-height: 1.5;
  }

  .description-builder-toolbar {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .description-builder-fields {
    display: grid;
    gap: 8px;
    margin-bottom: 8px;
  }

  .description-builder-row {
    display: grid;
    grid-template-columns: 70px 1fr auto;
    gap: 8px;
    align-items: center;
  }

  .description-builder-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--d-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .description-builder-input {
    width: 100%;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    color: var(--d-input-text);
    padding: 10px 12px;
    border-radius: 10px;
    outline: none;
    font-size: 13px;
    transition: border-color 0.2s ease;
  }

  .description-builder-input:focus {
    border-color: rgba(251,191,36,0.4);
  }

  .description-preview {
    margin-top: 10px;
    padding: 12px;
    border-radius: 14px;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    display: grid;
    gap: 8px;
  }

  .description-preview h5 {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--d-muted);
  }

  .description-preview-summary {
    margin: 0;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid var(--d-form-border);
    background: color-mix(in srgb, var(--d-form-bg) 86%, transparent);
    color: var(--d-text);
    line-height: 1.5;
    font-size: 13px;
  }

  .description-preview-features {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .description-preview-feature {
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid var(--d-nav-border);
    background: color-mix(in srgb, var(--d-nav-hover) 80%, transparent);
    color: var(--d-text);
    font-size: 12px;
    font-weight: 600;
  }

  .description-preview-notes {
    display: grid;
    gap: 6px;
  }

  .description-preview-note {
    margin: 0;
    padding: 8px 10px;
    border-left: 3px solid rgba(251,191,36,0.55);
    border-radius: 10px;
    color: var(--d-label-text);
    background: color-mix(in srgb, var(--d-form-bg) 86%, transparent);
    font-style: italic;
    line-height: 1.45;
    font-size: 13px;
  }

  .description-preview-empty {
    margin: 0;
    color: var(--d-muted);
    font-size: 13px;
    line-height: 1.45;
  }

  .submit-btn,
  .buy-btn {
    border: 0;
    padding: 10px 14px;
    border-radius: 14px;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #111827;
    font-weight: 800;
    cursor: pointer;
    transition: 0.2s ease;
    box-shadow: 0 4px 16px rgba(251,191,36,0.28);
  }

  .submit-btn:hover,
  .buy-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 22px rgba(251,191,36,0.38);
  }

  .submit-btn:disabled,
  .ghost-btn:disabled,
  .buy-btn:disabled {
    cursor: not-allowed;
    opacity: 0.7;
    transform: none;
  }

  .ghost-btn {
    border: 1px solid var(--d-ghost-border);
    padding: 9px 13px;
    border-radius: 12px;
    background: var(--d-ghost-bg);
    color: var(--d-ghost-text);
    font-weight: 700;
    cursor: pointer;
    font-size: 13px;
    transition: background 0.2s, border-color 0.2s;
  }

  .ghost-btn:hover {
    border-color: rgba(251,191,36,0.35);
    color: #f59e0b;
  }

  .button-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .upload-box {
    padding: 14px;
    border-radius: 18px;
    border: 1px dashed var(--d-input-border);
    background: var(--d-input-bg);
    display: grid;
    gap: 10px;
  }

  .upload-box small {
    color: var(--d-muted);
  }

  .product-list-panel {
    display: grid;
    gap: 12px;
    max-height: 600px;
    overflow-y: auto;
    padding-right: 6px;
    transition: all 0.25s ease;
  }

  .product-management-layout.products-maximized {
    grid-template-columns: 1fr;
    gap: 0;
  }

  .product-management-layout.products-maximized .management-form {
    display: none;
  }

  .product-management-layout.products-maximized .product-list-panel {
    width: 100%;
    max-height: 80vh;
  }

  .product-list-panel.maximized {
    max-height: 76vh;
    gap: 18px;
  }

  .product-list-header {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .product-list-header .filter-box {
    flex: 1;
  }

  .product-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-content: start;
  }

  .product-list-panel.maximized .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    align-content: start;
    flex-direction: row;
  }

  .product-card {
    display: grid;
    grid-template-columns: 70px 1fr 70px 80px 120px;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border-radius: 12px;
    border: 1px solid var(--d-product-border);
    background: var(--d-product-bg);
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    box-shadow: inset 0 1px 0 var(--d-card-shimmer);
    cursor: pointer;
  }

  .product-list-panel.maximized .product-card {
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
    gap: 12px;
    padding: 18px;
    border-radius: 24px;
    border-color: var(--d-product-border);
  }

  .product-list-panel.maximized .product-img {
    height: 150px;
    width: 100%;
    border-radius: 18px;
    margin-bottom: 4px;
    font-size: 42px;
  }

  .product-list-panel.maximized .product-info {
    gap: 6px;
  }

  .product-list-panel.maximized .product-card h4 {
    font-size: 16px;
    margin-bottom: 6px;
    white-space: normal;
  }

  .product-list-panel.maximized .product-card p {
    font-size: 13px;
    line-height: 1.5;
    display: block;
    -webkit-line-clamp: unset;
    -webkit-box-orient: unset;
    overflow: visible;
    text-overflow: unset;
  }


  .product-list-panel.maximized .product-price {
    justify-content: flex-start;
  }

  .product-list-panel.maximized .price {
    font-size: 18px;
  }

  .product-list-panel.maximized .product-tags {
    flex-direction: row;
    gap: 8px;
  }

  .product-list-panel.maximized .product-actions {
    justify-content: flex-start;
  }

  .product-list-panel.maximized .tag {
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
  }

  .product-card:hover,
  .product-card.active {
    transform: translateY(-2px);
    background: var(--d-product-hover);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12), inset 0 1px 0 var(--d-card-shimmer);
    border-color: rgba(251,191,36,0.35);
  }

  .product-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .product-img {
    height: 70px;
    width: 70px;
    border-radius: 8px;
    background: var(--d-product-img);
    display: grid;
    place-items: center;
    font-size: 24px;
    margin-bottom: 0;
    overflow: hidden;
    flex-shrink: 0;
  }

  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card h4 {
    display: block;
    margin: 0;
    font-size: 11px;
    color: var(--d-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 600;
  }

  .product-card p {
    color: var(--d-product-desc);
    font-size: 11px;
    line-height: 1.3;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .product-price {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-tags {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex-wrap: wrap;
  }

  .product-actions {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: stretch;
  }

  .product-action-btn {
    border: 1px solid var(--d-ghost-border);
    background: var(--d-ghost-bg);
    color: var(--d-ghost-text);
    border-radius: 10px;
    padding: 7px 10px;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    transition: 0.2s ease;
  }

  .product-action-btn:hover {
    border-color: rgba(251,191,36,0.35);
    color: #f59e0b;
  }

  .product-action-btn:disabled {
    cursor: not-allowed;
    opacity: 0.65;
  }

  .product-action-btn.force {
    border-color: rgba(248,113,113,0.35);
    color: #dc2626;
    background: rgba(248,113,113,0.08);
  }

  body[data-theme="dark"] .product-action-btn.force {
    color: #fca5a5;
  }

  .product-meta {
    display: none;
  }

  .query-meta,
  .thread-meta,
  .order-actions,
  .customer-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag-row {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 2px 4px;
    border-radius: 4px;
    font-size: 8px;
    font-weight: 700;
    background: var(--d-nav-hover);
    border: 1px solid var(--d-nav-border);
    color: var(--d-nav-text);
    white-space: nowrap;
  }

  .price {
    color: #f59e0b;
    font-size: 11px;
    font-weight: 800;
  }

  .query-list {
    display: grid;
    gap: 14px;
    align-content: start;
    max-height: 74vh;
    overflow-y: auto;
    padding-right: 6px;
  }

  .query-card {
    padding: 18px;
    border-radius: 20px;
    background: var(--d-query-bg);
    border: 1px solid var(--d-query-border);
    transition: background 0.3s, border-color 0.3s, transform 0.2s ease;
  }

  .query-card.active {
    border-color: rgba(251,191,36,0.35);
    transform: translateY(-2px);
  }

  .query-card h4 {
    margin-bottom: 8px;
    color: var(--d-text);
  }

  .query-card p {
    color: var(--d-muted);
    font-size: 14px;
    line-height: 1.55;
    margin-bottom: 12px;
  }

  .thread-stack {
    display: grid;
    gap: 10px;
    max-height: 46vh;
    overflow-y: auto;
    padding-right: 4px;
    margin-bottom: 14px;
  }

  .chat-bubble {
    max-width: 84%;
    padding: 10px 12px;
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.5;
  }

  .chat-bubble.user {
    justify-self: start;
    background: rgba(251,191,36,0.18);
    border: 1px solid rgba(251,191,36,0.3);
    color: #d97706;
  }

  body[data-theme="dark"] .chat-bubble.user {
    color: #fde68a;
  }

  .chat-bubble.admin {
    justify-self: end;
    background: rgba(96,165,250,0.12);
    border: 1px solid rgba(96,165,250,0.22);
    color: #2563eb;
  }

  body[data-theme="dark"] .chat-bubble.admin {
    color: #bfdbfe;
    background: rgba(96,165,250,0.15);
  }

  .chat-meta {
    display: block;
    margin-top: 6px;
    font-size: 11px;
    opacity: 0.75;
  }

  .section-intro,
  .empty-note,
  .summary-caption {
    color: var(--d-empty-text);
    line-height: 1.7;
  }

  .summary-caption {
    margin-bottom: 16px;
  }

  .customer-cell {
    display: grid;
    gap: 3px;
  }

  .customer-cell small {
    color: var(--d-muted);
  }

  .lead-list {
    display: grid;
    gap: 14px;
    max-height: 74vh;
    overflow-y: auto;
    padding-right: 6px;
    align-content: start;
  }

  .lead-card {
    width: 100%;
    border: 1px solid var(--d-query-border);
    background: var(--d-query-bg);
    color: inherit;
    padding: 18px;
    border-radius: 20px;
    cursor: pointer;
    text-align: left;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }

  .lead-card:hover,
  .lead-card.active {
    border-color: rgba(251,191,36,0.35);
    transform: translateY(-2px);
  }

  .lead-card-header {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: flex-start;
    margin-bottom: 10px;
  }

  .lead-card h4 {
    margin: 0;
    color: var(--d-text);
    font-size: 16px;
  }

  .lead-card p {
    margin: 4px 0 0;
    color: var(--d-muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .lead-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .lead-meta-chip,
  .lead-detail-card {
    padding: 8px 10px;
    border-radius: 14px;
    border: 1px solid var(--d-form-border);
    background: color-mix(in srgb, var(--d-form-bg) 84%, transparent);
    color: var(--d-label-text);
    font-size: 12px;
    line-height: 1.45;
  }

  .lead-detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .lead-detail-card strong {
    display: block;
    color: var(--d-text);
    font-size: 13px;
    margin-bottom: 4px;
  }

  .faq-list {
    display: grid;
    gap: 14px;
    max-height: 74vh;
    overflow-y: auto;
    padding-right: 6px;
    align-content: start;
  }

  .faq-card {
    border: 1px solid var(--d-query-border);
    background: var(--d-query-bg);
    color: inherit;
    padding: 18px;
    border-radius: 20px;
    display: grid;
    gap: 12px;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }

  .faq-card.active,
  .faq-card:hover {
    border-color: rgba(251,191,36,0.35);
    transform: translateY(-2px);
  }

  .faq-card-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
  }

  .faq-card h4 {
    margin: 0;
    color: var(--d-text);
    font-size: 16px;
    line-height: 1.45;
  }

  .faq-card-answer {
    margin: 0;
    color: var(--d-muted);
    font-size: 13px;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .faq-card-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .faq-chip {
    display: inline-flex;
    align-items: center;
    padding: 8px 10px;
    border-radius: 999px;
    border: 1px solid var(--d-form-border);
    background: color-mix(in srgb, var(--d-form-bg) 84%, transparent);
    color: var(--d-label-text);
    font-size: 12px;
    font-weight: 600;
  }

  .faq-empty-panel {
    padding: 18px;
    border-radius: 18px;
    border: 1px dashed var(--d-form-border);
    background: color-mix(in srgb, var(--d-form-bg) 82%, transparent);
  }

  .notification-recipient {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid var(--d-form-border);
    background: color-mix(in srgb, var(--d-form-bg) 88%, transparent);
  }

  .notification-recipient strong {
    color: var(--d-text);
    font-size: 16px;
  }

  .notification-recipient span {
    color: var(--d-muted);
    font-size: 13px;
  }

  .contact-message-preview {
    display: grid;
    gap: 10px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid var(--d-form-border);
    background: color-mix(in srgb, var(--d-form-bg) 88%, transparent);
  }

  .contact-message-preview strong {
    color: var(--d-text);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .contact-message-preview p {
    margin: 0;
    color: var(--d-td-color);
    font-size: 14px;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .toast-container {
    position: fixed;
    right: 28px;
    bottom: 28px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .toast {
    padding: 14px 18px;
    border-radius: 14px;
    color: #fff;
    max-width: 320px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.35);
    animation: toastIn 0.25s ease;
  }

  .toast.success {
    background: linear-gradient(135deg, #166534 0%, #15803d 100%);
    border: 1px solid rgba(134,239,172,0.25);
  }

  .toast.error {
    background: linear-gradient(135deg, #7f1d1d 0%, #b91c1c 100%);
    border: 1px solid rgba(252,165,165,0.25);
  }

  .loading-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    color: var(--d-text);
    font-size: 18px;
    letter-spacing: -0.02em;
  }

  @@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @@keyframes toastIn {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @@media (max-width: 1200px) {
    .cards,
    .product-grid,
    .product-management-layout,
    .faq-layout,
    .support-layout,
    .notification-layout,
    .lead-detail-grid {
      grid-template-columns: 1fr;
    }

    .product-list-panel.maximized .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .management-form {
      position: static;
    }
  }

  @@media (max-width: 820px) {
    .dashboard {
      grid-template-columns: 1fr;
    }

    .topbar {
      align-items: flex-start;
      flex-direction: column;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .product-list-panel.maximized .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

@if (canRenderDashboard)
{
<div class="dashboard">
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-icon">K</div>
      <div>
        <h1>Kohinoorea</h1>
        <p>Premium Admin Panel</p>
      </div>
    </div>

    <button class="nav-button @(activeSection == AdminSection.Products ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Products)">Products</button>
    <button class="nav-button @(activeSection == AdminSection.Orders ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Orders)">Orders</button>
    <button class="nav-button @(activeSection == AdminSection.Customers ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Customers)">Customers</button>
    <button class="nav-button @(activeSection == AdminSection.Faq ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Faq)">FAQ</button>
    <button class="nav-button @(activeSection == AdminSection.Notifications ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Notifications)">Notifications</button>
    <button class="nav-button @(activeSection == AdminSection.Contact ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Contact)">Contact</button>
    <button class="nav-button @(activeSection == AdminSection.Support ? "active" : null)" type="button" @onclick="() => NavigateToSection(AdminSection.Support)">Support</button>

    <div class="sidebar-card">
      <h3>@SidebarTitle</h3>
      <p>@SidebarMessage</p>
    </div>
  </aside>

  <main class="main">
    <header class="topbar" id="overview">
      <div>
        <h2>@PageTitle</h2>
        <p>Jump directly to Products, Orders, Customers, FAQ, Notifications, Contact, or Support and work each section inside its own scrollable control panel.</p>
      </div>
      <div class="profile">
        <div class="avatar">@AvatarInitial</div>
        <div>
          <strong>Administrator</strong>
          <span>@ProfileEmail</span>
        </div>
      </div>
    </header>

    <section class="cards">
      <div class="stat-card @(activeSection == AdminSection.Products ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Products)">
        <div class="stat-icon">P</div>
        <h3>Products</h3>
        <p>Create plans, click any product to edit it, and keep the catalog scrollable on the right.</p>
        <div class="stat-number">@productCount</div>
      </div>

      <div class="stat-card @(activeSection == AdminSection.Orders ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Orders)">
        <div class="stat-icon">O</div>
        <h3>Orders</h3>
        <p>Filter orders, scroll the table, and update statuses without losing position.</p>
        <div class="stat-number">@orderCount</div>
      </div>

      <div class="stat-card @(activeSection == AdminSection.Customers ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Customers)">
        <div class="stat-icon">C</div>
        <h3>Customers</h3>
        <p>Load the users table and inspect account activity in one place.</p>
        <div class="stat-number">@customerCount</div>
      </div>

      <div class="stat-card @(activeSection == AdminSection.Faq ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Faq)">
        <div class="stat-icon">F</div>
        <h3>FAQ</h3>
        <p>Publish premium question-and-answer content for the public FAQ page.</p>
        <div class="stat-number">@faqCount</div>
      </div>

      <div class="stat-card @(activeSection == AdminSection.Notifications ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Notifications)">
        <div class="stat-icon">N</div>
        <h3>Notifications</h3>
        <p>Follow up with signed-up users who still have no completed purchase.</p>
        <div class="stat-number">@followUpLeads.Count</div>
      </div>

      <div class="stat-card @(activeSection == AdminSection.Contact ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Contact)">
        <div class="stat-icon">M</div>
        <h3>Contact</h3>
        <p>Review inbound contact requests and reply directly from the admin inbox.</p>
        <div class="stat-number">@contactCount</div>
      </div>

      <div class="stat-card @(activeSection == AdminSection.Support ? "active" : null)" @onclick="() => NavigateToSection(AdminSection.Support)">
        <div class="stat-icon">S</div>
        <h3>Support</h3>
        <p>Stay on top of open queries and respond from a focused thread view.</p>
        <div class="stat-number">@supportTrace.Count</div>
      </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
      <p class="summary-caption">@statusMessage</p>
    }

    <section id="@CurrentSectionAnchor" class="content-panel">
      @if (activeSection == AdminSection.Products)
      {
        <div class="panel-header">
          <div>
            <h3>Product Management</h3>
            <p class="section-intro">Click any product card to load it into the form, edit it, and update it without leaving this section.</p>
          </div>
          <span class="badge">Admin Posted Products</span>
        </div>

        <div class="product-management-layout @(isProductsMaximized ? "products-maximized" : null)">
          <EditForm class="management-form form-grid" Model="createProduct" OnValidSubmit="SaveProductAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div>
              <label>Product Name</label>
              <InputText @bind-Value="createProduct.Name" placeholder="Premium Annual Plan" />
            </div>

            <div>
              <label>Description</label>
              <div class="description-builder-toolbar">
                <button class="ghost-btn" type="button" @onclick="AddDescriptionSummaryField">Add p</button>
                <button class="ghost-btn" type="button" @onclick="AddDescriptionFeatureField">Add span</button>
                <button class="submit-btn" type="button" @onclick="BuildDescriptionFromFields">Insert Description</button>
                <button class="ghost-btn" type="button" @onclick="ClearDescriptionFields">Clear Fields</button>
              </div>
              <div class="description-builder-fields">
                @for (var i = 0; i < descriptionSummaryInputs.Count; i++)
                {
                  var summaryIndex = i;
                  <div class="description-builder-row">
                    <span class="description-builder-label">p @(@summaryIndex + 1)</span>
                    <input class="description-builder-input" value="@descriptionSummaryInputs[summaryIndex]" @oninput="e => UpdateDescriptionSummaryField(summaryIndex, e.Value?.ToString())" placeholder="Summary paragraph text..." />
                    <button class="ghost-btn" type="button" @onclick="() => RemoveDescriptionSummaryField(summaryIndex)">Remove</button>
                  </div>
                }

                @for (var i = 0; i < descriptionFeatureInputs.Count; i++)
                {
                  var featureIndex = i;
                  <div class="description-builder-row">
                    <span class="description-builder-label">span @(@featureIndex + 1)</span>
                    <input class="description-builder-input" value="@descriptionFeatureInputs[featureIndex]" @oninput="e => UpdateDescriptionFeatureField(featureIndex, e.Value?.ToString())" placeholder="Feature bullet text..." />
                    <button class="ghost-btn" type="button" @onclick="() => RemoveDescriptionFeatureField(featureIndex)">Remove</button>
                  </div>
                }
              </div>

              <InputTextArea @bind-Value="createProduct.Description" placeholder="Generated description will appear here after Insert Description." />
              <p class="helper-text">Use Add p/Add span to create fields, then click Insert Description to build one HTML description string.</p>
              <div class="description-preview">
                <h5>Beautified Preview</h5>
                <p class="description-preview-summary">@adminCurrency.ReplacePricesInTextFromUsd(GetDescriptionSummary(createProduct.Description))</p>
                @if (GetDescriptionTagValues(createProduct.Description, "span").Count > 0)
                {
                  <div class="description-preview-features">
                    @foreach (var feature in GetDescriptionTagValues(createProduct.Description, "span"))
                    {
                      <span class="description-preview-feature">@adminCurrency.ReplacePricesInTextFromUsd(feature)</span>
                    }
                  </div>
                }
                @if (GetDescriptionTagValues(createProduct.Description, "i").Count > 0)
                {
                  <div class="description-preview-notes">
                    @foreach (var note in GetDescriptionTagValues(createProduct.Description, "i"))
                    {
                      <p class="description-preview-note">@adminCurrency.ReplacePricesInTextFromUsd(note)</p>
                    }
                  </div>
                }
                @if (string.IsNullOrWhiteSpace(createProduct.Description))
                {
                  <p class="description-preview-empty">Add p, span, and i tags above to see formatted content.</p>
                }
              </div>
            </div>

            <div class="upload-box">
              <label>Product Image</label>
              <InputFile OnChange="HandleProductImageSelectedAsync" accept=".jpg,.jpeg,.png,.webp,.gif" />
              <small>@(isUploadingImage ? "Uploading image..." : string.IsNullOrWhiteSpace(selectedImageName) ? "Upload a cover image or paste a direct URL below." : $"Selected: {selectedImageName}")</small>
            </div>

            <div>
              <label>Image URL</label>
              <InputText @bind-Value="createProduct.ImageLink" placeholder="/uploads/products/... or https://..." />
            </div>

            <div class="form-row">
              <div>
                <label>Price</label>
                <InputNumber @bind-Value="createProduct.Price" placeholder="2999" />
              </div>
              <div>
                <label>Country Code</label>
                <InputText @bind-Value="createProduct.CountryCode" placeholder="IN, US, GB or leave empty" />
              </div>
            </div>

            <div class="form-row">
              <label class="toggle-row">
                <InputCheckbox @bind-Value="createProduct.IsActive" /> Active listing
              </label>
              <label class="toggle-row">
                <InputCheckbox @bind-Value="createProduct.IsMaster" /> Master pricing plan
              </label>
            </div>

            <div class="button-row">
              <button class="submit-btn" type="submit">@(editingProductId.HasValue ? "Update Product" : "Create Product")</button>
              @if (editingProductId.HasValue)
              {
                <button class="ghost-btn" type="button" @onclick="ResetProductForm">Cancel Edit</button>
              }
            </div>
          </EditForm>

          <div class="product-list-panel @(isProductsMaximized ? "maximized" : null)">
            <div class="product-list-header">
              <input class="filter-box" @bind="productFilter" @bind:event="oninput" placeholder="Filter products by name, country, status, or description..." />
              <button class="ghost-btn" type="button" @onclick="ToggleProductsMaximize">@(isProductsMaximized ? "Normal" : "Maximize")</button>
            </div>
            <div class="product-grid">
              @if (FilteredProducts.Count == 0)
              {
                <p class="empty-note">No products match this filter.</p>
              }
              else
              {
                @foreach (var product in FilteredProducts)
                {
                  <div class="product-card @(editingProductId == product.Id ? "active" : null)" @onclick="() => StartEditingProduct(product)">
                    <div class="product-img">
                      <img src="@GetProductImageUrl(product)" alt="@product.Name" loading="lazy" />
                    </div>
                    <div class="product-info">
                      <h4>@product.Name</h4>
                      @if (isProductsMaximized)
                      {
                        <p>@GetProductFullDescription(product)</p>
                      }
                      else
                      {
                        <p>@GetProductSummary(product)</p>
                      }
                    </div>
                    <div class="product-price">
                      <span class="price">@adminCurrency.FormatFromUsd(product.Price)</span>
                    </div>
                    <div class="product-tags">
                      <span class="tag">@(product.IsActive ? "Active" : "Hidden")</span>
                      @if (product.IsMaster)
                      {
                        <span class="tag">Master</span>
                      }
                      @if (!string.IsNullOrWhiteSpace(product.CountryCode))
                      {
                        <span class="tag">@product.CountryCode!.ToUpperInvariant()</span>
                      }
                    </div>
                    <div class="product-actions" @onclick:stopPropagation="true">
                      <button class="product-action-btn" type="button" @onclick="() => ToggleProductActiveAsync(product)">@(product.IsActive ? "Soft Delete" : "Restore")</button>
                      <button class="product-action-btn force" type="button" @onclick="() => ForceDeleteProductAsync(product)">Force Delete</button>
                    </div>
                  </div>
                }
              }
            </div>
          </div>
        </div>
      }
      else if (activeSection == AdminSection.Orders)
      {
        <div class="panel-header">
          <div>
            <h3>Order Trace</h3>
            <p class="section-intro">Filter orders instantly and keep the table scrollable while saving status changes.</p>
          </div>
          <span class="badge">Live Admin Control</span>
        </div>

        <input class="filter-box" @bind="orderFilter" @bind:event="oninput" placeholder="Filter orders by id, product, user, email, or status..." />

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Order</th>
                <th>Product</th>
                <th>User</th>
                <th>Email</th>
                <th>Qty</th>
                <th>Total</th>
                <th>Ordered</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              @if (FilteredOrders.Count == 0)
              {
                <tr>
                  <td colspan="8">No orders match this filter.</td>
                </tr>
              }
              else
              {
                @foreach (var row in FilteredOrders)
                {
                  <tr>
                    <td><strong>ORD-@row.OrderId</strong></td>
                    <td>@row.ProductName</td>
                    <td>@row.UserFullName</td>
                    <td>@row.UserEmail</td>
                    <td>@row.Quantity</td>
                    <td>@adminCurrency.FormatFromUsd(row.TotalAmount)</td>
                    <td>@row.OrderedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</td>
                    <td>
                      <div class="order-actions">
                        <span class="status @GetStatusCss(row.Status)">@NormalizeOrderStatus(row.Status)</span>
                        <select class="status-select" value="@GetPendingOrderStatus(row)" @onchange="e => HandlePendingOrderStatusChange(row.OrderId, e.Value?.ToString())">
                          <option value="Pending">Pending</option>
                          <option value="Completed">Completed</option>
                          <option value="Denied">Denied</option>
                        </select>
                        <button class="ghost-btn" type="button" disabled="@(!IsOrderStatusDirty(row) || savingOrderIds.Contains(row.OrderId))" @onclick="() => SaveOrderStatusAsync(row)">
                          @(savingOrderIds.Contains(row.OrderId) ? "Saving..." : "Save")
                        </button>
                      </div>
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      }
      else if (activeSection == AdminSection.Customers)
      {
        <div class="panel-header">
          <div>
            <h3>Customers</h3>
            <p class="section-intro">This section loads the users table directly from the admin auth endpoint.</p>
          </div>
          <span class="badge">User Accounts</span>
        </div>

        <input class="filter-box" @bind="customerFilter" @bind:event="oninput" placeholder="Filter customers by name, email, phone, role, or status..." />

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Contact</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created</th>
                <th>Last Login</th>
              </tr>
            </thead>
            <tbody>
              @if (FilteredCustomers.Count == 0)
              {
                <tr>
                  <td colspan="6">No customers match this filter.</td>
                </tr>
              }
              else
              {
                @foreach (var customer in FilteredCustomers)
                {
                  <tr>
                    <td>
                      <div class="customer-cell">
                        <strong>@customer.FullName</strong>
                        <small>ID @customer.Id</small>
                      </div>
                    </td>
                    <td>
                      <div class="customer-cell">
                        <span>@customer.Email</span>
                        <small>@(string.IsNullOrWhiteSpace(customer.Phone) ? "No phone" : customer.Phone)</small>
                      </div>
                    </td>
                    <td>@customer.Role</td>
                    <td>
                      <div class="order-actions">
                        <span class="status @(customer.IsActive ? "open" : "closed")">@(customer.IsActive ? "Active" : "Inactive")</span>
                        <button class="ghost-btn" type="button" disabled="@savingCustomerIds.Contains(customer.Id)" @onclick="() => ToggleCustomerActiveAsync(customer)">
                          @(savingCustomerIds.Contains(customer.Id) ? "Saving..." : customer.IsActive ? "Deactivate" : "Activate")
                        </button>
                      </div>
                    </td>
                    <td>@customer.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>@(customer.LastLoginAtUtc.HasValue ? customer.LastLoginAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "Never")</td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      }
      else if (activeSection == AdminSection.Faq)
      {
        <div class="panel-header">
          <div>
            <h3>FAQ Management</h3>
            <p class="section-intro">Create premium FAQ entries, control their order, and decide which ones appear on the public FAQ page.</p>
          </div>
          <span class="badge">Public Content</span>
        </div>

        <div class="faq-layout">
          <div class="thread-panel">
            <input class="filter-box" @bind="faqFilter" @bind:event="oninput" placeholder="Filter FAQs by question, answer, order, or status..." />

            <div class="faq-list">
              @if (FilteredFaqs.Count == 0)
              {
                <div class="faq-empty-panel">
                  <p class="empty-note">No FAQs match this filter yet.</p>
                </div>
              }
              else
              {
                @foreach (var faq in FilteredFaqs)
                {
                  <div class="faq-card @(editingFaqId == faq.Id ? "active" : null)">
                    <div class="faq-card-header">
                      <h4>@faq.Question</h4>
                      <span class="status @(faq.IsActive ? "open" : "closed")">@(faq.IsActive ? "Visible" : "Hidden")</span>
                    </div>

                    <p class="faq-card-answer">@faq.Answer</p>

                    <div class="faq-card-meta">
                      <span class="faq-chip">Order @faq.DisplayOrder</span>
                      <span class="faq-chip">Created @faq.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                    </div>

                    <div class="button-row">
                      <button class="ghost-btn" type="button" @onclick="() => StartEditingFaq(faq)">Edit</button>
                      <button class="ghost-btn" type="button" @onclick="() => ToggleFaqActiveAsync(faq)">
                        @(faq.IsActive ? "Hide" : "Show")
                      </button>
                    </div>
                  </div>
                }
              }
            </div>
          </div>

          <EditForm class="management-form form-grid" Model="faqRequest" OnValidSubmit="SaveFaqAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div>
              <label>Question</label>
              <InputText @bind-Value="faqRequest.Question" placeholder="What is Kohinoor EA?" />
            </div>

            <div>
              <label>Answer</label>
              <InputTextArea @bind-Value="faqRequest.Answer" placeholder="Write the full FAQ answer here..." />
            </div>

            <div class="form-row">
              <div>
                <label>Display Order</label>
                <InputNumber @bind-Value="faqRequest.DisplayOrder" />
              </div>
              <label class="toggle-row">
                <InputCheckbox @bind-Value="faqRequest.IsActive" /> Show on public FAQ page
              </label>
            </div>

            <p class="helper-text">Lower display order appears first on the public FAQ page. Hidden FAQs stay in admin only.</p>

            <div class="button-row">
              <button class="submit-btn" type="submit" disabled="@isSavingFaq">@(isSavingFaq ? "Saving..." : editingFaqId.HasValue ? "Update FAQ" : "Add FAQ")</button>
              @if (editingFaqId.HasValue)
              {
                <button class="ghost-btn" type="button" @onclick="ResetFaqForm">Cancel Edit</button>
              }
            </div>
          </EditForm>
        </div>
      }
      else if (activeSection == AdminSection.Notifications)
      {
        <div class="panel-header">
          <div>
            <h3>Follow-up Notifications</h3>
            <p class="section-intro">Select a signed-up user who still has no completed purchase, then send a follow-up email from the admin dashboard.</p>
          </div>
          <span class="badge">Lead Follow-up</span>
        </div>

        <div class="notification-layout">
          <div>
            <input class="filter-box" @bind="followUpLeadFilter" @bind:event="oninput" placeholder="Filter leads by name, email, phone, plan, broker, or order status..." />

            <div class="lead-list">
              @if (FilteredFollowUpLeads.Count == 0)
              {
                <p class="empty-note">No follow-up users are waiting right now.</p>
              }
              else
              {
                @foreach (var lead in FilteredFollowUpLeads)
                {
                  <button class="lead-card @(selectedFollowUpLeadUserId == lead.UserId ? "active" : null)" type="button" @onclick="() => SelectFollowUpLead(lead)">
                    <div class="lead-card-header">
                      <div>
                        <h4>@lead.FullName</h4>
                        <p>@lead.Email</p>
                      </div>
                      <span class="status pending">No purchase</span>
                    </div>

                    <div class="lead-meta-row">
                      <span class="lead-meta-chip">@GetLeadPlanLabel(lead.RequestedPlan)</span>
                      <span class="lead-meta-chip">@GetLeadOrderSummary(lead)</span>
                      <span class="lead-meta-chip">Joined @lead.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                    </div>
                  </button>
                }
              }
            </div>
          </div>

          <EditForm class="thread-panel form-grid" Model="followUpEmailRequest" OnValidSubmit="SendFollowUpNotificationAsync">
            <DataAnnotationsValidator />

            @if (SelectedFollowUpLead is null)
            {
              <p class="empty-note">Select a user from the left to prepare a notification email.</p>
            }
            else
            {
              <div class="notification-recipient">
                <strong>@SelectedFollowUpLead.FullName</strong>
                <span>@SelectedFollowUpLead.Email</span>
                <span>@GetLeadPlanLabel(SelectedFollowUpLead.RequestedPlan) | @GetLeadOrderSummary(SelectedFollowUpLead)</span>
              </div>

              <div class="lead-detail-grid">
                <div class="lead-detail-card">
                  <strong>Phone</strong>
                  <span>@(string.IsNullOrWhiteSpace(SelectedFollowUpLead.Phone) ? "Not provided" : SelectedFollowUpLead.Phone)</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Broker</strong>
                  <span>@(string.IsNullOrWhiteSpace(SelectedFollowUpLead.Mt4Broker) ? "Not provided" : SelectedFollowUpLead.Mt4Broker)</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Last Login</strong>
                  <span>@(SelectedFollowUpLead.LastLoginAtUtc.HasValue ? SelectedFollowUpLead.LastLoginAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "Never")</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Last Order</strong>
                  <span>@GetLeadLastOrderText(SelectedFollowUpLead)</span>
                </div>
              </div>

              <div>
                <label>Email Subject</label>
                <InputText @bind-Value="followUpEmailRequest.Subject" placeholder="Kohinoor EA follow-up" />
                <ValidationMessage For="@(() => followUpEmailRequest.Subject)" />
              </div>

              <div>
                <label>Email Message</label>
                <InputTextArea @bind-Value="followUpEmailRequest.Message" placeholder="Write your follow-up message here..." />
                <ValidationMessage For="@(() => followUpEmailRequest.Message)" />
              </div>

              <p class="helper-text">This email is sent to the selected user's registered account email using the SMTP settings configured on the server.</p>

              <div class="button-row">
                <button class="submit-btn" type="submit" disabled="@(!CanSendFollowUpEmail)">@(isSendingFollowUpEmail ? "Sending..." : "Send Notification Email")</button>
                <button class="ghost-btn" type="button" disabled="@(SelectedFollowUpLead is null)" @onclick="ResetFollowUpDraft">Reset Draft</button>
              </div>
            }
          </EditForm>
        </div>
      }
      else if (activeSection == AdminSection.Contact)
      {
        <div class="panel-header">
          <div>
            <h3>Contact Inbox</h3>
            <p class="section-intro">Review contact requests from the public page, select any message, and reply to the sender by email from the dashboard.</p>
          </div>
          <span class="badge">Contact Replies</span>
        </div>

        <div class="contact-admin-layout">
          <div>
            <input class="filter-box" @bind="contactFilter" @bind:event="oninput" placeholder="Filter contact messages by name, email, subject, message, or reply status..." />

            <div class="lead-list">
              @if (FilteredContactMessages.Count == 0)
              {
                <p class="empty-note">No contact requests have arrived yet.</p>
              }
              else
              {
                @foreach (var contactMessage in FilteredContactMessages)
                {
                  <button class="lead-card @(selectedContactMessageId == contactMessage.Id ? "active" : null)" type="button" @onclick="() => SelectContactMessage(contactMessage)">
                    <div class="lead-card-header">
                      <div>
                        <h4>@contactMessage.Name</h4>
                        <p>@contactMessage.Email</p>
                      </div>
                      <span class="status @(contactMessage.IsReplied ? "completed" : "pending")">@(contactMessage.IsReplied ? "Replied" : "Awaiting reply")</span>
                    </div>

                    <p>@contactMessage.Subject</p>
                    <div class="lead-meta-row">
                      <span class="lead-meta-chip">Received @contactMessage.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                      @if (contactMessage.LastRepliedAtUtc.HasValue)
                      {
                        <span class="lead-meta-chip">Last replied @contactMessage.LastRepliedAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                      }
                    </div>
                  </button>
                }
              }
            </div>
          </div>

          <EditForm class="thread-panel form-grid" Model="contactReplyRequest" OnValidSubmit="SendContactReplyAsync">
            <DataAnnotationsValidator />

            @if (SelectedContactMessage is null)
            {
              <p class="empty-note">Select a contact message from the left to review it and send an email reply.</p>
            }
            else
            {
              <div class="notification-recipient">
                <strong>@SelectedContactMessage.Name</strong>
                <span>@SelectedContactMessage.Email</span>
                <span>@(SelectedContactMessage.IsReplied ? "This contact already has a reply history." : "Waiting for the first admin reply.")</span>
              </div>

              <div class="lead-detail-grid">
                <div class="lead-detail-card">
                  <strong>Subject</strong>
                  <span>@SelectedContactMessage.Subject</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Received</strong>
                  <span>@SelectedContactMessage.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Status</strong>
                  <span>@(SelectedContactMessage.IsReplied ? "Replied" : "Awaiting reply")</span>
                </div>
                <div class="lead-detail-card">
                  <strong>Last Reply</strong>
                  <span>@(SelectedContactMessage.LastRepliedAtUtc.HasValue ? SelectedContactMessage.LastRepliedAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "No reply sent yet")</span>
                </div>
              </div>

              <div class="contact-message-preview">
                <strong>Original Message</strong>
                <p>@SelectedContactMessage.Message</p>
              </div>

              <div>
                <label>Email Subject</label>
                <InputText @bind-Value="contactReplyRequest.Subject" placeholder="Re: Your Kohinoor EA inquiry" />
                <ValidationMessage For="@(() => contactReplyRequest.Subject)" />
              </div>

              <div>
                <label>Email Message</label>
                <InputTextArea @bind-Value="contactReplyRequest.Message" placeholder="Write your reply here..." />
                <ValidationMessage For="@(() => contactReplyRequest.Message)" />
              </div>

              <p class="helper-text">Reply emails use the same SMTP delivery flow already used for OTP and notification emails.</p>

              <div class="button-row">
                <button class="submit-btn" type="submit" disabled="@(!CanSendContactReply)">@(isSendingContactReply ? "Sending..." : "Send Reply Email")</button>
                <button class="ghost-btn" type="button" disabled="@(SelectedContactMessage is null)" @onclick="ResetContactReplyDraft">Reset Draft</button>
              </div>
            }
          </EditForm>
        </div>
      }
      else if (activeSection == AdminSection.Support)
      {
        var selectedSupportQuery = SelectedSupportThreadQuery;
        <div class="panel-header">
          <div>
            <h3>Support Query Trace</h3>
            <p class="section-intro">Support remains focused: choose any query on the left and reply from the thread panel on the right.</p>
          </div>
          <div style="display:flex; gap:10px; align-items:center;">
            <span class="badge">Admin Support</span>
            <button class="ghost-btn" type="button" @onclick="ToggleSupportMaximize">@(isSupportMaximized ? "Minimize" : "Focus Thread")</button>
          </div>
        </div>

        <div class="support-layout @(isSupportMaximized ? "maximized" : null)">
          <div class="query-list">
            @if (supportTrace.Count == 0)
            {
              <p class="empty-note">No support queries yet.</p>
            }
            else
            {
              @foreach (var query in supportTrace.OrderByDescending(item => item.CreatedAtUtc))
              {
                <div class="query-card @(expandedSupportQueryId == query.Id ? "active" : null)">
                  <h4>@query.Subject</h4>
                  <p><strong>@query.Category:</strong> @query.Message</p>
                  <div class="query-meta">
                    <span>@query.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                    <span style="display:flex; align-items:center; gap:10px;">
                      <span class="status @GetStatusCss(query.Status)">@query.Status</span>
                      <button class="ghost-btn" type="button" @onclick="() => ToggleSupportThreadAsync(query.Id)">@(expandedSupportQueryId == query.Id ? "Close" : "Open")</button>
                    </span>
                  </div>
                </div>
              }
            }
          </div>

          <div class="thread-panel">
            @if (!expandedSupportQueryId.HasValue || selectedSupportQuery is null)
            {
              <p class="empty-note">Open any support query to inspect the full conversation and send an admin reply.</p>
            }
            else
            {
              <div class="thread-meta" style="margin-bottom:14px;">
                <div>
                  <h4 style="margin-bottom:4px;">@selectedSupportQuery.Subject</h4>
                  <p class="summary-caption" style="margin-bottom:0;">Ticket #@selectedSupportQuery.Id • @selectedSupportQuery.Category • @selectedSupportQuery.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</p>
                </div>
                <div class="button-row">
                  <button class="ghost-btn" type="button" disabled="@isUpdatingSupportTicketStatus" @onclick="ToggleSelectedSupportTicketStatusAsync">
                    @(IsSupportTicketClosed(selectedSupportQuery.Status) ? "Reopen Ticket" : "Close Ticket")
                  </button>
                  <button class="ghost-btn" type="button" @onclick="CloseSupportThread">Close Thread</button>
                </div>
              </div>

              <div class="thread-stack">
                @if (expandedSupportMessages.Count == 0)
                {
                  <p class="empty-note">No messages yet.</p>
                }
                else
                {
                  @foreach (var message in expandedSupportMessages)
                  {
                    var bubbleCss = string.Equals(message.SenderRole, AuthRoles.Admin, StringComparison.OrdinalIgnoreCase) ? "admin" : "user";
                    <div class="chat-bubble @bubbleCss">
                      @message.Message
                      <span class="chat-meta">@message.SenderRole • @message.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                    </div>
                  }
                }
              </div>

              <EditForm Model="adminReplyRequest" OnValidSubmit="SendAdminReplyAsync">
                <DataAnnotationsValidator />
                <label>Reply to Customer</label>
                <InputTextArea @bind-Value="adminReplyRequest.Message" placeholder="Reply to this query..." />
                <button class="submit-btn" type="submit" style="margin-top:12px;">Send Reply</button>
              </EditForm>
            }
          </div>
        </div>
      }
    </section>
  </main>
</div>
}
else
{
  <div class="loading-shell">Loading admin dashboard...</div>
}

<div class="toast-container">
  @foreach (var toast in toasts)
  {
    <div class="toast @(toast.IsError ? "error" : "success")">@toast.Text</div>
  }
</div>

@code {
  private readonly CurrencyContext adminCurrency = CurrencyContext.FromCountryCode("US");
    private enum AdminSection
    {
        Products,
        Orders,
        Customers,
        Faq,
        Notifications,
        Contact,
        Support
    }

    private sealed class ToastMessage
    {
        public int Id { get; set; }
        public string Text { get; set; } = string.Empty;
        public bool IsError { get; set; }
    }

    private sealed class ImageUploadResponse
    {
        public string? ImageUrl { get; set; }
    }

    private readonly List<ProductDto> products = new();
    private readonly List<OrderTraceDto> orderTrace = new();
    private readonly List<FaqDto> faqs = new();
    private readonly List<ContactMessageDto> contactMessages = new();
    private readonly List<SupportQueryDto> supportTrace = new();
    private readonly List<SupportQueryMessageDto> expandedSupportMessages = new();
    private readonly List<AdminUserDto> customers = new();
    private readonly List<AdminLeadNotificationDto> followUpLeads = new();
    private readonly List<ToastMessage> toasts = new();
    private readonly Dictionary<long, string> pendingOrderStatuses = new();
    private readonly HashSet<long> savingOrderIds = new();
    private readonly HashSet<long> savingCustomerIds = new();
    private readonly List<string> descriptionSummaryInputs = new();
    private readonly List<string> descriptionFeatureInputs = new();
    private CreateProductRequest createProduct = new() { IsActive = true };
    private CreateFaqRequest faqRequest = new() { IsActive = true };
    private CreateSupportQueryMessageRequest adminReplyRequest = new();
    private SendLeadFollowUpEmailRequest followUpEmailRequest = new();
    private SendContactReplyRequest contactReplyRequest = new();
    private AdminSection activeSection = AdminSection.Products;
    private string? statusMessage;
    private string profileEmail = string.Empty;
    private string? pendingScrollAnchor;
    private string productFilter = string.Empty;
    private string orderFilter = string.Empty;
    private string customerFilter = string.Empty;
    private string faqFilter = string.Empty;
    private string followUpLeadFilter = string.Empty;
    private string contactFilter = string.Empty;
    private int toastCounter;
    private int productCount;
    private int orderCount;
    private int customerCount;
    private int faqCount;
    private int contactCount;
    private decimal totalRevenue;
    private bool canRenderDashboard;
    private bool isSupportMaximized;
    private bool isProductsMaximized;
    private bool isUploadingImage;
    private bool isSavingFaq;
    private bool isSendingFollowUpEmail;
    private bool isSendingContactReply;
    private bool isUpdatingSupportTicketStatus;
    private long? expandedSupportQueryId;
    private long? editingProductId;
    private long? editingFaqId;
