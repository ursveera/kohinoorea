    private async Task SendContactReplyAsync()
    {
        statusMessage = null;

        var selectedContact = SelectedContactMessage;
        if (selectedContact is null)
        {
            statusMessage = "Select a contact message before sending a reply.";
            _ = ShowToastAsync(statusMessage, isError: true);
            return;
        }

        isSendingContactReply = true;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/commerce/contact-messages/{selectedContact.Id}/reply", contactReplyRequest);
            AuthResponse? payload = null;

            if (response.Content.Headers.ContentLength is > 0 || response.Content.Headers.ContentType is not null)
            {
                try
                {
                    payload = await response.Content.ReadFromJsonAsync<AuthResponse>();
                }
                catch
                {
                }
            }

            if (!response.IsSuccessStatusCode || payload?.Success == false)
            {
                statusMessage = payload?.Message ?? "Unable to send the contact reply email.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            statusMessage = payload?.Message ?? "Reply email sent successfully.";
            _ = ShowToastAsync(statusMessage);
            await LoadDashboardDataAsync();
            ResetContactReplyDraft();
        }
        finally
        {
            isSendingContactReply = false;
        }
    }

    private async Task DeleteSelectedContactMessageAsync()
    {
        var selected = SelectedContactMessage;
        if (selected is null)
