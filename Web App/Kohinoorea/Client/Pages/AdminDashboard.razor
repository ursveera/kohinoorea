    private async Task ShowToastAsync(string text, bool isError = false)
    {
        var id = ++toastCounter;
        toasts.Add(new ToastMessage { Id = id, Text = text, IsError = isError });
        await InvokeAsync(StateHasChanged);
        await Task.Delay(3200);
        toasts.RemoveAll(item => item.Id == id);
        await InvokeAsync(StateHasChanged);
    }

    private static string NormalizeOrderStatus(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "completed" => "Completed",
            "denied" => "Denied",
            _ => "Pending"
        };
    }

    private static string GetStatusCss(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "completed" => "completed",
            "denied" => "denied",
            "closed" => "closed",
            "open" => "open",
            "active" => "open",
            _ => "pending"
        };
    }

    private static bool IsSupportTicketClosed(string? status)
    {
        return string.Equals(status?.Trim(), "Closed", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetLeadPlanLabel(string? requestedPlan)
    {
        return requestedPlan?.Trim().ToLowerInvariant() switch
        {
            "annual" => "Annual Plan",
            "lifetime" => "Lifetime 4 Years",
            "demo" => "Demo / Trial",
            _ => "Plan not selected"
        };
    }

    private static string GetLeadOrderSummary(AdminLeadNotificationDto lead)
    {
        if (lead.TotalOrders <= 0)
        {
            return "No order started yet";
        }

        var orderLabel = lead.TotalOrders == 1 ? "1 order started" : $"{lead.TotalOrders} orders started";
        return $"{orderLabel} | Last: {NormalizeOrderStatus(lead.LastOrderStatus)}";
    }

    private static string GetLeadLastOrderText(AdminLeadNotificationDto lead)
    {
        if (!lead.LastOrderAtUtc.HasValue)
        {
            return "No order created yet.";
        }

        return $"{NormalizeOrderStatus(lead.LastOrderStatus)} on {lead.LastOrderAtUtc.Value.ToLocalTime():dd MMM yyyy hh:mm tt}";
    }

    private static SendLeadFollowUpEmailRequest BuildFollowUpDraft(AdminLeadNotificationDto lead)
    {
        var planLabel = GetLeadPlanLabel(lead.RequestedPlan);

        return new SendLeadFollowUpEmailRequest
        {
            Subject = $"Kohinoor EA follow-up for your {planLabel}",
            Message =
$@"Hello {lead.FullName},

We noticed that you created your Kohinoor EA account for the {planLabel} but have not completed a purchase yet.

If you need help choosing the right plan, completing your payment, or getting started with setup, reply to this email and our team will help you.

Regards,
Kohinoor EA Support"
        };
    }

    private static SendContactReplyRequest BuildContactReplyDraft(ContactMessageDto contactMessage)
    {
        var normalizedSubject = string.IsNullOrWhiteSpace(contactMessage.Subject)
            ? "Kohinoor EA reply"
            : contactMessage.Subject.Trim();

        if (!normalizedSubject.StartsWith("Re:", StringComparison.OrdinalIgnoreCase))
        {
            normalizedSubject = $"Re: {normalizedSubject}";
        }

        return new SendContactReplyRequest
        {
            Subject = normalizedSubject,
            Message =
$@"Hello {contactMessage.Name},

Thank you for contacting Kohinoor EA. We reviewed your message and are happy to help.

Regards,
Kohinoor EA Support"
        };
    }

    private static string GetProductSummary(ProductDto product)
    {
      return GetDescriptionSummary(product.Description);
    }

    private static string GetProductFullDescription(ProductDto product)
    {
        var raw = product.Description ?? string.Empty;
        if (string.IsNullOrWhiteSpace(raw))
        {
            return "No description added yet.";
        }

        var cleaned = NormalizeDescriptionText(raw);
        return string.IsNullOrWhiteSpace(cleaned) ? "No description added yet." : cleaned;
    }

    private static string GetDescriptionSummary(string? raw)
    {
      if (string.IsNullOrWhiteSpace(raw))
      {
        return "No description added yet.";
      }

      var match = Regex.Match(raw, @"<p[^>]*>(.*?)</p>", RegexOptions.Singleline | RegexOptions.IgnoreCase);
      if (match.Success)
      {
        var cleaned = NormalizeDescriptionText(match.Groups[1].Value);
        return string.IsNullOrWhiteSpace(cleaned) ? "No description added yet." : cleaned;
      }

      return NormalizeDescriptionText(raw);
    }

    private static List<string> GetDescriptionTagValues(string? raw, string tagName)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return new List<string>();
        }

        var matches = Regex.Matches(raw, $@"<{tagName}[^>]*>(.*?)</{tagName}>", RegexOptions.Singleline | RegexOptions.IgnoreCase);
        var values = new List<string>();
        foreach (Match match in matches)
        {
            var value = NormalizeDescriptionText(match.Groups[1].Value);
            if (!string.IsNullOrWhiteSpace(value))
            {
                values.Add(value);
            }
        }

        return values;
    }

    private static string NormalizeDescriptionText(string raw)
    {
        var cleaned = Regex.Replace(raw, @"<.*?>", " ").Trim();
        cleaned = Regex.Replace(cleaned, @"\s+", " ").Trim();
        return cleaned;
    }

