    private void BuildDescriptionFromFields()
    {
      var parts = new List<string>();

      foreach (var summary in descriptionSummaryInputs.Where(text => !string.IsNullOrWhiteSpace(text)))
      {
        parts.Add($"<p>{EscapeDescriptionValue(summary)}</p>");
      }

      foreach (var feature in descriptionFeatureInputs.Where(text => !string.IsNullOrWhiteSpace(text)))
      {
        parts.Add($"<span>{EscapeDescriptionValue(feature)}</span>");
      }

      createProduct.Description = string.Join(string.Empty, parts);
    }

    private void ClearDescriptionFields()
    {
      descriptionSummaryInputs.Clear();
      descriptionFeatureInputs.Clear();
      createProduct.Description = string.Empty;
    }

    private void PopulateDescriptionFields(string? description)
    {
      descriptionSummaryInputs.Clear();
      descriptionFeatureInputs.Clear();

      if (string.IsNullOrWhiteSpace(description))
      {
        return;
      }

      foreach (var summary in GetDescriptionTagValues(description, "p"))
      {
        descriptionSummaryInputs.Add(summary);
      }

      foreach (var feature in GetDescriptionTagValues(description, "span"))
      {
        descriptionFeatureInputs.Add(feature);
      }
    }

    private static string EscapeDescriptionValue(string value)
    {
      return value
        .Replace("&", "&amp;", StringComparison.Ordinal)
        .Replace("<", "&lt;", StringComparison.Ordinal)
        .Replace(">", "&gt;", StringComparison.Ordinal);
    }

    private void NormalizeProductForm()
    {
