    private DotNetObjectReference<AdminDashboard>? infiniteScrollDotNetRef;
    private IJSObjectReference? exportModule;

    private readonly HashSet<long> savingCustomerIds = new();
    private readonly HashSet<long> savingAdminIds = new();
    private readonly Dictionary<long, DateTime> notifiedProductUntilUtc = new();
    private readonly List<string> descriptionSummaryInputs = new();
    private readonly List<string> descriptionFeatureInputs = new();
    private CreateProductRequest createProduct = new() { IsActive = true };
    private CreateFaqRequest faqRequest = new() { IsActive = true };
    private CreateSupportQueryMessageRequest adminReplyRequest = new();
    private SendLeadFollowUpEmailRequest followUpEmailRequest = new();
    private SendContactReplyRequest contactReplyRequest = new();
    private CreateAdminRequest createAdminRequest = new();
    private sealed class AdminRoleSelection
    {
        public bool Products { get; set; } = true;
        public bool Orders { get; set; } = true;
        public bool Customers { get; set; } = true;
        public bool Admins { get; set; } = false;
        public bool Faq { get; set; } = true;
        public bool Notifications { get; set; } = true;
        public bool Contact { get; set; } = true;
        public bool Support { get; set; } = true;
    }

    private AdminRoleSelection createAdminRoles = new();
    private AdminSection activeSection = AdminSection.Products;
    private string? statusMessage;
    private string profileEmail = string.Empty;
    private string? pendingScrollAnchor;
