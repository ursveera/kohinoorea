    private List<ProductDto> FilteredProducts => products
        .Where(product => MatchesProductFilter(product))
        .OrderByDescending(item => item.CreatedAtUtc)
        .ToList();

    private List<OrderTraceDto> FilteredOrders => orderTrace
        .Where(order => MatchesOrderFilter(order))
        .OrderByDescending(item => item.OrderedAtUtc)
        .ToList();

    private List<OrderTraceDto> PendingOrdersForVerification => orderTrace
        .Where(order => string.Equals(NormalizeOrderStatus(order.Status), "Pending", StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(item => item.OrderedAtUtc)
        .Take(25)
        .ToList();

    private List<ActivePlanDto> FilteredActivePlans => activePlans
        .Where(plan => MatchesActivePlanFilter(plan))
        .OrderByDescending(item => item.OrderedAtUtc)
        .ToList();

