@page "/admin-dashboard"
@implements IDisposable
@using System.Text.RegularExpressions
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Kohinoorea.Client.Services

<PageTitle>Kohinoorea Admin Dashboard</PageTitle>
<PremiumConfirmModal
  Title="Confirm Permanent Delete"
  Message="@modalMessage"
  IsVisible="@showConfirmModal"
  OnResult="OnConfirmModalResult"
  OnClose="HideConfirmModal" />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  :root, body[data-theme="dark"] {
    --d-bg: linear-gradient(135deg,#060810 0%,#0f1623 55%,#040609 100%);
    --d-glow1: rgba(255,196,87,0.18);
    --d-glow2: rgba(128,90,213,0.18);
    --d-text: #f0f4ff;
    --d-muted: #7b8fa8;
    --d-sidebar-bg: rgba(6,9,18,0.82);
    --d-sidebar-border: rgba(255,255,255,0.07);
    --d-brand-sub: #6b7fa0;
    --d-nav-text: #b8c8de;
    --d-nav-hover: rgba(255,255,255,0.08);
    --d-nav-border: rgba(255,255,255,0.07);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.14),rgba(249,115,22,0.07));
    --d-plan-card-border: rgba(251,191,36,0.2);
    --d-plan-card-text: #c8d4e8;
    --d-profile-bg: rgba(255,255,255,0.07);
    --d-profile-border: rgba(255,255,255,0.07);
    --d-card-bg: rgba(255,255,255,0.06);
    --d-card-border: rgba(255,255,255,0.08);
    --d-card-shimmer: rgba(255,255,255,0.025);
    --d-panel-bg: rgba(255,255,255,0.06);
    --d-panel-border: rgba(255,255,255,0.08);
    --d-panel-shadow: 0 20px 80px rgba(0,0,0,0.28);
    --d-th-color: #6b7fa0;
    --d-td-color: #d1dce8;
    --d-row-border: rgba(255,255,255,0.07);
    --d-product-bg: rgba(255,255,255,0.05);
    --d-product-hover: rgba(255,255,255,0.09);
    --d-product-border: rgba(255,255,255,0.07);
    --d-product-img: linear-gradient(135deg,#1a2235,#2a3a55);
    --d-product-desc: #6b7fa0;
    --d-ghost-bg: rgba(15,23,42,0.6);
    --d-ghost-border: rgba(255,255,255,0.16);
    --d-ghost-text: #c8d4e8;
    --d-query-bg: rgba(255,255,255,0.05);
    --d-query-border: rgba(255,255,255,0.07);
    --d-form-bg: rgba(255,255,255,0.05);
    --d-form-border: rgba(255,255,255,0.07);
    --d-input-bg: rgba(10,16,30,0.88);
    --d-input-border: rgba(255,255,255,0.09);
    --d-input-text: #f0f4ff;
    --d-label-text: #b8c8de;
    --d-empty-text: #6b7fa0;
    --d-divider: rgba(255,255,255,0.07);
    --d-stat-num: #fbbf24;
  }

  body[data-theme="light"] {
    --d-bg: linear-gradient(135deg,#eef2f9 0%,#faf7f0 55%,#f2eefb 100%);
    --d-glow1: rgba(251,191,36,0.2);
    --d-glow2: rgba(128,90,213,0.1);
    --d-text: #111827;
    --d-muted: #6b7280;
    --d-sidebar-bg: rgba(255,255,255,0.88);
    --d-sidebar-border: rgba(0,0,0,0.09);
    --d-brand-sub: #6b7280;
    --d-nav-text: #374151;
    --d-nav-hover: rgba(0,0,0,0.05);
    --d-nav-border: rgba(0,0,0,0.05);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.1),rgba(249,115,22,0.05));
    --d-plan-card-border: rgba(251,191,36,0.3);
    --d-plan-card-text: #374151;
    --d-profile-bg: rgba(0,0,0,0.04);
    --d-profile-border: rgba(0,0,0,0.08);
    --d-card-bg: rgba(255,255,255,0.82);
    --d-card-border: rgba(0,0,0,0.08);
    --d-card-shimmer: rgba(255,255,255,0.7);
    --d-panel-bg: rgba(255,255,255,0.88);
    --d-panel-border: rgba(0,0,0,0.08);
    --d-panel-shadow: 0 8px 40px rgba(0,0,0,0.1);
    --d-th-color: #6b7280;
    --d-td-color: #374151;
    --d-row-border: rgba(0,0,0,0.07);
    --d-product-bg: rgba(255,255,255,0.75);
    --d-product-hover: rgba(255,255,255,0.95);
    --d-product-border: rgba(0,0,0,0.08);
    --d-product-img: linear-gradient(135deg,#dde3f0,#c7d2e8);
    --d-product-desc: #6b7280;
    --d-ghost-bg: rgba(255,255,255,0.7);
    --d-ghost-border: rgba(0,0,0,0.14);
    --d-ghost-text: #374151;
    --d-query-bg: rgba(255,255,255,0.7);
    --d-query-border: rgba(0,0,0,0.07);
    --d-form-bg: rgba(255,255,255,0.75);
    --d-form-border: rgba(0,0,0,0.07);
    --d-input-bg: rgba(255,255,255,0.95);
    --d-input-border: rgba(0,0,0,0.12);
    --d-input-text: #111827;
    --d-label-text: #374151;
    --d-empty-text: #6b7280;
    --d-divider: rgba(0,0,0,0.07);
    --d-stat-num: #d97706;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Inter", sans-serif;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, var(--d-glow1), transparent 35%),
      radial-gradient(circle at top right, var(--d-glow2), transparent 35%),
      var(--d-bg);
    color: var(--d-text);
    transition: background 0.35s, color 0.25s;
  }

  .dashboard {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  .sidebar {
    padding: 28px 22px;
    background: var(--d-sidebar-bg);
    border-right: 1px solid var(--d-sidebar-border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 38px;
  }

  .brand-icon {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #111827;
    font-weight: 900;
    box-shadow: 0 10px 30px rgba(251,191,36,0.28);
  }

  .brand h1 {
    font-size: 20px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .brand p {
    font-size: 12px;
    color: var(--d-brand-sub);
    margin-top: 2px;
  }

  .nav-button {
    width: 100%;
    border: 0;
    color: var(--d-nav-text);
    background: transparent;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    margin-bottom: 8px;
    border-radius: 16px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: 0.25s ease;
    text-align: left;
  }

  .nav-button:hover,
  .nav-button.active {
    color: var(--d-text);
    background: var(--d-nav-hover);
    box-shadow: inset 0 0 0 1px var(--d-nav-border);
  }

  .sidebar-card {
    margin-top: 34px;
    padding: 20px;
    border-radius: 22px;
    background: var(--d-plan-card-bg);
    border: 1px solid var(--d-plan-card-border);
  }

  .sidebar-card h3 {
    font-size: 15px;
    color: var(--d-text);
    margin-bottom: 8px;
  }

  .sidebar-card p {
    color: var(--d-plan-card-text);
    font-size: 13px;
    line-height: 1.6;
  }

  .main {
    padding: 28px;
    overflow: hidden;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 18px;
  }

  .topbar h2 {
    font-size: 32px;
    letter-spacing: -0.06em;
    color: var(--d-text);
  }

  .topbar p {
    color: var(--d-muted);
    margin-top: 6px;
  }

  .profile {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    border-radius: 999px;
    background: var(--d-profile-bg);
    border: 1px solid var(--d-profile-border);
  }

  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fbbf24, #a855f7);
    display: grid;
    place-items: center;
    font-weight: 800;
    color: #fff;
  }

  .profile span {
    display: block;
    font-size: 13px;
    color: var(--d-muted);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }

  .stat-card {
    position: relative;
    border: 1px solid var(--d-card-border);
    background: var(--d-card-bg);
    border-radius: 28px;
    padding: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-card::after {
    content: "";
    position: absolute;
    right: -35px;
    top: -35px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(251,191,36,0.1);
    pointer-events: none;
  }

  .stat-card:hover,
  .stat-card.active {
    transform: translateY(-6px);
    border-color: rgba(251,191,36,0.4);
    box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 0 0 1px rgba(251,191,36,0.1), inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-icon {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    font-size: 24px;
    background: var(--d-nav-hover);
    margin-bottom: 18px;
    border: 1px solid var(--d-card-border);
  }

  .stat-card h3 {
    font-size: 18px;
    margin-bottom: 8px;
    color: var(--d-text);
  }

  .stat-card p {
    color: var(--d-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .stat-number {
    margin-top: 18px;
    font-size: 30px;
    font-weight: 800;
    color: var(--d-stat-num);
  }

  .content-panel {
    border: 1px solid var(--d-panel-border);
    background: var(--d-panel-bg);
    border-radius: 30px;
    padding: 26px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: var(--d-panel-shadow);
    animation: fadeIn 0.35s ease;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 22px;
  }

  .panel-header h3 {
    font-size: 24px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .badge {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(34,197,94,0.11);
    color: #22c55e;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(34,197,94,0.22);
  }

  .filter-box,
  .management-form input,
  .management-form textarea,
  .management-form select,
  .thread-panel input,
  .thread-panel textarea,
  .thread-panel select,
  .status-select {
    width: 100%;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    color: var(--d-input-text);
    padding: 13px 14px;
    border-radius: 16px;
    outline: none;
    font-size: 14px;
    transition: border-color 0.2s, background 0.2s;
  }

  .filter-box {
    margin-bottom: 16px;
  }

  .role-toggle-bar {
    display: flex;
    gap: .65rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    padding: .75rem .85rem;
    border: 1px solid var(--d-panel-border);
    background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    border-radius: 16px;
    box-shadow: 0 16px 60px rgba(0,0,0,0.18);
    margin-top: .25rem;
  }

  .role-toggle-actions {
    display: flex;
    gap: .5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .role-chip {
    appearance: none;
    border: 1px solid var(--d-ghost-border);
    background: rgba(15, 23, 42, 0.55);
    color: var(--d-ghost-text);
    padding: .5rem .7rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: .9rem;
    letter-spacing: .2px;
    display: inline-flex;
    gap: .45rem;
    align-items: center;
    cursor: pointer;
    transition: transform .12s ease, background .12s ease, border-color .12s ease, box-shadow .12s ease;
    user-select: none;
  }

  .role-chip:hover {
    transform: translateY(-1px);
    background: rgba(255,255,255,0.08);
    box-shadow: 0 10px 28px rgba(0,0,0,0.22);
  }

  .role-chip:active {
    transform: translateY(0px) scale(0.99);
  }

  .role-chip.selected {
    border-color: rgba(251, 191, 36, 0.35);
    background: linear-gradient(135deg, rgba(251,191,36,0.18), rgba(249,115,22,0.10));
    box-shadow: 0 14px 45px rgba(251,191,36,0.12);
    color: var(--d-text);
  }

  .role-chip .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(148, 163, 184, 0.55);
    box-shadow: inset 0 0 0 2px rgba(255,255,255,0.08);
  }

  .role-chip.selected .dot {
    background: radial-gradient(circle at 30% 30%, #fde68a 0%, #fbbf24 40%, #d97706 100%);
    box-shadow: 0 0 0 3px rgba(251,191,36,0.12);
  }

  .role-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(160px, 1fr));
    gap: .6rem;
    margin-top: .75rem;
  }

  @@media (max-width: 1050px) {
    .role-grid { grid-template-columns: repeat(2, minmax(160px, 1fr)); }
  }

  .role-tile {
    border: 1px solid var(--d-panel-border);
    background: rgba(255,255,255,0.04);
    border-radius: 16px;
    padding: .75rem .85rem;
    cursor: pointer;
    transition: transform .12s ease, background .12s ease, border-color .12s ease, box-shadow .12s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
  }

  .role-tile:hover {
    transform: translateY(-1px);
    background: rgba(255,255,255,0.07);
    box-shadow: 0 14px 50px rgba(0,0,0,0.22);
  }

  .role-tile.selected {
    border-color: rgba(16, 185, 129, 0.35);
    background: linear-gradient(135deg, rgba(16,185,129,0.14), rgba(34,197,94,0.06));
  }

  .role-tile strong {
    color: var(--d-text);
    font-size: 1rem;
    letter-spacing: .2px;
  }

  .role-tile small {
    display: block;
    margin-top: .15rem;
    color: var(--d-muted);
    font-weight: 600;
    font-size: .82rem;
  }

  .role-pill {
    min-width: 56px;
    text-align: center;
    padding: .3rem .55rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: .8rem;
    border: 1px solid var(--d-ghost-border);
    background: rgba(15,23,42,0.55);
    color: var(--d-ghost-text);
  }

  .role-tile.selected .role-pill {
    border-color: rgba(16, 185, 129, 0.35);
    background: rgba(16,185,129,0.14);
    color: var(--d-text);
  }

  .admin-form-card {
    border: 1px solid var(--d-panel-border);
    background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    border-radius: 18px;
    padding: 1rem 1rem;
    box-shadow: 0 22px 70px rgba(0,0,0,0.24);
  }

  .admin-input {
    width: 100%;
    padding: .78rem .9rem;
    border-radius: 14px;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    color: var(--d-input-text);
    outline: none;
    transition: box-shadow .15s ease, border-color .15s ease, transform .12s ease;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.02);
  }

  .admin-input::placeholder {
    color: rgba(123, 143, 168, 0.9);
    font-weight: 600;
  }

  .admin-input:focus {
    border-color: rgba(251,191,36,0.35);
    box-shadow: 0 0 0 5px rgba(251,191,36,0.12);
  }

  .admin-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
  }

  @@media (max-width: 900px) {
    .admin-grid-2 { grid-template-columns: 1fr; }
  }

  .admin-actions {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .admin-btn {
    border-radius: 14px;
    border: 1px solid var(--d-ghost-border);
    background: rgba(15,23,42,0.55);
    color: var(--d-ghost-text);
    padding: .6rem .85rem;
    font-weight: 800;
    cursor: pointer;
    transition: transform .12s ease, background .12s ease, border-color .12s ease, box-shadow .12s ease;
  }

  .admin-btn:hover { transform: translateY(-1px); background: rgba(255,255,255,0.08); box-shadow: 0 12px 32px rgba(0,0,0,0.22); }
  .admin-btn:active { transform: translateY(0px) scale(0.99); }

  .admin-btn.primary {
    border-color: rgba(251,191,36,0.35);
    background: linear-gradient(135deg, rgba(251,191,36,0.22), rgba(249,115,22,0.14));
    color: var(--d-text);
    box-shadow: 0 16px 45px rgba(251,191,36,0.12);
  }

  .admin-btn.danger {
    border-color: rgba(239,68,68,0.35);
    background: linear-gradient(135deg, rgba(239,68,68,0.16), rgba(244,63,94,0.10));
    color: var(--d-text);
  }

  .admin-table input, .admin-table select {
    font-weight: 700;
  }

  .admin-table .status-select {
    border-radius: 999px;
    padding: .55rem .8rem;
  }

  .orders-toolbar {
    display: flex;
    gap: 14px;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .orders-toolbar .filter-box {
    margin-bottom: 0;
    flex: 1;
  }

  .orders-export {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .orders-export .ghost-btn {
    padding: 10px 14px;
    min-width: 128px;
  }

  .table-wrap {
    overflow: auto;
    max-height: 60vh;
    padding-right: 4px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
  }

  th, td {
    padding: 16px 14px;
    text-align: left;
    border-bottom: 1px solid var(--d-row-border);
    font-size: 14px;
    vertical-align: middle;
  }

  th {
    color: var(--d-th-color);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--d-panel-bg) 88%, transparent);
    backdrop-filter: blur(12px);
  }

  td {
    color: var(--d-td-color);
  }

  .status {
    display: inline-flex;
    padding: 7px 11px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
  }

  .completed,
  .delivered {
    background: rgba(34,197,94,0.12);
    color: #16a34a;
  }

  .pending {
    background: rgba(251,191,36,0.12);
    color: #d97706;
  }

  .denied,
  .cancelled {
    background: rgba(248,113,113,0.12);
    color: #dc2626;
  }

  .open {
    background: rgba(96,165,250,0.12);
    color: #2563eb;
  }

  .closed {
    background: rgba(148,163,184,0.12);
    color: #6b7280;
  }

  body[data-theme="dark"] .completed,
  body[data-theme="dark"] .delivered { color: #86efac; }
  body[data-theme="dark"] .pending { color: #fde68a; }
  body[data-theme="dark"] .denied,
  body[data-theme="dark"] .cancelled { color: #fca5a5; }
  body[data-theme="dark"] .open { color: #93c5fd; }
  body[data-theme="dark"] .closed { color: #cbd5e1; }

  .product-management-layout,
  .faq-layout,
  .support-layout,
  .notification-layout,
  .contact-admin-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: start;
  }

  .support-layout.maximized {
    grid-template-columns: 1fr;
  }

  .management-form,
  .thread-panel,
  .product-list-panel {
    padding: 20px;
    border-radius: 24px;
    background: var(--d-form-bg);
    border: 1px solid var(--d-form-border);
  }

  .management-form {
    position: sticky;
    top: 20px;
  }

