    private async Task ToggleSupportThreadAsync(long queryId)
    {
        if (expandedSupportQueryId == queryId)
        {
            CloseSupportThread();
            return;
        }

        expandedSupportQueryId = queryId;
        adminReplyRequest = new CreateSupportQueryMessageRequest();
        activeSection = AdminSection.Support;
        await LoadSupportThreadAsync(queryId);
    }

    private async Task LoadSupportThreadAsync(long queryId)
    {
        var response = await Http.GetAsync($"api/commerce/support/{queryId}/messages");
        if (!response.IsSuccessStatusCode)
        {
            expandedSupportMessages.Clear();
            statusMessage = "Unable to load support thread.";
            _ = ShowToastAsync("Unable to load support thread.", isError: true);
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<List<SupportQueryMessageDto>>();
        expandedSupportMessages.Clear();
        expandedSupportMessages.AddRange(payload ?? Enumerable.Empty<SupportQueryMessageDto>());
    }

    private async Task SendAdminReplyAsync()
    {
        if (!expandedSupportQueryId.HasValue)
        {
            return;
        }

        var queryId = expandedSupportQueryId.Value;
        var response = await Http.PostAsJsonAsync($"api/commerce/support/{queryId}/messages", adminReplyRequest);
        if (!response.IsSuccessStatusCode)
        {
            statusMessage = "Unable to send admin reply.";
            _ = ShowToastAsync("Failed to send reply.", isError: true);
            return;
        }

        adminReplyRequest = new CreateSupportQueryMessageRequest();
        statusMessage = "Admin reply sent.";
        _ = ShowToastAsync("Reply sent.");
        await LoadSupportThreadAsync(queryId);
    }

    private Task ToggleSelectedSupportTicketStatusAsync()
    {
        var selectedQuery = SelectedSupportThreadQuery;
        if (selectedQuery is null)
        {
            return Task.CompletedTask;
        }

        var nextStatus = IsSupportTicketClosed(selectedQuery.Status) ? "Open" : "Closed";
        return UpdateSupportTicketStatusAsync(nextStatus);
    }

    private async Task UpdateSupportTicketStatusAsync(string nextStatus)
    {
        var selectedQuery = SelectedSupportThreadQuery;
        if (selectedQuery is null)
        {
            return;
        }

        isUpdatingSupportTicketStatus = true;

        try
        {
            var response = await Http.PatchAsJsonAsync($"api/commerce/support/{selectedQuery.Id}/status", new UpdateSupportQueryStatusRequest
            {
                Status = nextStatus
            });

            if (!response.IsSuccessStatusCode)
            {
                statusMessage = "Unable to update support ticket status.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            selectedQuery.Status = nextStatus;
            statusMessage = string.Equals(nextStatus, "Closed", StringComparison.OrdinalIgnoreCase)
                ? "Support ticket closed."
                : "Support ticket reopened.";
            _ = ShowToastAsync(statusMessage);
        }
        finally
        {
            isUpdatingSupportTicketStatus = false;
        }
    }

    private void CloseSupportThread()
    {
        expandedSupportQueryId = null;
        expandedSupportMessages.Clear();
        adminReplyRequest = new CreateSupportQueryMessageRequest();
    }

    private void SelectFollowUpLead(AdminLeadNotificationDto lead)
    {
        selectedFollowUpLeadUserId = lead.UserId;
        followUpEmailRequest = BuildFollowUpDraft(lead);
    }

    private void ResetFollowUpDraft()
    {
        if (SelectedFollowUpLead is null)
        {
            return;
        }

        followUpEmailRequest = BuildFollowUpDraft(SelectedFollowUpLead);
    }

    private async Task SendFollowUpNotificationAsync()
    {
        statusMessage = null;

        var lead = SelectedFollowUpLead;
        if (lead is null)
        {
            statusMessage = "Select a user before sending a notification.";
            _ = ShowToastAsync(statusMessage, isError: true);
            return;
        }

        isSendingFollowUpEmail = true;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/auth/follow-up-leads/{lead.UserId}/email", followUpEmailRequest);
            var payload = await response.Content.ReadFromJsonAsync<AuthResponse>();

            if (!response.IsSuccessStatusCode || payload?.Success != true)
            {
                statusMessage = payload?.Message ?? "Unable to send the notification email.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            statusMessage = payload.Message;
            _ = ShowToastAsync(payload.Message);
        }
        finally
        {
            isSendingFollowUpEmail = false;
        }
    }

    private void SelectContactMessage(ContactMessageDto contactMessage)
    {
        selectedContactMessageId = contactMessage.Id;
        contactReplyRequest = BuildContactReplyDraft(contactMessage);
    }

    private void ResetContactReplyDraft()
    {
        if (SelectedContactMessage is null)
        {
            return;
        }

        contactReplyRequest = BuildContactReplyDraft(SelectedContactMessage);
    }

    private async Task SendContactReplyAsync()
    {
        statusMessage = null;

        var selectedContact = SelectedContactMessage;
        if (selectedContact is null)
        {
            statusMessage = "Select a contact message before sending a reply.";
            _ = ShowToastAsync(statusMessage, isError: true);
            return;
        }

        isSendingContactReply = true;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/commerce/contact-messages/{selectedContact.Id}/reply", contactReplyRequest);
            AuthResponse? payload = null;

            if (response.Content.Headers.ContentLength is > 0 || response.Content.Headers.ContentType is not null)
            {
                try
                {
                    payload = await response.Content.ReadFromJsonAsync<AuthResponse>();
                }
                catch
                {
                }
            }

            if (!response.IsSuccessStatusCode || payload?.Success == false)
            {
                statusMessage = payload?.Message ?? "Unable to send the contact reply email.";
                _ = ShowToastAsync(statusMessage, isError: true);
                return;
            }

            statusMessage = payload?.Message ?? "Reply email sent successfully.";
            _ = ShowToastAsync(statusMessage);
            await LoadDashboardDataAsync();
            ResetContactReplyDraft();
        }
        finally
        {
            isSendingContactReply = false;
        }
    }

    private bool MatchesProductFilter(ProductDto product)
    {
        if (string.IsNullOrWhiteSpace(productFilter))
        {
            return true;
        }

        var needle = productFilter.Trim();
        var haystack = string.Join(" ", new[]
        {
            product.Name,
            product.Description,
            product.CountryCode,
            product.IsActive ? "active" : "hidden",
            product.IsMaster ? "master" : "regular"
        });

        return haystack.Contains(needle, StringComparison.OrdinalIgnoreCase);
    }

