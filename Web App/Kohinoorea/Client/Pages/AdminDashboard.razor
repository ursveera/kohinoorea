    private static List<string> BuildSelectedAdminRoles(AdminRoleSelection selection)
    {
        if (IsAllRolesSelected(selection))
        {
            // Keep DB role value small and treat plain Admin as full access.
            return new List<string> { AuthRoles.Admin };
        }

        var roles = new List<string> { AuthRoles.Admin };
        if (selection.Admins) roles.Add(AdminSectionRoles.Admins);
        if (selection.Products) roles.Add(AdminSectionRoles.Products);
        if (selection.Orders) roles.Add(AdminSectionRoles.Orders);
        if (selection.Customers) roles.Add(AdminSectionRoles.Customers);
        if (selection.Faq) roles.Add(AdminSectionRoles.Faq);
        if (selection.Notifications) roles.Add(AdminSectionRoles.Notifications);
        if (selection.Contact) roles.Add(AdminSectionRoles.Contact);
        if (selection.Support) roles.Add(AdminSectionRoles.Support);
        return roles;
    }

    private static bool IsAnyRoleSelected(AdminRoleSelection selection) =>
        selection.Products || selection.Orders || selection.Customers || selection.Admins ||
        selection.Faq || selection.Notifications || selection.Contact || selection.Support;

    private static bool IsAllRolesSelected(AdminRoleSelection selection) =>
        selection.Products && selection.Orders && selection.Customers && selection.Admins &&
        selection.Faq && selection.Notifications && selection.Contact && selection.Support;

    private static bool IsSupportOnly(AdminRoleSelection selection) =>
        selection.Support &&
        !(selection.Products || selection.Orders || selection.Customers || selection.Admins ||
          selection.Faq || selection.Notifications || selection.Contact);

    private static bool IsOrdersOnly(AdminRoleSelection selection) =>
        selection.Orders &&
        !(selection.Products || selection.Customers || selection.Admins ||
          selection.Faq || selection.Notifications || selection.Contact || selection.Support);

