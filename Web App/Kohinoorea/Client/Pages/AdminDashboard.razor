  private void ShowForceDeleteModal(ProductDto product)
  {
    pendingForceDeleteProduct = product;
    modalMessage = $"Force delete '{product.Name}'? This cannot be undone.\n\nYes = delete permanently\nNo = cancel";
    showConfirmModal = true;
