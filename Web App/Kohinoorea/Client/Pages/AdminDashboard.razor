    private string GetPendingOrderStatus(OrderTraceDto row)
    {
        return pendingOrderStatuses.TryGetValue(row.OrderId, out var value)
            ? NormalizeOrderStatus(value)
            : NormalizeOrderStatus(row.Status);
    }

    private bool IsOrderStatusDirty(OrderTraceDto row)
    {
        return !string.Equals(GetPendingOrderStatus(row), NormalizeOrderStatus(row.Status), StringComparison.OrdinalIgnoreCase);
    }

    private async Task SaveOrderStatusAsync(OrderTraceDto row)
    {
        var previousStatus = NormalizeOrderStatus(row.Status);
        var nextStatus = GetPendingOrderStatus(row);

        if (string.Equals(previousStatus, nextStatus, StringComparison.OrdinalIgnoreCase))
        {
            _ = ShowToastAsync($"Order #{row.OrderId} already has that status.");
            return;
        }

        row.Status = nextStatus;
        savingOrderIds.Add(row.OrderId);
        StateHasChanged();

        var response = await Http.PatchAsJsonAsync($"api/commerce/orders/{row.OrderId}/status", new { Status = nextStatus });
        if (!response.IsSuccessStatusCode)
        {
            row.Status = previousStatus;
            pendingOrderStatuses[row.OrderId] = previousStatus;
            savingOrderIds.Remove(row.OrderId);
            StateHasChanged();
            _ = ShowToastAsync($"Failed to update order #{row.OrderId}.", isError: true);
            return;
        }

        pendingOrderStatuses[row.OrderId] = nextStatus;
        savingOrderIds.Remove(row.OrderId);
        StateHasChanged();
        _ = ShowToastAsync($"Order #{row.OrderId} marked as {nextStatus}.");
    }

    private Task MarkOrderCompletedAsync(OrderTraceDto row)
    {
        pendingOrderStatuses[row.OrderId] = "Completed";
        return SaveOrderStatusAsync(row);
    }

