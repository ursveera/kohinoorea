    private sealed class CartItem
    {
        public long ProductId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; } = 1;
    }

    private const string CartKey = "kohinoor_cart";

    private async Task AddToCartAsync(long productId, string productName = "")
    {
        var product = products.FirstOrDefault(p => p.Id == productId);
        if (product is null)
        {
            productStatusMessage = "Product not found.";
            return;
        }

        var cart = await LocalStorage.GetItemAsync<List<CartItem>>(CartKey) ?? new List<CartItem>();
        var existing = cart.FirstOrDefault(i => i.ProductId == productId);
        if (existing is not null)
            existing.Quantity++;
        else
            cart.Add(new CartItem { ProductId = product.Id, Name = product.Name, Description = product.Description, UnitPrice = product.Price, Quantity = 1 });

        await LocalStorage.SetItemAsync(CartKey, cart);
        Navigation.NavigateTo("/cart", true);
    }

    private async Task SubmitSupportAsync()
    {
        supportStatusMessage = null;

        var response = await Http.PostAsJsonAsync("api/commerce/support/my", supportRequest);
        if (!response.IsSuccessStatusCode)
        {
            supportStatusMessage = "Unable to send query.";
            return;
        }

        var createdQuery = await response.Content.ReadFromJsonAsync<SupportQueryDto>();
        supportStatusMessage = "Your ticket has been sent to admin.";
        supportRequest = new CreateSupportQueryRequest();
        activeSupportTicketFilter = SupportTicketFilter.Open;
        await LoadDashboardDataAsync();

        if (createdQuery is not null)
        {
            await OpenQueryThreadAsync(createdQuery.Id);
        }
    }

    private void ResolveMembership()
    {
        var activeOrder = orders
            .Where(order => string.Equals(order.Status, "Active", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(order => order.OrderedAtUtc)
            .FirstOrDefault();

        if (activeOrder is null)
        {
            currentPlanName = "No Plan";
            membershipMessage = "No active plan found for your account.";
            return;
        }

        currentPlanName = string.IsNullOrWhiteSpace(activeOrder.ProductName) ? "Active Plan" : activeOrder.ProductName;
        membershipMessage = $"You are currently on {currentPlanName}.";
    }

    private static string GetStatusCss(string? status)
    {
        var value = status?.Trim().ToLowerInvariant();
        return value switch
        {
            "completed" => "delivered",
            "delivered" => "delivered",
            "denied" => "cancelled",
            "cancelled" => "cancelled",
            "closed" => "closed",
            "open" => "open",
            "active" => "open",
            _ => "pending"
        };
    }

    private static bool CanDownloadInvoice(UserOrderDto order)
    {
        var value = order.Status?.Trim().ToLowerInvariant();
        return value is "completed" or "delivered";
    }

    private static bool IsClosedSupportTicket(string? status)
    {
        return string.Equals(status?.Trim(), "Closed", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetOrderStatusLabel(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "completed" => "Completed",
            "delivered" => "Delivered",
            "denied" => "Denied",
            "cancelled" => "Cancelled",
            "closed" => "Closed",
            "open" => "Open",
            "active" => "Active",
            _ => "Pending"
        };
    }

    private static string GetSupportStatusLabel(string? status)
    {
        return IsClosedSupportTicket(status) ? "Closed" : "Open";
    }

    private static bool MatchesSupportTicketFilter(SupportQueryDto query, SupportTicketFilter filter)
    {
        return filter switch
        {
            SupportTicketFilter.Closed => IsClosedSupportTicket(query.Status),
            _ => !IsClosedSupportTicket(query.Status)
        };
    }

    private static string GetSupportFilterLabel(SupportTicketFilter filter)
    {
        return filter switch
        {
            SupportTicketFilter.Closed => "Closed Tickets",
            _ => "Open Tickets"
        };
    }

    private void UpdateSupportQueryStatus(long queryId, string status)
    {
        var query = queries.FirstOrDefault(item => item.Id == queryId);
        if (query is not null)
        {
            query.Status = status;
        }
    }

