@page "/dashboard"
@implements IDisposable
@using System.Net
@using System.Text.RegularExpressions
@using Kohinoorea.Client.Services

<PageTitle>Kohinoorea User Dashboard</PageTitle>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  /* ── Theme tokens ─────────────────────────────────── */
  :root, body[data-theme="dark"] {
    --d-bg:           linear-gradient(135deg,#060810 0%,#0f1623 55%,#040609 100%);
    --d-glow1:        rgba(255,196,87,0.18);
    --d-glow2:        rgba(128,90,213,0.18);
    --d-text:         #f0f4ff;
    --d-muted:        #7b8fa8;
    --d-sidebar-bg:   rgba(6,9,18,0.82);
    --d-sidebar-border: rgba(255,255,255,0.07);
    --d-brand-sub:    #6b7fa0;
    --d-nav-text:     #b8c8de;
    --d-nav-hover:    rgba(255,255,255,0.08);
    --d-nav-border:   rgba(255,255,255,0.07);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.14),rgba(249,115,22,0.07));
    --d-plan-card-border: rgba(251,191,36,0.2);
    --d-plan-card-text: #c8d4e8;
    --d-profile-bg:   rgba(255,255,255,0.07);
    --d-profile-border: rgba(255,255,255,0.07);
    --d-card-bg:      rgba(255,255,255,0.06);
    --d-card-border:  rgba(255,255,255,0.08);
    --d-card-shimmer: rgba(255,255,255,0.025);
    --d-panel-bg:     rgba(255,255,255,0.06);
    --d-panel-border: rgba(255,255,255,0.08);
    --d-panel-shadow: 0 20px 80px rgba(0,0,0,0.28);
    --d-th-color:     #6b7fa0;
    --d-td-color:     #d1dce8;
    --d-row-border:   rgba(255,255,255,0.07);
    --d-product-bg:   rgba(255,255,255,0.05);
    --d-product-hover: rgba(255,255,255,0.09);
    --d-product-border: rgba(255,255,255,0.07);
    --d-product-img:  linear-gradient(135deg,#1a2235,#2a3a55);
    --d-product-desc: #6b7fa0;
    --d-ghost-bg:     rgba(15,23,42,0.6);
    --d-ghost-border: rgba(255,255,255,0.16);
    --d-ghost-text:   #c8d4e8;
    --d-query-bg:     rgba(255,255,255,0.05);
    --d-query-border: rgba(255,255,255,0.07);
    --d-form-bg:      rgba(255,255,255,0.05);
    --d-form-border:  rgba(255,255,255,0.07);
    --d-input-bg:     rgba(10,16,30,0.88);
    --d-input-border: rgba(255,255,255,0.09);
    --d-input-text:   #f0f4ff;
    --d-label-text:   #b8c8de;
    --d-empty-text:   #6b7fa0;
    --d-divider:      rgba(255,255,255,0.07);
    --d-stat-num:     #fbbf24;
  }

  body[data-theme="light"] {
    --d-bg:           linear-gradient(135deg,#eef2f9 0%,#faf7f0 55%,#f2eefb 100%);
    --d-glow1:        rgba(251,191,36,0.2);
    --d-glow2:        rgba(128,90,213,0.1);
    --d-text:         #111827;
    --d-muted:        #6b7280;
    --d-sidebar-bg:   rgba(255,255,255,0.88);
    --d-sidebar-border: rgba(0,0,0,0.09);
    --d-brand-sub:    #6b7280;
    --d-nav-text:     #374151;
    --d-nav-hover:    rgba(0,0,0,0.05);
    --d-nav-border:   rgba(0,0,0,0.05);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.1),rgba(249,115,22,0.05));
    --d-plan-card-border: rgba(251,191,36,0.3);
    --d-plan-card-text: #374151;
    --d-profile-bg:   rgba(0,0,0,0.04);
    --d-profile-border: rgba(0,0,0,0.08);
    --d-card-bg:      rgba(255,255,255,0.82);
    --d-card-border:  rgba(0,0,0,0.08);
    --d-card-shimmer: rgba(255,255,255,0.7);
    --d-panel-bg:     rgba(255,255,255,0.88);
    --d-panel-border: rgba(0,0,0,0.08);
    --d-panel-shadow: 0 8px 40px rgba(0,0,0,0.1);
    --d-th-color:     #6b7280;
    --d-td-color:     #374151;
    --d-row-border:   rgba(0,0,0,0.07);
    --d-product-bg:   rgba(255,255,255,0.75);
    --d-product-hover: rgba(255,255,255,0.95);
    --d-product-border: rgba(0,0,0,0.08);
    --d-product-img:  linear-gradient(135deg,#dde3f0,#c7d2e8);
    --d-product-desc: #6b7280;
    --d-ghost-bg:     rgba(255,255,255,0.7);
    --d-ghost-border: rgba(0,0,0,0.14);
    --d-ghost-text:   #374151;
    --d-query-bg:     rgba(255,255,255,0.7);
    --d-query-border: rgba(0,0,0,0.07);
    --d-form-bg:      rgba(255,255,255,0.75);
    --d-form-border:  rgba(0,0,0,0.07);
    --d-input-bg:     rgba(255,255,255,0.95);
    --d-input-border: rgba(0,0,0,0.12);
    --d-input-text:   #111827;
    --d-label-text:   #374151;
    --d-empty-text:   #6b7280;
    --d-divider:      rgba(0,0,0,0.07);
    --d-stat-num:     #d97706;
  }

  /* ── Reset ────────────────────────────────────────── */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Inter", sans-serif;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, var(--d-glow1), transparent 35%),
      radial-gradient(circle at top right, var(--d-glow2), transparent 35%),
      var(--d-bg);
    color: var(--d-text);
    transition: background 0.35s, color 0.25s;
  }

  /* ── Layout ───────────────────────────────────────── */
  .dashboard {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  /* ── Sidebar ──────────────────────────────────────── */
  .sidebar {
    padding: 28px 22px;
    background: var(--d-sidebar-bg);
    border-right: 1px solid var(--d-sidebar-border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: background 0.3s, border-color 0.3s;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 38px;
  }

  .brand-icon {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #111827;
    font-weight: 900;
    box-shadow: 0 10px 30px rgba(251,191,36,0.28);
  }

  .brand h1 {
    font-size: 20px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .brand p {
    font-size: 12px;
    color: var(--d-brand-sub);
    margin-top: 2px;
  }

  .nav-button {
    width: 100%;
    border: 0;
    color: var(--d-nav-text);
    background: transparent;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    margin-bottom: 8px;
    border-radius: 16px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: 0.25s ease;
    text-align: left;
  }

  .nav-button:hover,
  .nav-button.active {
    color: var(--d-text);
    background: var(--d-nav-hover);
    box-shadow: inset 0 0 0 1px var(--d-nav-border);
  }

  .sidebar-card {
    margin-top: 34px;
    padding: 20px;
    border-radius: 22px;
    background: var(--d-plan-card-bg);
    border: 1px solid var(--d-plan-card-border);
    transition: background 0.3s, border-color 0.3s;
  }

  .sidebar-card h3 {
    font-size: 15px;
    color: var(--d-text);
    margin-bottom: 8px;
  }

  .sidebar-card p {
    color: var(--d-plan-card-text);
    font-size: 13px;
    line-height: 1.6;
  }

  /* ── Main area ────────────────────────────────────── */
  .main {
    padding: 28px;
    overflow: hidden;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .topbar h2 {
    font-size: 32px;
    letter-spacing: -0.06em;
    color: var(--d-text);
  }

  .topbar p {
    color: var(--d-muted);
    margin-top: 6px;
  }

  .profile {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    border-radius: 999px;
    background: var(--d-profile-bg);
    border: 1px solid var(--d-profile-border);
    transition: background 0.3s, border-color 0.3s;
  }

  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fbbf24, #a855f7);
    display: grid;
    place-items: center;
    font-weight: 800;
    color: #fff;
  }

  .profile span {
    display: block;
    font-size: 13px;
    color: var(--d-muted);
  }

  /* ── Stat cards ───────────────────────────────────── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }

  .stat-card {
    position: relative;
    border: 1px solid var(--d-card-border);
    background: var(--d-card-bg);
    border-radius: 28px;
    padding: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-card::after {
    content: "";
    position: absolute;
    right: -35px;
    top: -35px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(251,191,36,0.1);
    pointer-events: none;
  }

  .stat-card:hover,
  .stat-card.active {
    transform: translateY(-6px);
    border-color: rgba(251,191,36,0.4);
    box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 0 0 1px rgba(251,191,36,0.1), inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-icon {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    font-size: 24px;
    background: var(--d-nav-hover);
    margin-bottom: 18px;
    border: 1px solid var(--d-card-border);
  }

  .stat-card h3 {
    font-size: 18px;
    margin-bottom: 8px;
    color: var(--d-text);
  }

  .stat-card p {
    color: var(--d-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .stat-number {
    margin-top: 18px;
    font-size: 30px;
    font-weight: 800;
    color: var(--d-stat-num);
  }

  /* ── Content panel ────────────────────────────────── */
  .content-panel {
    border: 1px solid var(--d-panel-border);
    background: var(--d-panel-bg);
    border-radius: 30px;
    padding: 26px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: var(--d-panel-shadow);
    animation: fadeIn 0.35s ease;
    transition: background 0.3s, border-color 0.3s;
  }

  .content-panel.support-maximized {
    height: calc(100vh - 225px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  @@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 22px;
  }

  .panel-header h3 {
    font-size: 24px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .section-intro {
    color: var(--d-muted);
    margin-top: 6px;
    line-height: 1.6;
    max-width: 760px;
  }

  .badge {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(34,197,94,0.11);
    color: #22c55e;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(34,197,94,0.22);
  }

  /* ── Table ────────────────────────────────────────── */
  .table-wrap {
    overflow: auto;
    max-height: 60vh;
    padding-right: 4px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 920px;
  }

  th, td {
    padding: 16px 14px;
    text-align: left;
    border-bottom: 1px solid var(--d-row-border);
    font-size: 14px;
    vertical-align: middle;
  }

  th {
    color: var(--d-th-color);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--d-panel-bg) 88%, transparent);
    backdrop-filter: blur(12px);
    z-index: 1;
  }

  td { color: var(--d-td-color); }

  /* ── Status pills ─────────────────────────────────── */
  .status {
    display: inline-flex;
    padding: 7px 11px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
  }

  .delivered { background: rgba(34,197,94,0.12);  color: #16a34a; }
  .pending   { background: rgba(251,191,36,0.12); color: #d97706; }
  .cancelled { background: rgba(248,113,113,0.12);color: #dc2626; }
  .open      { background: rgba(96,165,250,0.12); color: #2563eb; }
  .closed    { background: rgba(148,163,184,0.12);color: #6b7280; }

  body[data-theme="dark"] .delivered { color: #86efac; }
  body[data-theme="dark"] .pending   { color: #fde68a; }
  body[data-theme="dark"] .cancelled { color: #fca5a5; }
  body[data-theme="dark"] .open      { color: #93c5fd; }
  body[data-theme="dark"] .closed    { color: #cbd5e1; }

  /* ── Product grid ─────────────────────────────────── */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .product-card {
    padding: 18px;
    border-radius: 24px;
    border: 1px solid var(--d-product-border);
    background: var(--d-product-bg);
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
    box-shadow: inset 0 1px 0 var(--d-card-shimmer);
  }

  .product-card:hover {
    transform: translateY(-4px);
    background: var(--d-product-hover);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12), inset 0 1px 0 var(--d-card-shimmer);
  }

  .product-img {
    height: 150px;
    border-radius: 18px;
    background: var(--d-product-img);
    display: grid;
    place-items: center;
    font-size: 48px;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card h4 {
    margin-bottom: 8px;
    font-size: 16px;
    color: var(--d-text);
  }

  .product-card p {
    color: var(--d-product-desc);
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .price {
    color: #f59e0b;
    font-size: 18px;
    font-weight: 800;
  }

  /* ── Buttons ──────────────────────────────────────── */
  .buy-btn,
  .submit-btn {
    border: 0;
    padding: 10px 14px;
    border-radius: 14px;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #111827;
    font-weight: 800;
    cursor: pointer;
    transition: 0.2s ease;
    box-shadow: 0 4px 16px rgba(251,191,36,0.28);
  }

  .buy-btn:hover,
  .submit-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 22px rgba(251,191,36,0.38);
  }

  .ghost-btn {
    border: 1px solid var(--d-ghost-border);
    padding: 9px 13px;
    border-radius: 12px;
    background: var(--d-ghost-bg);
    color: var(--d-ghost-text);
    font-weight: 700;
    cursor: pointer;
    font-size: 13px;
    transition: background 0.2s, border-color 0.2s;
  }

  .ghost-btn:hover {
    border-color: rgba(251,191,36,0.35);
    color: #f59e0b;
  }

  .order-table-actions {
    display: flex;
    justify-content: flex-start;
  }

  /* ── Support ──────────────────────────────────────── */
  .support-layout {
    display: grid;
    grid-template-columns: minmax(300px, 360px) minmax(0, 1fr);
    gap: 22px;
    min-height: 72vh;
    align-items: start;
  }

  .support-layout.maximized {
    grid-template-columns: minmax(300px, 360px) minmax(0, 1fr);
  }

  .support-layout > * { min-height: 0; }

  .support-layout.maximized .support-create-card { display: none; }

  .support-sidebar-panel,
  .support-thread-panel {
    padding: 20px;
    border-radius: 24px;
    background: var(--d-form-bg);
    border: 1px solid var(--d-form-border);
    display: grid;
    gap: 16px;
    min-height: 0;
    transition: background 0.3s, border-color 0.3s;
  }

  .support-sidebar-panel {
    display: flex;
    flex-direction: column;
    align-self: start;
  }

  .support-thread-panel {
    min-height: 72vh;
  }

  .support-premium-card {
    padding: 18px;
    border-radius: 22px;
    background:
      radial-gradient(circle at top right, rgba(251,191,36,0.18), transparent 42%),
      linear-gradient(135deg, rgba(251,191,36,0.12), rgba(168,85,247,0.12));
    border: 1px solid rgba(251,191,36,0.22);
    display: grid;
    gap: 12px;
  }

  .support-premium-card h4 {
    color: var(--d-text);
    font-size: 18px;
  }

  .support-premium-card p {
    color: var(--d-label-text);
    line-height: 1.6;
    font-size: 13px;
  }

  .support-stats {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .support-stat {
    min-width: 110px;
    padding: 12px 14px;
    border-radius: 16px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.08);
    display: grid;
    gap: 4px;
  }

  body[data-theme="light"] .support-stat {
    background: rgba(255,255,255,0.55);
    border-color: rgba(0,0,0,0.06);
  }

  .support-stat strong {
    color: var(--d-text);
    font-size: 19px;
  }

  .support-stat span {
    color: var(--d-muted);
    font-size: 12px;
    font-weight: 600;
  }

  .support-tabs {
    display: flex;
    gap: 10px;
  }

  .support-tab {
    flex: 1;
    border: 1px solid var(--d-ghost-border);
    padding: 12px 14px;
    border-radius: 16px;
    background: var(--d-ghost-bg);
    color: var(--d-ghost-text);
    cursor: pointer;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    transition: 0.2s ease;
  }

  .support-tab strong {
    font-size: 13px;
    letter-spacing: 0.01em;
  }

  .support-tab span {
    min-width: 28px;
    height: 28px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(255,255,255,0.08);
    font-size: 12px;
  }

  body[data-theme="light"] .support-tab span {
    background: rgba(0,0,0,0.05);
  }

  .support-tab.active,
  .support-tab:hover {
    color: var(--d-text);
    border-color: rgba(251,191,36,0.35);
    box-shadow: 0 12px 28px rgba(0,0,0,0.12);
  }

  .support-tab.active {
    background: linear-gradient(135deg, rgba(251,191,36,0.18), rgba(249,115,22,0.12));
  }

  .query-list {
    display: grid;
    gap: 14px;
    overflow-y: auto;
    padding-right: 6px;
    min-height: 220px;
    max-height: 360px;
    align-content: start;
  }

  .support-layout.maximized .query-list {
    max-height: 460px;
  }

  .ticket-card {
    border: 1px solid var(--d-query-border);
    border-radius: 20px;
    background: var(--d-query-bg);
    padding: 18px;
    display: grid;
    gap: 12px;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    color: inherit;
  }

  .ticket-card:hover,
  .ticket-card.active {
    transform: translateY(-2px);
    border-color: rgba(251,191,36,0.32);
    box-shadow: 0 14px 28px rgba(0,0,0,0.12);
  }

  .ticket-card.active {
    background: color-mix(in srgb, var(--d-query-bg) 82%, rgba(251,191,36,0.16));
  }

  .ticket-card-top {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
  }

  .ticket-card-heading {
    display: grid;
    gap: 6px;
  }

  .ticket-title {
    color: var(--d-text);
    font-size: 16px;
    font-weight: 700;
  }

  .ticket-ticket-id {
    color: var(--d-muted);
    font-size: 12px;
    font-weight: 600;
  }

  .ticket-preview {
    color: var(--d-muted);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ticket-chip {
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid var(--d-nav-border);
    background: color-mix(in srgb, var(--d-nav-hover) 82%, transparent);
    color: var(--d-label-text);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .ticket-card-actions {
    display: flex;
    justify-content: flex-end;
  }

  .thread-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--d-divider);
  }

  .thread-meta h4 {
    color: var(--d-text);
    margin-bottom: 6px;
    font-size: 20px;
  }

  .thread-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .thread-stack {
    flex: 1 1 auto;
    min-height: 320px;
    max-height: 46vh;
    overflow-y: auto;
    padding: 18px;
    border-radius: 22px;
    border: 1px solid var(--d-query-border);
    background:
      radial-gradient(circle at top right, rgba(37,99,235,0.08), transparent 34%),
      linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    display: grid;
    gap: 12px;
    align-content: start;
  }

  .thread-placeholder {
    min-height: 100%;
    border-radius: 22px;
    border: 1px dashed var(--d-form-border);
    background: color-mix(in srgb, var(--d-form-bg) 85%, transparent);
    display: grid;
    place-items: center;
    padding: 28px;
    text-align: center;
  }

  .thread-placeholder h4 {
    color: var(--d-text);
    margin-bottom: 10px;
    font-size: 20px;
  }

  .thread-placeholder p {
    color: var(--d-muted);
    line-height: 1.7;
    max-width: 420px;
  }

  .chat-bubble {
    max-width: min(84%, 520px);
    padding: 12px 14px;
    border-radius: 16px;
    font-size: 13px;
    line-height: 1.6;
    white-space: pre-wrap;
    box-shadow: 0 8px 22px rgba(0,0,0,0.08);
  }

  .chat-bubble.user {
    justify-self: start;
    background: rgba(251,191,36,0.18);
    border: 1px solid rgba(251,191,36,0.3);
    color: #d97706;
    border-bottom-left-radius: 6px;
  }

  body[data-theme="dark"] .chat-bubble.user {
    color: #fde68a;
  }

  .chat-bubble.admin {
    justify-self: end;
    background: rgba(96,165,250,0.12);
    border: 1px solid rgba(96,165,250,0.22);
    color: #2563eb;
    border-bottom-right-radius: 6px;
  }

  body[data-theme="dark"] .chat-bubble.admin {
    color: #bfdbfe;
    background: rgba(96,165,250,0.16);
  }

  .chat-meta {
    display: block;
    margin-top: 6px;
    font-size: 11px;
    opacity: 0.75;
  }

  .support-chat-composer {
    display: grid;
    gap: 12px;
  }

  .support-chat-composer textarea {
    margin-bottom: 0;
    min-height: 110px;
    width: 100%;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    color: var(--d-input-text);
    padding: 13px 14px;
    border-radius: 16px;
    outline: none;
    font-size: 14px;
    resize: vertical;
    transition: border-color 0.2s, background 0.2s;
  }

  .support-chat-composer textarea:focus {
    border-color: rgba(251,191,36,0.4);
  }

  .composer-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .composer-actions .empty-note,
  .composer-actions .summary-caption {
    margin: 0;
  }

  .support-create-card {
    margin-top: 0;
  }

  .support-form {
    padding: 20px;
    border-radius: 24px;
    background: var(--d-form-bg);
    border: 1px solid var(--d-form-border);
    transition: background 0.3s, border-color 0.3s;
  }

  .support-form h4 {
    color: var(--d-text);
    margin-bottom: 8px;
    font-size: 18px;
  }

  .support-form .summary-caption {
    margin-bottom: 14px;
  }

  .support-form label {
    display: block;
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 700;
    color: var(--d-label-text);
  }

  .support-form input,
  .support-form textarea,
  .support-form select {
    width: 100%;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    color: var(--d-input-text);
    padding: 13px 14px;
    border-radius: 16px;
    outline: none;
    margin-bottom: 14px;
    font-size: 14px;
    transition: border-color 0.2s, background 0.2s;
  }

  .support-form input:focus,
  .support-form textarea:focus,
  .support-form select:focus {
    border-color: rgba(251,191,36,0.4);
  }

  .support-form textarea {
    min-height: 130px;
    resize: vertical;
  }

  .query-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--d-muted);
  }

  .support-closed-note {
    margin-bottom: 0;
  }

  .ticket-empty-state {
    padding: 20px;
    border-radius: 18px;
    border: 1px dashed var(--d-query-border);
    color: var(--d-empty-text);
    line-height: 1.7;
  }

  .thread-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .query-card {
    padding: 18px;
    border-radius: 20px;
    background: var(--d-query-bg);
    border: 1px solid var(--d-query-border);
    transition: background 0.3s, border-color 0.3s;
  }

  /* ── Misc ─────────────────────────────────────────── */
  .empty-note {
    color: var(--d-empty-text);
    line-height: 1.7;
  }

  .summary-caption {
    color: var(--d-empty-text);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  @@media (max-width: 1100px) {
    .cards,
    .product-grid,
    .support-layout {
      grid-template-columns: 1fr;
    }

    .support-layout,
    .support-layout.maximized {
      min-height: auto;
    }

    .support-sidebar-panel,
    .support-thread-panel {
      min-height: 420px;
    }

    .composer-actions,
    .thread-meta {
      flex-direction: column;
      align-items: stretch;
    }
  }

  @@media (max-width: 820px) {
    .dashboard { grid-template-columns: 1fr; }
    .sidebar { position: static; }
    .topbar { align-items: flex-start; flex-direction: column; }
  }
</style>

@if (canRenderDashboard)
{
<div class="dashboard">
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-icon">K</div>
      <div>
        <h1>Kohinoorea</h1>
        <p>Premium User Panel</p>
      </div>
    </div>

    <button class="nav-button @(activeSection == DashboardSection.Overview ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Overview)">🏠 Overview</button>
    <button class="nav-button @(activeSection == DashboardSection.Orders ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Orders)">📦 Orders</button>
    <button class="nav-button @(activeSection == DashboardSection.Products ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Products)">💎 Products</button>
    <button class="nav-button @(activeSection == DashboardSection.Support ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Support)">🎧 Support</button>

    <div class="sidebar-card">
      <h3>@CurrentPlanName</h3>
      <p>@MembershipMessage</p>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div>
        <h2>@PageTitle</h2>
        <p>Manage your orders, discover admin-posted products, and contact support.</p>
      </div>
      <div class="profile">
        <div class="avatar">@AvatarInitial</div>
        <div>
          <strong>@CurrentPlanName</strong>
          <span>@ProfileEmail</span>
        </div>
      </div>
    </header>

    <section class="cards">
      <div class="stat-card @(activeSection == DashboardSection.Orders ? "active" : null)" @onclick="() => NavigateToSection(DashboardSection.Orders)">
        <div class="stat-icon">📦</div>
        <h3>Orders</h3>
        <p>View your ordered items and complete transaction history.</p>
        <div class="stat-number">@orders.Count</div>
      </div>

      <div class="stat-card @(activeSection == DashboardSection.Products ? "active" : null)" @onclick="() => NavigateToSection(DashboardSection.Products)">
        <div class="stat-icon">💎</div>
        <h3>Products</h3>
        <p>Browse premium products posted by the admin.</p>
        <div class="stat-number">@products.Count</div>
      </div>

      <div class="stat-card @(activeSection == DashboardSection.Support ? "active" : null)" @onclick="() => NavigateToSection(DashboardSection.Support)">
        <div class="stat-icon">🎧</div>
        <h3>Support</h3>
        <p>See your queries or send a custom question to admin.</p>
        <div class="stat-number">@queries.Count</div>
      </div>
    </section>

    <section id="@CurrentSectionAnchor" class="content-panel @(activeSection == DashboardSection.Support && isSupportMaximized ? "support-maximized" : null)">
      @if (activeSection == DashboardSection.Overview)
      {
        <div class="panel-header">
          <h3>Dashboard Overview</h3>
          <span class="badge">@(currentPlanName == "No Plan" ? "No Active Plan" : currentPlanName)</span>
        </div>
        <p class="empty-note">
          Select Orders to view your transaction history. Select Products to view admin products and add to cart. Select Support to view/send your queries.
        </p>
      }
      else if (activeSection == DashboardSection.Orders)
      {
        <div class="panel-header">
          <h3>Orders & Transaction History</h3>
          <span class="badge">Secure Records</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(orderStatusMessage))
        {
          <p class="summary-caption">@orderStatusMessage</p>
        }
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Product</th>
                <th>Date</th>
                <th>Amount</th>
                <th>Payment</th>
                <th>Status</th>
                <th>Invoice</th>
              </tr>
            </thead>
            <tbody>
              @if (orders.Count == 0)
              {
                <tr><td colspan="7">No orders found.</td></tr>
              }
              else
              {
                @foreach (var order in orders)
                {
                  <tr>
                    <td><strong>ORD-@order.OrderId</strong></td>
                    <td>@order.ProductName</td>
                    <td>@order.OrderedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>@CurrencyContext.FormatPriceForCountry(order.TotalAmount, "US")</td>
                    <td>@(string.IsNullOrWhiteSpace(order.PaymentMethod) ? "Card" : order.PaymentMethod)</td>
                    <td><span class="status @GetStatusCss(order.Status)">@GetOrderStatusLabel(order.Status)</span></td>
                    <td>
                      <div class="order-table-actions">
                        @if (CanDownloadInvoice(order))
                        {
                          <button class="ghost-btn" type="button" @onclick="() => DownloadInvoiceAsync(order)">Download Invoice</button>
                        }
                        else
                        {
                          <button class="ghost-btn" type="button" disabled title="Invoice becomes available after the order is completed.">Available After Completion</button>
                        }
                      </div>
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      }
      else if (activeSection == DashboardSection.Products)
      {
        <div class="panel-header">
          <h3>Premium Product Collection</h3>
          <span class="badge">Posted by Admin</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(productStatusMessage))
        {
          <p class="summary-caption">@productStatusMessage</p>
        }
        <div class="product-grid">
          @if (products.Count == 0)
          {
            <p class="empty-note">No products posted yet.</p>
          }
          else
          {
            @foreach (var product in products)
            {
              <div class="product-card">
                <div class="product-img">
                  <img src="@GetProductImageUrl(product)" alt="@product.Name" loading="lazy" />
                </div>
                <h4>@product.Name</h4>
                @{
                  var descRaw = product.Description ?? string.Empty;
                  var descMatch = Regex.Match(descRaw, @"<p>(.*?)</p>", RegexOptions.Singleline);
                  var descText = descMatch.Success
                    ? currency.ReplacePricesInTextFromUsd(descMatch.Groups[1].Value.Trim())
                    : (string.IsNullOrWhiteSpace(descRaw) ? "No description available." : currency.ReplacePricesInTextFromUsd(descRaw));
                }
                <p>@descText</p>
                <div class="price-row">
                  <span class="price">@CurrencyContext.FormatPriceForCountry(product.Price, product.CountryCode ?? "US")</span>
                  <div style="display:flex; gap:8px;">
                    <button class="buy-btn" type="button" @onclick="() => AddToCartAsync(product.Id, product.Name)">Add to Cart</button>
                    <button class="buy-btn" type="button" style="background:linear-gradient(135deg,#a855f7,#7c3aed);" @onclick="() => NavigateToBuyProduct(product.Id)">Buy Now</button>
                  </div>
                </div>
              </div>
            }
          }
        </div>
      }
      else if (activeSection == DashboardSection.Support)
      {
        var selectedQuery = SelectedSupportQuery;
        var visibleQueries = FilteredSupportQueries.ToList();
        <div class="panel-header">
          <div>
            <h3>Premium Support Desk</h3>
            <p class="section-intro">Switch between open and closed tickets, then continue each conversation in a chat-style workspace.</p>
          </div>
          <div style="display:flex; gap:10px; align-items:center;">
            <span class="badge">Priority Support</span>
            <button class="ghost-btn" type="button" @onclick="ToggleSupportMaximize">@(isSupportMaximized ? "Minimize" : "Focus Chat")</button>
          </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(supportStatusMessage))
        {
          <p class="summary-caption">@supportStatusMessage</p>
        }
        <div class="support-layout @(isSupportMaximized ? "maximized" : null)">
          <div class="support-sidebar-panel">
            <div class="support-premium-card">
              <h4>Premium help, tracked by ticket</h4>
              <p>Select any ticket to continue the conversation like chat, or create a fresh ticket for a new issue.</p>
              <div class="support-stats">
                <div class="support-stat">
                  <strong>@OpenSupportQueryCount</strong>
                  <span>Open Tickets</span>
                </div>
                <div class="support-stat">
                  <strong>@ClosedSupportQueryCount</strong>
                  <span>Closed Tickets</span>
                </div>
              </div>
            </div>

            <div class="support-tabs" role="tablist" aria-label="Support ticket filters">
              <button class="support-tab @(activeSupportTicketFilter == SupportTicketFilter.Open ? "active" : null)" type="button" @onclick="() => SelectSupportTicketFilter(SupportTicketFilter.Open)">
                <strong>Open</strong>
                <span>@OpenSupportQueryCount</span>
              </button>
              <button class="support-tab @(activeSupportTicketFilter == SupportTicketFilter.Closed ? "active" : null)" type="button" @onclick="() => SelectSupportTicketFilter(SupportTicketFilter.Closed)">
                <strong>Closed</strong>
                <span>@ClosedSupportQueryCount</span>
              </button>
            </div>

            <div class="query-list">
              @if (visibleQueries.Count == 0)
              {
                <div class="ticket-empty-state">No @GetSupportFilterLabel(activeSupportTicketFilter).ToLowerInvariant() tickets yet.</div>
              }
              else
              {
                @foreach (var query in visibleQueries)
                {
                  <div class="ticket-card @(selectedQuery?.Id == query.Id ? "active" : null)">
                    <div class="ticket-card-top">
                      <div class="ticket-card-heading">
                        <div class="ticket-title">@query.Subject</div>
                        <span class="ticket-ticket-id">Ticket #@query.Id</span>
                      </div>
                      <span class="status @GetStatusCss(query.Status)">@GetSupportStatusLabel(query.Status)</span>
                    </div>
                    <p class="ticket-preview">@query.Message</p>
                    <div class="query-meta">
                      <span class="ticket-chip">@query.Category</span>
                      <span>@query.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                    </div>
                    <div class="ticket-card-actions">
                      <button class="ghost-btn" type="button" @onclick="() => OpenQueryThreadAsync(query.Id)">
                        @(selectedQuery?.Id == query.Id ? "Chat Open" : "Open Chat")
                      </button>
                    </div>
                  </div>
                }
              }
            </div>

            <EditForm class="support-form support-create-card" Model="supportRequest" OnValidSubmit="SubmitSupportAsync">
              <DataAnnotationsValidator />
              <h4>Create New Ticket</h4>
              <p class="summary-caption">Start a fresh conversation with the support team for orders, payments, products, or setup help.</p>
              <label>Subject</label>
              <InputText @bind-Value="supportRequest.Subject" placeholder="Enter ticket subject" />

              <label>Category</label>
              <InputSelect @bind-Value="supportRequest.Category">
                <option value="Order">Order</option>
                <option value="Payment">Payment</option>
                <option value="Product">Product</option>
                <option value="General">General</option>
              </InputSelect>

              <label>Your Question</label>
              <InputTextArea @bind-Value="supportRequest.Message" placeholder="Write your question for admin..." />

              <button class="submit-btn" type="submit">Create Ticket</button>
            </EditForm>
          </div>

          <div class="support-thread-panel">
            @if (selectedQuery is null)
            {
              <div class="thread-placeholder">
                <div>
                  <h4>Select a ticket</h4>
                  <p>Pick any open or closed ticket from the left to view the full conversation in a WhatsApp-style chat layout.</p>
                </div>
              </div>
            }
            else
            {
              <div class="thread-meta">
                <div>
                  <div class="thread-badges">
                    <span class="status @GetStatusCss(selectedQuery.Status)">@GetSupportStatusLabel(selectedQuery.Status)</span>
                    <span class="ticket-chip">@selectedQuery.Category</span>
                  </div>
                  <h4>@selectedQuery.Subject</h4>
                  <p class="summary-caption">Ticket #@selectedQuery.Id • Opened @selectedQuery.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</p>
                </div>
                <div class="thread-actions">
                  <button class="ghost-btn" type="button" @onclick="CloseQueryThread">Close Chat</button>
                </div>
              </div>

              <div class="thread-stack">
                @if (activeQueryMessages.Count == 0)
                {
                  <p class="empty-note">No replies yet.</p>
                }
                else
                {
                  @foreach (var message in activeQueryMessages)
                  {
                    var bubbleCss = string.Equals(message.SenderRole, AuthRoles.Admin, StringComparison.OrdinalIgnoreCase) ? "admin" : "user";
                    <div class="chat-bubble @bubbleCss">
                      @message.Message
                      <span class="chat-meta">@message.SenderRole • @message.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                    </div>
                  }
                }
              </div>

              <EditForm class="support-chat-composer" Model="replyRequest" OnValidSubmit="SubmitReplyAsync">
                <DataAnnotationsValidator />
                @if (IsClosedSupportTicket(selectedQuery.Status))
                {
                  <p class="summary-caption support-closed-note">This ticket is currently closed. Sending a message will reopen it and move it back to Open Tickets.</p>
                }
                <InputTextArea Value="@replyRequest.Message"
                               ValueChanged="OnReplyMessageChangedAsync"
                               ValueExpression="@(() => replyRequest.Message)"
                               placeholder="Type your message..." />
                @if (!string.IsNullOrWhiteSpace(realtimeTypingLine))
                {
                  <p class="empty-note" style="margin-top:6px;">@realtimeTypingLine</p>
                }
                <div class="composer-actions">
                  <p class="empty-note">Admin replies stay inside this thread so your full support history is always visible.</p>
                  <button class="submit-btn" type="submit">@(IsClosedSupportTicket(selectedQuery.Status) ? "Send & Reopen" : "Send Message")</button>
                </div>
              </EditForm>
            }
          </div>
        </div>
      }
    </section>
  </main>
</div>
}

@inject HttpClient Http
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS

@code {
    private CurrencyContext currency = CurrencyContext.FromCountryCode("US");
    private enum DashboardSection
    {
        Overview,
        Orders,
        Products,
        Support
    }

    private enum SupportTicketFilter
    {
        Open,
        Closed
    }

    private readonly List<UserOrderDto> orders = new();
    private readonly List<ProductDto> products = new();
    private readonly List<SupportQueryDto> queries = new();
    private readonly List<SupportQueryMessageDto> activeQueryMessages = new();
    private CreateSupportQueryRequest supportRequest = new();
    private CreateSupportQueryMessageRequest replyRequest = new();

    private bool canRenderDashboard;
    private DashboardSection activeSection = DashboardSection.Overview;
    private string profileEmail = string.Empty;
    private string currentPlanName = "No Plan";
    private string membershipMessage = "No active plan found for your account.";
    private string? productStatusMessage;
    private string? orderStatusMessage;
    private string? supportStatusMessage;
    private bool isSupportMaximized;
    private long? expandedQueryId;
    private SupportTicketFilter activeSupportTicketFilter = SupportTicketFilter.Open;
    private string? pendingScrollAnchor;

    private IJSObjectReference? supportRealtimeModule;
    private IJSObjectReference? supportRealtimeInstance;
    private DotNetObjectReference<Dashboard>? supportRealtimeDotNetRef;
    private string realtimeTypingLine = string.Empty;
    private DateTime lastRealtimeTypingPingUtc = DateTime.MinValue;
    private long? currentUserId;
    private bool currentUserIsAdmin;

    private string ProfileEmail => profileEmail;
    private string CurrentPlanName => currentPlanName;
    private string MembershipMessage => membershipMessage;
    private string PageTitle => activeSection switch
    {
        DashboardSection.Orders => "Your Orders",
        DashboardSection.Products => "Admin Posted Products",
        DashboardSection.Support => "Support Center",
        _ => "Welcome back, User"
    };

    private string AvatarInitial => string.IsNullOrWhiteSpace(profileEmail)
        ? "U"
        : profileEmail.Trim()[0].ToString().ToUpperInvariant();

    private string CurrentSectionAnchor => GetSectionHash(activeSection);
    private SupportQueryDto? SelectedSupportQuery => expandedQueryId.HasValue
        ? queries.FirstOrDefault(query => query.Id == expandedQueryId.Value)
        : null;
    private IEnumerable<SupportQueryDto> FilteredSupportQueries => queries
        .Where(query => MatchesSupportTicketFilter(query, activeSupportTicketFilter))
        .OrderByDescending(query => query.CreatedAtUtc);
    private int OpenSupportQueryCount => queries.Count(query => !IsClosedSupportTicket(query.Status));
    private int ClosedSupportQueryCount => queries.Count(query => IsClosedSupportTicket(query.Status));

    protected override async Task OnInitializedAsync()
    {
      Navigation.LocationChanged += HandleLocationChanged;

        currency = await CurrencyContext.ResolveAsync(Http, LocalStorage);

        var authToken = await LocalStorage.GetItemAsync<string>("authToken");
        (currentUserId, currentUserIsAdmin) = ResolveRealtimeIdentity(authToken);

        var meResponse = await Http.GetAsync("api/auth/me");
        if (!meResponse.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        var me = await meResponse.Content.ReadFromJsonAsync<AuthResponse>();
        profileEmail = me?.Email ?? string.Empty;

        await LoadDashboardDataAsync();
        ApplySectionFromUri(Navigation.Uri, shouldQueueScroll: true);
        canRenderDashboard = true;
    }

      protected override async Task OnAfterRenderAsync(bool firstRender)
      {
        if (!string.IsNullOrWhiteSpace(pendingScrollAnchor))
        {
          var anchor = pendingScrollAnchor;
          pendingScrollAnchor = null;
          await JS.InvokeVoidAsync("eval", $"document.getElementById('{anchor}')?.scrollIntoView({{ behavior: 'smooth', block: 'start' }});");
        }

        await base.OnAfterRenderAsync(firstRender);
      }

    private void SetSection(DashboardSection section)
    {
        activeSection = section;
        if (section != DashboardSection.Support)
        {
            isSupportMaximized = false;
            expandedQueryId = null;
            activeQueryMessages.Clear();
            replyRequest = new CreateSupportQueryMessageRequest();
        }
    }

        private void NavigateToSection(DashboardSection section)
        {
          SetSection(section);
          pendingScrollAnchor = GetSectionHash(section);
          Navigation.NavigateTo($"/dashboard#{GetSectionHash(section)}", replace: true);
        }

        private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
        {
          ApplySectionFromUri(e.Location, shouldQueueScroll: true);
          _ = InvokeAsync(StateHasChanged);
        }

        private void ApplySectionFromUri(string uri, bool shouldQueueScroll)
        {
          var fragment = Navigation.ToAbsoluteUri(uri).Fragment.TrimStart('#').ToLowerInvariant();
          var section = fragment switch
          {
            "orders" => DashboardSection.Orders,
            "products" => DashboardSection.Products,
            "support" => DashboardSection.Support,
            _ => DashboardSection.Overview
          };

          SetSection(section);
          if (shouldQueueScroll)
          {
            pendingScrollAnchor = GetSectionHash(section);
          }
        }

        private static string GetSectionHash(DashboardSection section)
        {
          return section switch
          {
            DashboardSection.Orders => "orders",
            DashboardSection.Products => "products",
            DashboardSection.Support => "support",
            _ => "overview"
          };
        }

        public void Dispose()
        {
          Navigation.LocationChanged -= HandleLocationChanged;
        }

    private void ToggleSupportMaximize()
    {
        isSupportMaximized = !isSupportMaximized;
    }

    private void SelectSupportTicketFilter(SupportTicketFilter filter)
    {
        activeSupportTicketFilter = filter;

        var selectedQuery = SelectedSupportQuery;
        if (selectedQuery is not null && !MatchesSupportTicketFilter(selectedQuery, filter))
        {
            CloseQueryThread();
        }
    }

    private async Task OpenQueryThreadAsync(long queryId)
    {
        expandedQueryId = queryId;
        replyRequest = new CreateSupportQueryMessageRequest();
        await LoadThreadMessagesAsync(queryId);
        var ownerUserId = SelectedSupportQuery?.UserId ?? currentUserId;
        if (ownerUserId.HasValue)
        {
            await StartSupportRealtimeAsync(ownerUserId.Value);
        }
    }

    private void CloseQueryThread()
    {
        expandedQueryId = null;
        activeQueryMessages.Clear();
        replyRequest = new CreateSupportQueryMessageRequest();
        realtimeTypingLine = string.Empty;
        _ = StopSupportRealtimeAsync();
    }

    private async Task LoadThreadMessagesAsync(long queryId)
    {
        var response = await Http.GetAsync($"api/commerce/support/my/{queryId}/messages");
        if (!response.IsSuccessStatusCode)
        {
            supportStatusMessage = "Unable to load query conversation.";
            activeQueryMessages.Clear();
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<List<SupportQueryMessageDto>>();
        activeQueryMessages.Clear();
        activeQueryMessages.AddRange(payload ?? Enumerable.Empty<SupportQueryMessageDto>());
    }

    private async Task SubmitReplyAsync()
    {
        if (!expandedQueryId.HasValue)
        {
            return;
        }

        var queryId = expandedQueryId.Value;
        var messageText = replyRequest.Message?.Trim() ?? string.Empty;
        var wasClosed = IsClosedSupportTicket(SelectedSupportQuery?.Status);
        var response = await Http.PostAsJsonAsync($"api/commerce/support/my/{queryId}/messages", replyRequest);
        if (!response.IsSuccessStatusCode)
        {
            supportStatusMessage = "Unable to send reply.";
            return;
        }

        if (wasClosed)
        {
            UpdateSupportQueryStatus(queryId, "Open");
            activeSupportTicketFilter = SupportTicketFilter.Open;
            supportStatusMessage = "Reply sent and ticket reopened.";
        }
        else
        {
            supportStatusMessage = "Reply sent.";
        }

        replyRequest = new CreateSupportQueryMessageRequest();
        await LoadThreadMessagesAsync(queryId);
        await PublishSupportRealtimeAsync(queryId, messageText);
    }

    private async Task OnReplyMessageChangedAsync(string value)
    {
        replyRequest.Message = value;

        if (!expandedQueryId.HasValue || supportRealtimeInstance is null)
        {
            return;
        }

        var now = DateTime.UtcNow;
        if (now - lastRealtimeTypingPingUtc < TimeSpan.FromSeconds(2))
        {
            return;
        }

        lastRealtimeTypingPingUtc = now;
        try
        {
            await supportRealtimeInstance.InvokeVoidAsync("setTyping", !string.IsNullOrWhiteSpace(replyRequest.Message));
        }
        catch
        {
        }
    }

    private async Task EnsureSupportRealtimeModuleAsync()
    {
        if (supportRealtimeModule is not null)
        {
            return;
        }

        supportRealtimeDotNetRef ??= DotNetObjectReference.Create(this);
        supportRealtimeModule = await JS.InvokeAsync<IJSObjectReference>("import", "./assets/js/firebase-support-chat.js");
    }

    private async Task StartSupportRealtimeAsync(long ownerUserId)
    {
        await EnsureSupportRealtimeModuleAsync();

        await StopSupportRealtimeAsync();
        realtimeTypingLine = string.Empty;

        var display = string.IsNullOrWhiteSpace(ProfileEmail) ? "User" : ProfileEmail.Trim();
        var options = new
        {
            clientId = (string?)null,
            role = currentUserIsAdmin ? "admin" : "user",
            displayName = display
        };

        supportRealtimeInstance = await supportRealtimeModule!.InvokeAsync<IJSObjectReference>(
            "createSupportChat",
            supportRealtimeDotNetRef!,
            $"ticket-{ownerUserId}",
            options);
    }

    private static (long? UserId, bool IsAdmin) ResolveRealtimeIdentity(string? token)
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            return (null, false);
        }

        try
        {
            var handler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
            if (!handler.CanReadToken(token))
            {
                return (null, false);
            }

            var jwt = handler.ReadJwtToken(token);
            var role = jwt.Claims.FirstOrDefault(c => string.Equals(c.Type, "role", StringComparison.OrdinalIgnoreCase))?.Value
                       ?? jwt.Claims.FirstOrDefault(c => c.Type.EndsWith("/role", StringComparison.OrdinalIgnoreCase))?.Value;
            var isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);

            var userIdValue = jwt.Claims.FirstOrDefault(c => c.Type.EndsWith("/nameidentifier", StringComparison.OrdinalIgnoreCase))?.Value
                              ?? jwt.Claims.FirstOrDefault(c => string.Equals(c.Type, "sub", StringComparison.OrdinalIgnoreCase))?.Value;

            return long.TryParse(userIdValue, out var id) ? (id, isAdmin) : (null, isAdmin);
        }
        catch
        {
            return (null, false);
        }
    }

    private async Task StopSupportRealtimeAsync()
    {
        if (supportRealtimeInstance is not null)
        {
            try { await supportRealtimeInstance.InvokeVoidAsync("dispose"); } catch { }
            try { await supportRealtimeInstance.DisposeAsync(); } catch { }
            supportRealtimeInstance = null;
        }
    }

    private async Task PublishSupportRealtimeAsync(long queryId, string text)
    {
        if (supportRealtimeInstance is null)
        {
            return;
        }

        try
        {
            await supportRealtimeInstance.InvokeVoidAsync("sendMessage", text);
            await supportRealtimeInstance.InvokeVoidAsync("setTyping", false);
        }
        catch
        {
            supportStatusMessage = "Realtime update blocked (check Firebase rules/auth).";
        }
    }

    public sealed class SupportRealtimeMessage
    {
        public string Id { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
        public string SenderRole { get; set; } = "user";
        public string SenderName { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public long? CreatedAt { get; set; }
    }

    public sealed class SupportTypingUser
    {
        public string ClientId { get; set; } = string.Empty;
        public string Role { get; set; } = "user";
        public string DisplayName { get; set; } = string.Empty;
    }

    [JSInvokable]
    public async Task OnMessage(SupportRealtimeMessage message)
    {
        if (!expandedQueryId.HasValue)
        {
            return;
        }

        // Another party posted (after saving in DB); refresh the SQL-backed thread for canonical ordering/ids.
        await LoadThreadMessagesAsync(expandedQueryId.Value);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnTyping(List<SupportTypingUser> typing)
    {
        if (typing is null || typing.Count == 0)
        {
            realtimeTypingLine = string.Empty;
        }
        else
        {
            var names = typing
                .Select(t => string.IsNullOrWhiteSpace(t.DisplayName) ? t.Role : t.DisplayName)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Take(1)
                .ToList();

            realtimeTypingLine = names.Count == 0 ? "Support is typing…" : $"{names[0]} is typing…";
        }

        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        await StopSupportRealtimeAsync();
        if (supportRealtimeModule is not null)
        {
            try { await supportRealtimeModule.DisposeAsync(); } catch { }
            supportRealtimeModule = null;
        }
        supportRealtimeDotNetRef?.Dispose();
        supportRealtimeDotNetRef = null;
    }

    private async Task LoadDashboardDataAsync()
    {
        productStatusMessage = null;
        orderStatusMessage = null;
        supportStatusMessage = null;

        var ordersTask = Http.GetAsync("api/commerce/orders/my");
        var productsTask = Http.GetAsync("api/commerce/products");
        var queriesTask = Http.GetAsync("api/commerce/support/my");

        await Task.WhenAll(ordersTask, productsTask, queriesTask);

        var ordersResponse = await ordersTask;
        var productsResponse = await productsTask;
        var queriesResponse = await queriesTask;

        orders.Clear();
        if (ordersResponse.IsSuccessStatusCode)
        {
            var payload = await ordersResponse.Content.ReadFromJsonAsync<List<UserOrderDto>>();
            orders.AddRange(payload ?? Enumerable.Empty<UserOrderDto>());
        }

        products.Clear();
        if (productsResponse.IsSuccessStatusCode)
        {
            var payload = await productsResponse.Content.ReadFromJsonAsync<List<ProductDto>>();
            products.AddRange(payload ?? Enumerable.Empty<ProductDto>());
        }

        queries.Clear();
        if (queriesResponse.IsSuccessStatusCode)
        {
            var payload = await queriesResponse.Content.ReadFromJsonAsync<List<SupportQueryDto>>();
            queries.AddRange(payload ?? Enumerable.Empty<SupportQueryDto>());
        }

        var selectedQuery = SelectedSupportQuery;
        if (expandedQueryId.HasValue && selectedQuery is null)
        {
            CloseQueryThread();
        }
        else if (selectedQuery is not null)
        {
            activeSupportTicketFilter = IsClosedSupportTicket(selectedQuery.Status)
                ? SupportTicketFilter.Closed
                : SupportTicketFilter.Open;
        }

        ResolveMembership();
    }

