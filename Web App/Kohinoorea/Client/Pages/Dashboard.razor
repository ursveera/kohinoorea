@page "/dashboard"
@implements IDisposable
@using System.Text.RegularExpressions
@using Kohinoorea.Client.Services

<PageTitle>Kohinoorea User Dashboard</PageTitle>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  /* ── Theme tokens ─────────────────────────────────── */
  :root, body[data-theme="dark"] {
    --d-bg:           linear-gradient(135deg,#060810 0%,#0f1623 55%,#040609 100%);
    --d-glow1:        rgba(255,196,87,0.18);
    --d-glow2:        rgba(128,90,213,0.18);
    --d-text:         #f0f4ff;
    --d-muted:        #7b8fa8;
    --d-sidebar-bg:   rgba(6,9,18,0.82);
    --d-sidebar-border: rgba(255,255,255,0.07);
    --d-brand-sub:    #6b7fa0;
    --d-nav-text:     #b8c8de;
    --d-nav-hover:    rgba(255,255,255,0.08);
    --d-nav-border:   rgba(255,255,255,0.07);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.14),rgba(249,115,22,0.07));
    --d-plan-card-border: rgba(251,191,36,0.2);
    --d-plan-card-text: #c8d4e8;
    --d-profile-bg:   rgba(255,255,255,0.07);
    --d-profile-border: rgba(255,255,255,0.07);
    --d-card-bg:      rgba(255,255,255,0.06);
    --d-card-border:  rgba(255,255,255,0.08);
    --d-card-shimmer: rgba(255,255,255,0.025);
    --d-panel-bg:     rgba(255,255,255,0.06);
    --d-panel-border: rgba(255,255,255,0.08);
    --d-panel-shadow: 0 20px 80px rgba(0,0,0,0.28);
    --d-th-color:     #6b7fa0;
    --d-td-color:     #d1dce8;
    --d-row-border:   rgba(255,255,255,0.07);
    --d-product-bg:   rgba(255,255,255,0.05);
    --d-product-hover: rgba(255,255,255,0.09);
    --d-product-border: rgba(255,255,255,0.07);
    --d-product-img:  linear-gradient(135deg,#1a2235,#2a3a55);
    --d-product-desc: #6b7fa0;
    --d-ghost-bg:     rgba(15,23,42,0.6);
    --d-ghost-border: rgba(255,255,255,0.16);
    --d-ghost-text:   #c8d4e8;
    --d-query-bg:     rgba(255,255,255,0.05);
    --d-query-border: rgba(255,255,255,0.07);
    --d-form-bg:      rgba(255,255,255,0.05);
    --d-form-border:  rgba(255,255,255,0.07);
    --d-input-bg:     rgba(10,16,30,0.88);
    --d-input-border: rgba(255,255,255,0.09);
    --d-input-text:   #f0f4ff;
    --d-label-text:   #b8c8de;
    --d-empty-text:   #6b7fa0;
    --d-divider:      rgba(255,255,255,0.07);
    --d-stat-num:     #fbbf24;
  }

  body[data-theme="light"] {
    --d-bg:           linear-gradient(135deg,#eef2f9 0%,#faf7f0 55%,#f2eefb 100%);
    --d-glow1:        rgba(251,191,36,0.2);
    --d-glow2:        rgba(128,90,213,0.1);
    --d-text:         #111827;
    --d-muted:        #6b7280;
    --d-sidebar-bg:   rgba(255,255,255,0.88);
    --d-sidebar-border: rgba(0,0,0,0.09);
    --d-brand-sub:    #6b7280;
    --d-nav-text:     #374151;
    --d-nav-hover:    rgba(0,0,0,0.05);
    --d-nav-border:   rgba(0,0,0,0.05);
    --d-plan-card-bg: linear-gradient(135deg,rgba(251,191,36,0.1),rgba(249,115,22,0.05));
    --d-plan-card-border: rgba(251,191,36,0.3);
    --d-plan-card-text: #374151;
    --d-profile-bg:   rgba(0,0,0,0.04);
    --d-profile-border: rgba(0,0,0,0.08);
    --d-card-bg:      rgba(255,255,255,0.82);
    --d-card-border:  rgba(0,0,0,0.08);
    --d-card-shimmer: rgba(255,255,255,0.7);
    --d-panel-bg:     rgba(255,255,255,0.88);
    --d-panel-border: rgba(0,0,0,0.08);
    --d-panel-shadow: 0 8px 40px rgba(0,0,0,0.1);
    --d-th-color:     #6b7280;
    --d-td-color:     #374151;
    --d-row-border:   rgba(0,0,0,0.07);
    --d-product-bg:   rgba(255,255,255,0.75);
    --d-product-hover: rgba(255,255,255,0.95);
    --d-product-border: rgba(0,0,0,0.08);
    --d-product-img:  linear-gradient(135deg,#dde3f0,#c7d2e8);
    --d-product-desc: #6b7280;
    --d-ghost-bg:     rgba(255,255,255,0.7);
    --d-ghost-border: rgba(0,0,0,0.14);
    --d-ghost-text:   #374151;
    --d-query-bg:     rgba(255,255,255,0.7);
    --d-query-border: rgba(0,0,0,0.07);
    --d-form-bg:      rgba(255,255,255,0.75);
    --d-form-border:  rgba(0,0,0,0.07);
    --d-input-bg:     rgba(255,255,255,0.95);
    --d-input-border: rgba(0,0,0,0.12);
    --d-input-text:   #111827;
    --d-label-text:   #374151;
    --d-empty-text:   #6b7280;
    --d-divider:      rgba(0,0,0,0.07);
    --d-stat-num:     #d97706;
  }

  /* ── Reset ────────────────────────────────────────── */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Inter", sans-serif;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, var(--d-glow1), transparent 35%),
      radial-gradient(circle at top right, var(--d-glow2), transparent 35%),
      var(--d-bg);
    color: var(--d-text);
    transition: background 0.35s, color 0.25s;
  }

  /* ── Layout ───────────────────────────────────────── */
  .dashboard {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  /* ── Sidebar ──────────────────────────────────────── */
  .sidebar {
    padding: 28px 22px;
    background: var(--d-sidebar-bg);
    border-right: 1px solid var(--d-sidebar-border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: background 0.3s, border-color 0.3s;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 38px;
  }

  .brand-icon {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #111827;
    font-weight: 900;
    box-shadow: 0 10px 30px rgba(251,191,36,0.28);
  }

  .brand h1 {
    font-size: 20px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .brand p {
    font-size: 12px;
    color: var(--d-brand-sub);
    margin-top: 2px;
  }

  .nav-button {
    width: 100%;
    border: 0;
    color: var(--d-nav-text);
    background: transparent;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    margin-bottom: 8px;
    border-radius: 16px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: 0.25s ease;
    text-align: left;
  }

  .nav-button:hover,
  .nav-button.active {
    color: var(--d-text);
    background: var(--d-nav-hover);
    box-shadow: inset 0 0 0 1px var(--d-nav-border);
  }

  .sidebar-card {
    margin-top: 34px;
    padding: 20px;
    border-radius: 22px;
    background: var(--d-plan-card-bg);
    border: 1px solid var(--d-plan-card-border);
    transition: background 0.3s, border-color 0.3s;
  }

  .sidebar-card h3 {
    font-size: 15px;
    color: var(--d-text);
    margin-bottom: 8px;
  }

  .sidebar-card p {
    color: var(--d-plan-card-text);
    font-size: 13px;
    line-height: 1.6;
  }

  /* ── Main area ────────────────────────────────────── */
  .main {
    padding: 28px;
    overflow: hidden;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .topbar h2 {
    font-size: 32px;
    letter-spacing: -0.06em;
    color: var(--d-text);
  }

  .topbar p {
    color: var(--d-muted);
    margin-top: 6px;
  }

  .profile {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    border-radius: 999px;
    background: var(--d-profile-bg);
    border: 1px solid var(--d-profile-border);
    transition: background 0.3s, border-color 0.3s;
  }

  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fbbf24, #a855f7);
    display: grid;
    place-items: center;
    font-weight: 800;
    color: #fff;
  }

  .profile span {
    display: block;
    font-size: 13px;
    color: var(--d-muted);
  }

  /* ── Stat cards ───────────────────────────────────── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }

  .stat-card {
    position: relative;
    border: 1px solid var(--d-card-border);
    background: var(--d-card-bg);
    border-radius: 28px;
    padding: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-card::after {
    content: "";
    position: absolute;
    right: -35px;
    top: -35px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(251,191,36,0.1);
    pointer-events: none;
  }

  .stat-card:hover,
  .stat-card.active {
    transform: translateY(-6px);
    border-color: rgba(251,191,36,0.4);
    box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 0 0 1px rgba(251,191,36,0.1), inset 0 1px 0 var(--d-card-shimmer);
  }

  .stat-icon {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    font-size: 24px;
    background: var(--d-nav-hover);
    margin-bottom: 18px;
    border: 1px solid var(--d-card-border);
  }

  .stat-card h3 {
    font-size: 18px;
    margin-bottom: 8px;
    color: var(--d-text);
  }

  .stat-card p {
    color: var(--d-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .stat-number {
    margin-top: 18px;
    font-size: 30px;
    font-weight: 800;
    color: var(--d-stat-num);
  }

  /* ── Content panel ────────────────────────────────── */
  .content-panel {
    border: 1px solid var(--d-panel-border);
    background: var(--d-panel-bg);
    border-radius: 30px;
    padding: 26px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: var(--d-panel-shadow);
    animation: fadeIn 0.35s ease;
    transition: background 0.3s, border-color 0.3s;
  }

  .content-panel.support-maximized {
    height: calc(100vh - 225px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  @@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 22px;
  }

  .panel-header h3 {
    font-size: 24px;
    letter-spacing: -0.04em;
    color: var(--d-text);
  }

  .badge {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(34,197,94,0.11);
    color: #22c55e;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(34,197,94,0.22);
  }

  /* ── Table ────────────────────────────────────────── */
  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 760px;
  }

  th, td {
    padding: 16px 14px;
    text-align: left;
    border-bottom: 1px solid var(--d-row-border);
    font-size: 14px;
  }

  th {
    color: var(--d-th-color);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  td { color: var(--d-td-color); }

  /* ── Status pills ─────────────────────────────────── */
  .status {
    display: inline-flex;
    padding: 7px 11px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
  }

  .delivered { background: rgba(34,197,94,0.12);  color: #16a34a; }
  .pending   { background: rgba(251,191,36,0.12); color: #d97706; }
  .cancelled { background: rgba(248,113,113,0.12);color: #dc2626; }
  .open      { background: rgba(96,165,250,0.12); color: #2563eb; }
  .closed    { background: rgba(148,163,184,0.12);color: #6b7280; }

  body[data-theme="dark"] .delivered { color: #86efac; }
  body[data-theme="dark"] .pending   { color: #fde68a; }
  body[data-theme="dark"] .cancelled { color: #fca5a5; }
  body[data-theme="dark"] .open      { color: #93c5fd; }
  body[data-theme="dark"] .closed    { color: #cbd5e1; }

  /* ── Product grid ─────────────────────────────────── */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .product-card {
    padding: 18px;
    border-radius: 24px;
    border: 1px solid var(--d-product-border);
    background: var(--d-product-bg);
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
    box-shadow: inset 0 1px 0 var(--d-card-shimmer);
  }

  .product-card:hover {
    transform: translateY(-4px);
    background: var(--d-product-hover);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12), inset 0 1px 0 var(--d-card-shimmer);
  }

  .product-img {
    height: 150px;
    border-radius: 18px;
    background: var(--d-product-img);
    display: grid;
    place-items: center;
    font-size: 48px;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card h4 {
    margin-bottom: 8px;
    font-size: 16px;
    color: var(--d-text);
  }

  .product-card p {
    color: var(--d-product-desc);
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .price {
    color: #f59e0b;
    font-size: 18px;
    font-weight: 800;
  }

  /* ── Buttons ──────────────────────────────────────── */
  .buy-btn,
  .submit-btn {
    border: 0;
    padding: 10px 14px;
    border-radius: 14px;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #111827;
    font-weight: 800;
    cursor: pointer;
    transition: 0.2s ease;
    box-shadow: 0 4px 16px rgba(251,191,36,0.28);
  }

  .buy-btn:hover,
  .submit-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 22px rgba(251,191,36,0.38);
  }

  .ghost-btn {
    border: 1px solid var(--d-ghost-border);
    padding: 9px 13px;
    border-radius: 12px;
    background: var(--d-ghost-bg);
    color: var(--d-ghost-text);
    font-weight: 700;
    cursor: pointer;
    font-size: 13px;
    transition: background 0.2s, border-color 0.2s;
  }

  .ghost-btn:hover {
    border-color: rgba(251,191,36,0.35);
    color: #f59e0b;
  }

  /* ── Support ──────────────────────────────────────── */
  .support-layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 22px;
    height: 68vh;
    min-height: 0;
    overflow: hidden;
  }

  .support-layout.maximized {
    grid-template-columns: 1fr;
    max-height: none;
    height: 100%;
  }

  .support-layout > * { min-height: 0; }

  .support-layout.maximized .support-form { display: none; }

  .query-list {
    display: grid;
    gap: 14px;
    overflow-y: auto;
    padding-right: 6px;
    min-height: 0;
    max-height: 100%;
    height: 100%;
    align-content: start;
  }

  .query-card {
    padding: 18px;
    border-radius: 20px;
    background: var(--d-query-bg);
    border: 1px solid var(--d-query-border);
    transition: background 0.3s, border-color 0.3s;
  }

  .query-card h4 { margin-bottom: 8px; color: var(--d-text); }

  .query-card p {
    color: var(--d-muted);
    font-size: 14px;
    line-height: 1.55;
    margin-bottom: 12px;
  }

  .query-thread {
    margin-top: 14px;
    border-top: 1px solid var(--d-divider);
    padding-top: 14px;
    display: grid;
    gap: 10px;
  }

  .chat-bubble {
    max-width: 82%;
    padding: 10px 12px;
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.5;
  }

  .chat-bubble.user {
    justify-self: end;
    background: rgba(251,191,36,0.18);
    border: 1px solid rgba(251,191,36,0.3);
    color: #d97706;
  }

  body[data-theme="dark"] .chat-bubble.user {
    color: #fde68a;
    background: rgba(251,191,36,0.18);
  }

  .chat-bubble.admin {
    justify-self: start;
    background: rgba(96,165,250,0.12);
    border: 1px solid rgba(96,165,250,0.22);
    color: #2563eb;
  }

  body[data-theme="dark"] .chat-bubble.admin {
    color: #bfdbfe;
    background: rgba(96,165,250,0.15);
  }

  .chat-meta {
    display: block;
    margin-top: 6px;
    font-size: 11px;
    opacity: 0.75;
  }

  .inline-reply {
    margin-top: 10px;
    display: grid;
    gap: 10px;
  }

  .query-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--d-muted);
  }

  .support-form {
    padding: 20px;
    border-radius: 24px;
    background: var(--d-form-bg);
    border: 1px solid var(--d-form-border);
    transition: background 0.3s, border-color 0.3s;
  }

  .support-form label {
    display: block;
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 700;
    color: var(--d-label-text);
  }

  .support-form input,
  .support-form textarea,
  .support-form select {
    width: 100%;
    border: 1px solid var(--d-input-border);
    background: var(--d-input-bg);
    color: var(--d-input-text);
    padding: 13px 14px;
    border-radius: 16px;
    outline: none;
    margin-bottom: 14px;
    font-size: 14px;
    transition: border-color 0.2s, background 0.2s;
  }

  .support-form input:focus,
  .support-form textarea:focus,
  .support-form select:focus {
    border-color: rgba(251,191,36,0.4);
  }

  .support-form textarea {
    min-height: 130px;
    resize: vertical;
  }

  /* ── Misc ─────────────────────────────────────────── */
  .empty-note {
    color: var(--d-empty-text);
    line-height: 1.7;
  }

  @@media (max-width: 1100px) {
    .cards,
    .product-grid,
    .support-layout {
      grid-template-columns: 1fr;
    }
  }

  @@media (max-width: 820px) {
    .dashboard { grid-template-columns: 1fr; }
    .sidebar { position: static; }
    .topbar { align-items: flex-start; flex-direction: column; }
  }
</style>

@if (canRenderDashboard)
{
<div class="dashboard">
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-icon">K</div>
      <div>
        <h1>Kohinoorea</h1>
        <p>Premium User Panel</p>
      </div>
    </div>

    <button class="nav-button @(activeSection == DashboardSection.Overview ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Overview)">🏠 Overview</button>
    <button class="nav-button @(activeSection == DashboardSection.Orders ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Orders)">📦 Orders</button>
    <button class="nav-button @(activeSection == DashboardSection.Products ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Products)">💎 Products</button>
    <button class="nav-button @(activeSection == DashboardSection.Support ? "active" : null)" type="button" @onclick="() => NavigateToSection(DashboardSection.Support)">🎧 Support</button>

    <div class="sidebar-card">
      <h3>@CurrentPlanName</h3>
      <p>@MembershipMessage</p>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div>
        <h2>@PageTitle</h2>
        <p>Manage your orders, discover admin-posted products, and contact support.</p>
      </div>
      <div class="profile">
        <div class="avatar">@AvatarInitial</div>
        <div>
          <strong>@CurrentPlanName</strong>
          <span>@ProfileEmail</span>
        </div>
      </div>
    </header>

    <section class="cards">
      <div class="stat-card @(activeSection == DashboardSection.Orders ? "active" : null)" @onclick="() => NavigateToSection(DashboardSection.Orders)">
        <div class="stat-icon">📦</div>
        <h3>Orders</h3>
        <p>View your ordered items and complete transaction history.</p>
        <div class="stat-number">@orders.Count</div>
      </div>

      <div class="stat-card @(activeSection == DashboardSection.Products ? "active" : null)" @onclick="() => NavigateToSection(DashboardSection.Products)">
        <div class="stat-icon">💎</div>
        <h3>Products</h3>
        <p>Browse premium products posted by the admin.</p>
        <div class="stat-number">@products.Count</div>
      </div>

      <div class="stat-card @(activeSection == DashboardSection.Support ? "active" : null)" @onclick="() => NavigateToSection(DashboardSection.Support)">
        <div class="stat-icon">🎧</div>
        <h3>Support</h3>
        <p>See your queries or send a custom question to admin.</p>
        <div class="stat-number">@queries.Count</div>
      </div>
    </section>

    <section id="@CurrentSectionAnchor" class="content-panel @(activeSection == DashboardSection.Support && isSupportMaximized ? "support-maximized" : null)">
      @if (activeSection == DashboardSection.Overview)
      {
        <div class="panel-header">
          <h3>Dashboard Overview</h3>
          <span class="badge">@(currentPlanName == "No Plan" ? "No Active Plan" : currentPlanName)</span>
        </div>
        <p class="empty-note">
          Select Orders to view your transaction history. Select Products to view admin products and add to cart. Select Support to view/send your queries.
        </p>
      }
      else if (activeSection == DashboardSection.Orders)
      {
        <div class="panel-header">
          <h3>Orders & Transaction History</h3>
          <span class="badge">Secure Records</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Product</th>
                <th>Date</th>
                <th>Amount</th>
                <th>Payment</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              @if (orders.Count == 0)
              {
                <tr><td colspan="6">No orders found.</td></tr>
              }
              else
              {
                @foreach (var order in orders)
                {
                  <tr>
                    <td><strong>ORD-@order.OrderId</strong></td>
                    <td>@order.ProductName</td>
                    <td>@order.OrderedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>@currency.FormatFromUsd(order.TotalAmount)</td>
                    <td>@(string.IsNullOrWhiteSpace(order.PaymentMethod) ? "Card" : order.PaymentMethod)</td>
                    <td><span class="status @GetStatusCss(order.Status)">@((string.IsNullOrWhiteSpace(order.Status) ? "Pending" : order.Status))</span></td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      }
      else if (activeSection == DashboardSection.Products)
      {
        <div class="panel-header">
          <h3>Premium Product Collection</h3>
          <span class="badge">Posted by Admin</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(productStatusMessage))
        {
          <p class="summary-caption">@productStatusMessage</p>
        }
        <div class="product-grid">
          @if (products.Count == 0)
          {
            <p class="empty-note">No products posted yet.</p>
          }
          else
          {
            @foreach (var product in products)
            {
              <div class="product-card">
                <div class="product-img">
                  <img src="@GetProductImageUrl(product)" alt="@product.Name" loading="lazy" />
                </div>
                <h4>@product.Name</h4>
                @{
                  var descRaw = product.Description ?? string.Empty;
                  var descMatch = Regex.Match(descRaw, @"<p>(.*?)</p>", RegexOptions.Singleline);
                  var descText = descMatch.Success
                    ? currency.ReplacePricesInTextFromUsd(descMatch.Groups[1].Value.Trim())
                    : (string.IsNullOrWhiteSpace(descRaw) ? "No description available." : currency.ReplacePricesInTextFromUsd(descRaw));
                }
                <p>@descText</p>
                <div class="price-row">
                  <span class="price">@currency.FormatFromUsd(product.Price)</span>
                  <div style="display:flex; gap:8px;">
                    <button class="buy-btn" type="button" @onclick="() => AddToCartAsync(product.Id, product.Name)">Add to Cart</button>
                    <button class="buy-btn" type="button" style="background:linear-gradient(135deg,#a855f7,#7c3aed);" @onclick="() => NavigateToBuyProduct(product.Id)">Buy Now</button>
                  </div>
                </div>
              </div>
            }
          }
        </div>
      }
      else if (activeSection == DashboardSection.Support)
      {
        <div class="panel-header">
          <h3>Queries & Custom Support</h3>
          <div style="display:flex; gap:10px; align-items:center;">
            <span class="badge">Admin Support</span>
            <button class="ghost-btn" type="button" @onclick="ToggleSupportMaximize">@(isSupportMaximized ? "Minimize" : "Maximize")</button>
          </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(supportStatusMessage))
        {
          <p class="summary-caption">@supportStatusMessage</p>
        }
        <div class="support-layout @(isSupportMaximized ? "maximized" : null)">
          <div class="query-list">
            @if (queries.Count == 0)
            {
              <p class="empty-note">No support queries yet.</p>
            }
            else
            {
              @foreach (var query in queries)
              {
                <div class="query-card">
                  <h4>@query.Subject</h4>
                  <p><strong>@query.Category:</strong> @query.Message</p>
                  <div class="query-meta">
                    <span>@query.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                    <span style="display:flex; align-items:center; gap:10px;">
                      <span class="status @GetStatusCss(query.Status)">@query.Status</span>
                      <button class="ghost-btn" type="button" @onclick="() => ToggleQueryThreadAsync(query.Id)">@(expandedQueryId == query.Id ? "Close" : "Open")</button>
                    </span>
                  </div>

                  @if (expandedQueryId == query.Id)
                  {
                    <div class="query-thread">
                      @if (activeQueryMessages.Count == 0)
                      {
                        <p class="empty-note">No replies yet.</p>
                      }
                      else
                      {
                        @foreach (var message in activeQueryMessages)
                        {
                          var bubbleCss = string.Equals(message.SenderRole, AuthRoles.Admin, StringComparison.OrdinalIgnoreCase) ? "admin" : "user";
                          <div class="chat-bubble @bubbleCss">
                            @message.Message
                            <span class="chat-meta">@message.SenderRole • @message.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                          </div>
                        }
                      }
                    </div>
                  }
                </div>
              }
            }

            @if (expandedQueryId.HasValue)
            {
              <EditForm class="inline-reply" Model="replyRequest" OnValidSubmit="SubmitReplyAsync">
                <DataAnnotationsValidator />
                <InputTextArea @bind-Value="replyRequest.Message" placeholder="Reply to this query..." />
                <button class="submit-btn" type="submit">Send Reply</button>
              </EditForm>
            }
          </div>

          <EditForm class="support-form" Model="supportRequest" OnValidSubmit="SubmitSupportAsync">
            <DataAnnotationsValidator />
            <label>Subject</label>
            <InputText @bind-Value="supportRequest.Subject" placeholder="Enter query subject" />

            <label>Category</label>
            <InputSelect @bind-Value="supportRequest.Category">
              <option value="Order">Order</option>
              <option value="Payment">Payment</option>
              <option value="Product">Product</option>
              <option value="General">General</option>
            </InputSelect>

            <label>Your Question</label>
            <InputTextArea @bind-Value="supportRequest.Message" placeholder="Write your question for admin..." />

            <button class="submit-btn" type="submit">Send to Admin</button>
          </EditForm>
        </div>
      }
    </section>
  </main>
</div>
}

@inject HttpClient Http
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS

@code {
    private CurrencyContext currency = CurrencyContext.FromCountryCode("US");
    private enum DashboardSection
    {
        Overview,
        Orders,
        Products,
        Support
    }

    private readonly List<UserOrderDto> orders = new();
    private readonly List<ProductDto> products = new();
    private readonly List<SupportQueryDto> queries = new();
    private readonly List<SupportQueryMessageDto> activeQueryMessages = new();
    private CreateSupportQueryRequest supportRequest = new();
    private CreateSupportQueryMessageRequest replyRequest = new();

    private bool canRenderDashboard;
    private DashboardSection activeSection = DashboardSection.Overview;
    private string profileEmail = string.Empty;
    private string currentPlanName = "No Plan";
    private string membershipMessage = "No active plan found for your account.";
    private string? productStatusMessage;
    private string? supportStatusMessage;
    private bool isSupportMaximized;
    private long? expandedQueryId;
    private string? pendingScrollAnchor;

    private string ProfileEmail => profileEmail;
    private string CurrentPlanName => currentPlanName;
    private string MembershipMessage => membershipMessage;
    private string PageTitle => activeSection switch
    {
        DashboardSection.Orders => "Your Orders",
        DashboardSection.Products => "Admin Posted Products",
        DashboardSection.Support => "Support Center",
        _ => "Welcome back, User"
    };

    private string AvatarInitial => string.IsNullOrWhiteSpace(profileEmail)
        ? "U"
        : profileEmail.Trim()[0].ToString().ToUpperInvariant();

    private string CurrentSectionAnchor => GetSectionHash(activeSection);

    protected override async Task OnInitializedAsync()
    {
      Navigation.LocationChanged += HandleLocationChanged;

        currency = await CurrencyContext.ResolveAsync(Http, LocalStorage);

        var meResponse = await Http.GetAsync("api/auth/me");
        if (!meResponse.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        var me = await meResponse.Content.ReadFromJsonAsync<AuthResponse>();
        profileEmail = me?.Email ?? string.Empty;

        await LoadDashboardDataAsync();
        ApplySectionFromUri(Navigation.Uri, shouldQueueScroll: true);
        canRenderDashboard = true;
    }

      protected override async Task OnAfterRenderAsync(bool firstRender)
      {
        if (!string.IsNullOrWhiteSpace(pendingScrollAnchor))
        {
          var anchor = pendingScrollAnchor;
          pendingScrollAnchor = null;
          await JS.InvokeVoidAsync("eval", $"document.getElementById('{anchor}')?.scrollIntoView({{ behavior: 'smooth', block: 'start' }});");
        }

        await base.OnAfterRenderAsync(firstRender);
      }

    private void SetSection(DashboardSection section)
    {
        activeSection = section;
        if (section != DashboardSection.Support)
        {
            isSupportMaximized = false;
            expandedQueryId = null;
            activeQueryMessages.Clear();
            replyRequest = new CreateSupportQueryMessageRequest();
        }
    }

        private void NavigateToSection(DashboardSection section)
        {
          SetSection(section);
          pendingScrollAnchor = GetSectionHash(section);
          Navigation.NavigateTo($"/dashboard#{GetSectionHash(section)}", replace: true);
        }

        private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
        {
          ApplySectionFromUri(e.Location, shouldQueueScroll: true);
          _ = InvokeAsync(StateHasChanged);
        }

        private void ApplySectionFromUri(string uri, bool shouldQueueScroll)
        {
          var fragment = Navigation.ToAbsoluteUri(uri).Fragment.TrimStart('#').ToLowerInvariant();
          var section = fragment switch
          {
            "orders" => DashboardSection.Orders,
            "products" => DashboardSection.Products,
            "support" => DashboardSection.Support,
            _ => DashboardSection.Overview
          };

          SetSection(section);
          if (shouldQueueScroll)
          {
            pendingScrollAnchor = GetSectionHash(section);
          }
        }

        private static string GetSectionHash(DashboardSection section)
        {
          return section switch
          {
            DashboardSection.Orders => "orders",
            DashboardSection.Products => "products",
            DashboardSection.Support => "support",
            _ => "overview"
          };
        }

        public void Dispose()
        {
          Navigation.LocationChanged -= HandleLocationChanged;
        }

    private void ToggleSupportMaximize()
    {
        isSupportMaximized = !isSupportMaximized;
    }

    private async Task ToggleQueryThreadAsync(long queryId)
    {
        if (expandedQueryId == queryId)
        {
            expandedQueryId = null;
            activeQueryMessages.Clear();
            replyRequest = new CreateSupportQueryMessageRequest();
            return;
        }

        expandedQueryId = queryId;
        replyRequest = new CreateSupportQueryMessageRequest();
        await LoadThreadMessagesAsync(queryId);
    }

    private async Task LoadThreadMessagesAsync(long queryId)
    {
        var response = await Http.GetAsync($"api/commerce/support/my/{queryId}/messages");
        if (!response.IsSuccessStatusCode)
        {
            supportStatusMessage = "Unable to load query conversation.";
            activeQueryMessages.Clear();
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<List<SupportQueryMessageDto>>();
        activeQueryMessages.Clear();
        activeQueryMessages.AddRange(payload ?? Enumerable.Empty<SupportQueryMessageDto>());
    }

    private async Task SubmitReplyAsync()
    {
        if (!expandedQueryId.HasValue)
        {
            return;
        }

        var response = await Http.PostAsJsonAsync($"api/commerce/support/my/{expandedQueryId.Value}/messages", replyRequest);
        if (!response.IsSuccessStatusCode)
        {
            supportStatusMessage = "Unable to send reply.";
            return;
        }

        supportStatusMessage = "Reply sent.";
        replyRequest = new CreateSupportQueryMessageRequest();
        await LoadThreadMessagesAsync(expandedQueryId.Value);
    }

    private async Task LoadDashboardDataAsync()
    {
        productStatusMessage = null;
        supportStatusMessage = null;

        var ordersTask = Http.GetAsync("api/commerce/orders/my");
        var productsTask = Http.GetAsync("api/commerce/products");
        var queriesTask = Http.GetAsync("api/commerce/support/my");

        await Task.WhenAll(ordersTask, productsTask, queriesTask);

        var ordersResponse = await ordersTask;
        var productsResponse = await productsTask;
        var queriesResponse = await queriesTask;

        orders.Clear();
        if (ordersResponse.IsSuccessStatusCode)
        {
            var payload = await ordersResponse.Content.ReadFromJsonAsync<List<UserOrderDto>>();
            orders.AddRange(payload ?? Enumerable.Empty<UserOrderDto>());
        }

        products.Clear();
        if (productsResponse.IsSuccessStatusCode)
        {
            var payload = await productsResponse.Content.ReadFromJsonAsync<List<ProductDto>>();
            products.AddRange(payload ?? Enumerable.Empty<ProductDto>());
        }

        queries.Clear();
        if (queriesResponse.IsSuccessStatusCode)
        {
            var payload = await queriesResponse.Content.ReadFromJsonAsync<List<SupportQueryDto>>();
            queries.AddRange(payload ?? Enumerable.Empty<SupportQueryDto>());
        }

        ResolveMembership();
    }

    private sealed class CartItem
    {
        public long ProductId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; } = 1;
    }

    private const string CartKey = "kohinoor_cart";

    private async Task AddToCartAsync(long productId, string productName = "")
    {
        var product = products.FirstOrDefault(p => p.Id == productId);
        if (product is null)
        {
            productStatusMessage = "Product not found.";
            return;
        }

        var cart = await LocalStorage.GetItemAsync<List<CartItem>>(CartKey) ?? new List<CartItem>();
        var existing = cart.FirstOrDefault(i => i.ProductId == productId);
        if (existing is not null)
            existing.Quantity++;
        else
            cart.Add(new CartItem { ProductId = product.Id, Name = product.Name, Description = product.Description, UnitPrice = product.Price, Quantity = 1 });

        await LocalStorage.SetItemAsync(CartKey, cart);
        Navigation.NavigateTo("/cart", true);
    }

    private async Task SubmitSupportAsync()
    {
        supportStatusMessage = null;

        var response = await Http.PostAsJsonAsync("api/commerce/support/my", supportRequest);
        if (!response.IsSuccessStatusCode)
        {
            supportStatusMessage = "Unable to send query.";
            return;
        }

        supportStatusMessage = "Your query has been sent to admin.";
        supportRequest = new CreateSupportQueryRequest();
        await LoadDashboardDataAsync();

        if (expandedQueryId.HasValue)
        {
            await LoadThreadMessagesAsync(expandedQueryId.Value);
        }
    }

    private void ResolveMembership()
    {
        var activeOrder = orders
            .Where(order => string.Equals(order.Status, "Active", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(order => order.OrderedAtUtc)
            .FirstOrDefault();

        if (activeOrder is null)
        {
            currentPlanName = "No Plan";
            membershipMessage = "No active plan found for your account.";
            return;
        }

        currentPlanName = string.IsNullOrWhiteSpace(activeOrder.ProductName) ? "Active Plan" : activeOrder.ProductName;
        membershipMessage = $"You are currently on {currentPlanName}.";
    }

    private static string GetStatusCss(string? status)
    {
        var value = status?.Trim().ToLowerInvariant();
        return value switch
        {
            "delivered" => "delivered",
            "cancelled" => "cancelled",
            "closed" => "closed",
            "open" => "open",
            "active" => "open",
            _ => "pending"
        };
    }

    private void NavigateToBuyProduct(long productId)
    {
        Navigation.NavigateTo($"/buy-product?productId={productId}", true);
    }

    private static string GetProductImageUrl(ProductDto product)
    {
        if (!string.IsNullOrWhiteSpace(product.ImageLink))
        {
            return product.ImageLink.Trim();
        }

        var name = product.Name?.ToLowerInvariant() ?? string.Empty;

        if (name.Contains("monthly", StringComparison.Ordinal))
        {
            return "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80";
        }

        if (name.Contains("annual", StringComparison.Ordinal))
        {
            return "https://images.unsplash.com/photo-1551281044-8b66f0f6c1b0?auto=format&fit=crop&w=800&q=80";
        }

        if (name.Contains("lifetime", StringComparison.Ordinal))
        {
            return "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=800&q=80";
        }

        return "https://images.unsplash.com/photo-1556740749-887f6717d7e4?auto=format&fit=crop&w=800&q=80";
    }
}
