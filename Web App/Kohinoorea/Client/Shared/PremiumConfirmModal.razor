@inherits PremiumConfirmModalBase

<div class="modal-backdrop" style="@(IsVisible ? "display:block;" : "display:none;")">
    <div class="modal-dialog premium-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Title</h5>
                <button type="button" class="close" @onclick="OnCancel">&times;</button>
            </div>
            <div class="modal-body">
                <p>@Message</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-premium-yes" @onclick="OnYes">Yes</button>
                <button class="btn btn-premium-no" @onclick="OnCancel">No</button>
            </div>
        </div>
    </div>
</div>

@code {
    private async Task OnYes()
    {
        if (OnResult.HasDelegate)
            await OnResult.InvokeAsync(true);
        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
    }

    private async Task OnCancel()
    {
        if (OnResult.HasDelegate)
            await OnResult.InvokeAsync(false);
        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
    }
}
